# Copy this file to .env and fill in real values.
# The real .env is git-ignored — never commit secrets.

# Required for lessons 05–07 and lesson 14 (GitHub provider)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# Required for lessons 08–13
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_AI_API_KEY=your_azure_ai_api_key_here
AZURE_AI_MODEL_DEPLOYMENT_NAME=Kimi-K2-Thinking

# Optional provider controls (used by lesson 14 provider abstraction)
# PROVIDER=github
# LOCALFOUNDRY_ENDPOINT=http://localhost:5272/v1/
# LOCALFOUNDRY_MODEL=qwen2.5-0.5b-instruct-generic-gpu:4
