
# ── A2A Examples — environment variables template ────────────────────────────
# Copy this file to .env and fill in real values.
# The real .env is git-ignored — NEVER commit secrets.
#
# This file belongs at:  a2a/.env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── Provider selector (optional override — default: github) ──────────────────
# Uncomment to override the default provider in all notebooks.
# PROVIDER=github

# ── GitHub Models (Lessons 05–07, free with a GitHub account) ────────────────
# Visit: https://github.com/settings/tokens  (no special scopes needed)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# ── Azure AI Foundry (Lessons 08–13, Kimi-K2 / Kimi-K2-Thinking) ─────────────
# Visit: https://ai.azure.com  → create project → deploy Kimi-K2 (free tier)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_AI_API_KEY=your_azure_ai_api_key_here
AZURE_AI_MODEL_DEPLOYMENT_NAME=Kimi-K2-Thinking

# ── AI Toolkit LocalFoundry (local inference, no token needed) ────────────────
# Requires VS Code AI Toolkit extension: https://aka.ms/aitoolkit
# LOCALFOUNDRY_ENDPOINT=http://localhost:5272/v1/
# LOCALFOUNDRY_MODEL=qwen2.5-0.5b-instruct-generic-gpu:4

# ── Ollama (local inference, no token needed) ─────────────────────────────────
# Requires Ollama installed: https://ollama.com
# Start your model first:  ollama run qwen3.5:2b
OLLAMA_ENDPOINT=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen3.5:2b
