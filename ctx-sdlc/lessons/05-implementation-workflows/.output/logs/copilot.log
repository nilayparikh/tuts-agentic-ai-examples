: pref,\r\n95.         loanState,\r\n96.       });\r\n97. \r\n98.       if (!writeDecision.allowed) {\r\n99.         res.status(400).json({ error: writeDecision.reason });\r\n100.         return;\r\n101.       }\r\n102. \r\n103.       prefRepo.setPreference(pref);\r\n104. \r\n105.       // Audit the preference change\r\n106.       auditAction(\r\n107.         session,\r\n108.         \"preference.updated\",\r\n109.         previous ?? null,\r\n110.         pref,\r\n111.         \"notification-routes\",\r\n112.       );\r\n113. \r\n114.       res.json(pref);\r\n115.     } catch (err) {\r\n116.       next(err);\r\n117.     }\r\n118.   },\r\n119. );\r\n120. "
