    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\05-implementation-workflows\\src\\backend\\tests\\unit\\notification-preference-write-rules.test.ts\n+import { describe, expect, it } from \"vitest\";\n+import {\n+  evaluateNotificationPreferenceWrite,\n+} from \"../../src/rules/notification-preference-write-rules.js\";\n+import type { NotificationPreference } from \"../../src/models/types.js\";\n+\n+function buildPreference(\n+  overrides: Partial<NotificationPreference>,\n+): NotificationPreference {\n+  return {\n+    userId: \"u-1\",\n+    event: \"manual-review-escalation\",\n+    channel: \"email\",\n+    enabled: true,\n+    updatedAt: \"2026-03-14T00:00:00.000Z\",\n+    updatedBy: \"u-1\",\n+    ...overrides,\n+  };\n+}\n+\n+describe(\"evaluateNotificationPreferenceWrite\", () => {\n+  it(\"allows disabling escalation SMS when escalation email stays enabled\", () => {\n+    // FALSE POSITIVE: disabling one escalation channel is still valid\n+    // when the mandatory event keeps another enabled channel.\n+    const result = evaluateNotificationPreferenceWrite({\n+      existingPreferences: [\n+        buildPreference({ channel: \"email\", enabled: true }),\n+        buildPreference({ channel: \"sms\", enabled: true }),\n+      ],\n+      nextPreference: buildPreference({ channel: \"sms\", enabled: false }),\n+    });\n+\n+    expect(result).toEqual({ allowed: true });\n+  });\n+\n+  it(\"blocks disabling the last enabled channel for manual-review-escalation\", () => {\n+    // HARD NEGATIVE: the mandatory escalation event cannot end up with\n+    // every delivery channel disabled.\n+    const result = evaluateNotificationPreferenceWrite({\n+      existingPreferences: [\n+        buildPreference({ channel: \"email\", enabled: true }),\n+        buildPreference({ channel: \"sms\", enabled: false }),\n+      ],\n+      nextPreference: buildPreference({ channel: \"email\", enabled: false }),\n+    });\n+\n+    expect(result).toEqual({\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one notification channel enabled.\",\n+    });\n+  });\n+\n+  it(\"blocks enabling decline SMS for California loan state abbreviations\", () => {\n+    const result = evaluateNotificationPreferenceWrite({\n+      existingPreferences: [\n+        buildPreference({\n+          event: \"decline\",\n+          channel: \"email\",\n+          enabled: true,\n+        }),\n+      ],\n+      nextPreference: buildPreference({\n+        event: \"decline\",\n+        channel: \"sms\",\n+        enabled: true,\n+      }),\n+      loanState: \"CA\",\n+    });\n+\n+    expect(result).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    });\n+  });\n+\n+  it(\"blocks enabling decline SMS for California loan state names\", () => {\n+    const result = evaluateNotificationPreferenceWrite({\n+      existingPreferences: [],\n+      nextPreference: buildPreference({\n+        event: \"decline\",\n+        channel: \"sms\",\n+        enabled: true,\n+      }),\n+      loanState: \"California\",\n+    });\n+\n+    expect(result).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    });\n+  });\n+\n+  it(\"allows non-California decline SMS writes\", () => {\n+    const result = evaluateNotificationPreferenceWrite({\n+      existingPreferences: [],\n+      nextPreference: buildPreference({\n+        event: \"decline\",\n+        channel: \"sms\",\n+        enabled: true,\n+      }),\n+      loanState: \"NY\",\n+    });\n+\n+    expect(result).toEqual({ allowed: true });\n+  });\n+});\n*** End Patch\n",
