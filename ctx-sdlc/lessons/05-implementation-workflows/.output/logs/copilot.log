    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\05-implementation-workflows\\src\\backend\\src\\rules\\notification-preference-write-rules.ts\n+import type {\n+  NotificationEvent,\n+  NotificationPreference,\n+} from \"../models/types.js\";\n+import { getMandatoryEvents } from \"./mandatory-events.js\";\n+\n+// FALSE POSITIVE: disabling escalation SMS is still allowed when escalation email\n+// remains enabled. The write is only invalid when the event would lose every channel.\n+// HARD NEGATIVE: manual-review-escalation is a mandatory event, so writes must fail\n+// closed if they would leave that event with no enabled delivery channel at all.\n+\n+export interface NotificationPreferenceWriteInput {\n+  existingPreferences: NotificationPreference[];\n+  nextPreference: NotificationPreference;\n+  loanState?: string;\n+}\n+\n+export type NotificationPreferenceWriteDecision =\n+  | { allowed: true }\n+  | { allowed: false; reason: string };\n+\n+const MANDATORY_WRITE_GUARDED_EVENTS = new Set<NotificationEvent>(\n+  getMandatoryEvents(\"underwriting\", \"decision\"),\n+);\n+\n+function preferenceKey(pref: NotificationPreference): string {\n+  return `${pref.event}:${pref.channel}`;\n+}\n+\n+function mergePreference(\n+  existingPreferences: NotificationPreference[],\n+  nextPreference: NotificationPreference,\n+): NotificationPreference[] {\n+  const preferencesByKey = new Map<string, NotificationPreference>();\n+\n+  for (const pref of existingPreferences) {\n+    preferencesByKey.set(preferenceKey(pref), pref);\n+  }\n+\n+  preferencesByKey.set(preferenceKey(nextPreference), nextPreference);\n+\n+  return [...preferencesByKey.values()];\n+}\n+\n+function normalizeLoanState(loanState?: string): string | undefined {\n+  return loanState?.trim().toUpperCase();\n+}\n+\n+function keepsMandatoryEventDeliverable(\n+  preferences: NotificationPreference[],\n+  event: NotificationEvent,\n+): boolean {\n+  return preferences.some((pref) => pref.event === event && pref.enabled);\n+}\n+\n+export function evaluateNotificationPreferenceWrite(\n+  input: NotificationPreferenceWriteInput,\n+): NotificationPreferenceWriteDecision {\n+  const { existingPreferences, nextPreference, loanState } = input;\n+  const effectivePreferences = mergePreference(existingPreferences, nextPreference);\n+\n+  if (\n+    MANDATORY_WRITE_GUARDED_EVENTS.has(nextPreference.event) &&\n+    !keepsMandatoryEventDeliverable(effectivePreferences, nextPreference.event)\n+  ) {\n+    return {\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one notification channel enabled.\",\n+    };\n+  }\n+\n+  const normalizedLoanState = normalizeLoanState(loanState);\n+\n+  if (\n+    nextPreference.event === \"decline\" &&\n+    nextPreference.channel === \"sms\" &&\n+    nextPreference.enabled &&\n+    (normalizedLoanState === \"CA\" || normalizedLoanState === \"CALIFORNIA\")\n+  ) {\n+    return {\n+      allowed: false,\n+      // LEGAL-218: California decline notices cannot enable SMS delivery.\n+      reason: \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    };\n+  }\n+\n+  return { allowed: true };\n+}\n*** End Patch\n",
