    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\05-implementation-workflows\\src\\backend\\tests\\unit\\notification-preference-write-rules.test.ts\n+import { describe, expect, it } from \"vitest\";\n+\n+import type { NotificationPreference } from \"../../src/models/types.js\";\n+import { evaluateNotificationPreferenceWrite } from \"../../src/rules/notification-preference-write-rules.js\";\n+\n+const basePreference: NotificationPreference = {\n+  userId: \"uw-1\",\n+  event: \"approval\",\n+  channel: \"email\",\n+  enabled: true,\n+  updatedAt: \"2026-03-14T00:00:00.000Z\",\n+  updatedBy: \"uw-1\",\n+};\n+\n+function makePreference(\n+  overrides: Partial<NotificationPreference>,\n+): NotificationPreference {\n+  return {\n+    ...basePreference,\n+    ...overrides,\n+  };\n+}\n+\n+describe(\"Notification Preference Write Rules\", () => {\n+  it(\"allows disabling escalation SMS when escalation email remains enabled\", () => {\n+    // FALSE POSITIVE: disabling one channel is allowed when the other channel stays enabled.\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [\n+          makePreference({\n+            event: \"manual-review-escalation\",\n+            channel: \"email\",\n+            enabled: true,\n+          }),\n+          makePreference({\n+            event: \"manual-review-escalation\",\n+            channel: \"sms\",\n+            enabled: true,\n+          }),\n+        ],\n+        nextPreference: makePreference({\n+          event: \"manual-review-escalation\",\n+          channel: \"sms\",\n+          enabled: false,\n+        }),\n+      }),\n+    ).toEqual({ allowed: true });\n+  });\n+\n+  it(\"rejects disabling the last enabled escalation channel\", () => {\n+    // HARD NEGATIVE: a mandatory escalation event cannot end up with no enabled channels.\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [\n+          makePreference({\n+            event: \"manual-review-escalation\",\n+            channel: \"email\",\n+            enabled: true,\n+          }),\n+          makePreference({\n+            event: \"manual-review-escalation\",\n+            channel: \"sms\",\n+            enabled: false,\n+          }),\n+        ],\n+        nextPreference: makePreference({\n+          event: \"manual-review-escalation\",\n+          channel: \"email\",\n+          enabled: false,\n+        }),\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one notification channel enabled.\",\n+    });\n+  });\n+\n+  it(\"rejects enabling decline SMS for CA loans\", () => {\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: makePreference({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"CA\",\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    });\n+  });\n+\n+  it(\"rejects enabling decline SMS for California loans spelled out\", () => {\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: makePreference({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"California\",\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    });\n+  });\n+\n+  it(\"allows decline SMS outside California\", () => {\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: makePreference({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"NY\",\n+      }),\n+    ).toEqual({ allowed: true });\n+  });\n+});\n*** End Patch\n",
