    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\05-implementation-workflows\\src\\backend\\src\\rules\\notification-preference-write-rules.ts\n+// ---------------------------------------------------------------------------\n+// Notification Preference Write Rules\n+// ---------------------------------------------------------------------------\n+// FALSE POSITIVE: disabling escalation SMS is allowed when escalation email\n+// remains enabled; the rule protects the last enabled channel, not every\n+// channel.\n+// HARD NEGATIVE: never allow a write that leaves manual-review-escalation with\n+// zero enabled channels, and never allow decline SMS to be enabled for\n+// California loans under LEGAL-218.\n+// ---------------------------------------------------------------------------\n+\n+import type { NotificationPreference } from \"../models/types.js\";\n+import { getMandatoryEvents } from \"./mandatory-events.js\";\n+\n+export interface NotificationPreferenceWriteInput {\n+  existingPreferences: NotificationPreference[];\n+  nextPreference: NotificationPreference;\n+  loanState?: string;\n+}\n+\n+export interface NotificationPreferenceWriteResult {\n+  allowed: boolean;\n+  reason?: string;\n+}\n+\n+const ESCALATION_EVENT = \"manual-review-escalation\";\n+const DECLINE_SMS_REASON =\n+  \"LEGAL-218 prohibits enabling SMS for decline notifications on California loans.\";\n+const ESCALATION_CHANNEL_REASON =\n+  \"manual-review-escalation must keep at least one notification channel enabled.\";\n+\n+function isCaliforniaLoan(loanState?: string): boolean {\n+  const normalized = loanState?.trim().toUpperCase();\n+  return normalized === \"CA\" || normalized === \"CALIFORNIA\";\n+}\n+\n+function isMandatoryEscalationEvent(event: NotificationPreference[\"event\"]): boolean {\n+  return (\n+    event === ESCALATION_EVENT &&\n+    getMandatoryEvents(\"underwriting\", \"decision\").includes(ESCALATION_EVENT)\n+  );\n+}\n+\n+function isChannelEnabled(\n+  preferences: NotificationPreference[],\n+  channel: NotificationPreference[\"channel\"],\n+): boolean {\n+  const preference = preferences.find((pref) => pref.channel === channel);\n+  return preference?.enabled ?? false;\n+}\n+\n+export function validateNotificationPreferenceWrite(\n+  input: NotificationPreferenceWriteInput,\n+): NotificationPreferenceWriteResult {\n+  const { existingPreferences, nextPreference, loanState } = input;\n+\n+  if (\n+    nextPreference.event === \"decline\" &&\n+    nextPreference.channel === \"sms\" &&\n+    nextPreference.enabled &&\n+    isCaliforniaLoan(loanState)\n+  ) {\n+    return {\n+      allowed: false,\n+      reason: DECLINE_SMS_REASON,\n+    };\n+  }\n+\n+  if (isMandatoryEscalationEvent(nextPreference.event)) {\n+    const escalationPreferences = existingPreferences.filter(\n+      (pref) => pref.event === ESCALATION_EVENT,\n+    );\n+\n+    const emailEnabled =\n+      nextPreference.channel === \"email\"\n+        ? nextPreference.enabled\n+        : isChannelEnabled(escalationPreferences, \"email\");\n+    const smsEnabled =\n+      nextPreference.channel === \"sms\"\n+        ? nextPreference.enabled\n+        : isChannelEnabled(escalationPreferences, \"sms\");\n+\n+    if (!emailEnabled && !smsEnabled) {\n+      return {\n+        allowed: false,\n+        reason: ESCALATION_CHANNEL_REASON,\n+      };\n+    }\n+  }\n+\n+  return { allowed: true };\n+}\n*** End Patch\n",
    "call_id": "call_9Xhl4wp8jAF0RlqSbfmzbdmJ"
  },
