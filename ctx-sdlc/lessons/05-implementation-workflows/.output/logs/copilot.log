es: [\n+          makePreference({\n+            event: \"manual-review-escalation\",\n+            channel: \"email\",\n+            enabled: true,\n+          }),\n+          makePreference({\n+            event: \"manual-review-escalation\",\n+            channel: \"sms\",\n+            enabled: false,\n+          }),\n+        ],\n+        nextPreference: makePreference({\n+          event: \"manual-review-escalation\",\n+          channel: \"email\",\n+          enabled: false,\n+        }),\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one notification channel enabled.\",\n+    });\n+  });\n+\n+  it(\"rejects enabling decline SMS for CA loans\", () => {\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: makePreference({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"CA\",\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    });\n+  });\n+\n+  it(\"rejects enabling decline SMS for California loans spelled out\", () => {\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: makePreference({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"California\",\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    });\n+  });\n+\n+  it(\"allows decline SMS outside California\", () => {\n+    expect(\n+      evaluateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: makePreference({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"NY\",\n+      }),\n+    ).toEqual({ allowed: true });\n+  });\n+});\n*** End Patch\n",
