    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\05-implementation-workflows\\src\\backend\\src\\rules\\notification-preference-write-rules.ts\n+// ---------------------------------------------------------------------------\n+// Notification Preference Write Rules\n+// ---------------------------------------------------------------------------\n+// FALSE POSITIVE:\n+//   Disabling manual-review-escalation SMS is still valid when escalation email\n+//   remains enabled. The write should not be rejected just because one channel\n+//   turns off.\n+//\n+// HARD NEGATIVE:\n+//   manual-review-escalation is a mandatory notification event for the\n+//   underwriting -> decision flow. A write must never leave that event with all\n+//   delivery channels disabled.\n+// ---------------------------------------------------------------------------\n+\n+import type { LoanApplication, NotificationPreference } from \"../models/types.js\";\n+import { getMandatoryEvents } from \"./mandatory-events.js\";\n+\n+export interface NotificationPreferenceWriteInput {\n+  existingPreferences: NotificationPreference[];\n+  nextPreference: NotificationPreference;\n+  loanState?: LoanApplication[\"loanState\"];\n+}\n+\n+export type NotificationPreferenceWriteDecision =\n+  | { allowed: true }\n+  | { allowed: false; reason: string };\n+\n+const MANDATORY_WRITE_EVENTS = new Set(\n+  getMandatoryEvents(\"underwriting\", \"decision\"),\n+);\n+\n+export function evaluateNotificationPreferenceWrite(\n+  input: NotificationPreferenceWriteInput,\n+): NotificationPreferenceWriteDecision {\n+  if (blocksCaliforniaDeclineSms(input)) {\n+    return {\n+      allowed: false,\n+      reason: \"LEGAL-218: decline SMS cannot be enabled for California loans.\",\n+    };\n+  }\n+\n+  if (blocksMandatoryEventChannelRemoval(input)) {\n+    return {\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one notification channel enabled.\",\n+    };\n+  }\n+\n+  return { allowed: true };\n+}\n+\n+function blocksCaliforniaDeclineSms({\n+  nextPreference,\n+  loanState,\n+}: NotificationPreferenceWriteInput): boolean {\n+  return (\n+    nextPreference.event === \"decline\" &&\n+    nextPreference.channel === \"sms\" &&\n+    nextPreference.enabled &&\n+    isCaliforniaLoanState(loanState)\n+  );\n+}\n+\n+function blocksMandatoryEventChannelRemoval({\n+  existingPreferences,\n+  nextPreference,\n+}: NotificationPreferenceWriteInput): boolean {\n+  if (\n+    !MANDATORY_WRITE_EVENTS.has(nextPreference.event) ||\n+    nextPreference.enabled\n+  ) {\n+    return false;\n+  }\n+\n+  const nextEventPreferences = mergeNextPreference(existingPreferences, nextPreference)\n+    .filter((preference) => preference.event === nextPreference.event);\n+\n+  return !nextEventPreferences.some((preference) => preference.enabled);\n+}\n+\n+function mergeNextPreference(\n+  existingPreferences: NotificationPreference[],\n+  nextPreference: NotificationPreference,\n+): NotificationPreference[] {\n+  const withoutCurrentChannel = existingPreferences.filter(\n+    (preference) =>\n+      !(\n+        preference.event === nextPreference.event &&\n+        preference.channel === nextPreference.channel\n+      ),\n+  );\n+\n+  return [...withoutCurrentChannel, nextPreference];\n+}\n+\n+function isCaliforniaLoanState(loanState?: LoanApplication[\"loanState\"]): boolean {\n+  if (!loanState) {\n+    return false;\n+  }\n+\n+  const normalized = loanState.trim().toUpperCase();\n+  return normalized === \"CA\" || normalized === \"CALIFORNIA\";\n+}\n*** End Patch\n",
