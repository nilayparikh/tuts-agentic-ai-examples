    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\05-implementation-workflows\\src\\backend\\tests\\unit\\notification-preference-write-rules.test.ts\n+// ---------------------------------------------------------------------------\n+// Notification Preference Write Rules Tests\n+// ---------------------------------------------------------------------------\n+\n+import { describe, expect, it } from \"vitest\";\n+import { validateNotificationPreferenceWrite } from \"../../src/rules/notification-preference-write-rules.js\";\n+import type { NotificationPreference } from \"../../src/models/types.js\";\n+\n+const timestamp = \"2026-03-13T00:00:00.000Z\";\n+\n+function pref(\n+  overrides: Partial<NotificationPreference>,\n+): NotificationPreference {\n+  return {\n+    userId: \"user-1\",\n+    event: \"manual-review-escalation\",\n+    channel: \"email\",\n+    enabled: true,\n+    updatedAt: timestamp,\n+    updatedBy: \"user-1\",\n+    ...overrides,\n+  };\n+}\n+\n+describe(\"Notification Preference Write Rules\", () => {\n+  it(\"blocks disabling the last enabled channel for manual-review-escalation\", () => {\n+    // HARD NEGATIVE: the last mandatory escalation channel must not be disabled.\n+    expect(\n+      validateNotificationPreferenceWrite({\n+        existingPreferences: [\n+          pref({ event: \"manual-review-escalation\", channel: \"email\", enabled: false }),\n+          pref({ event: \"manual-review-escalation\", channel: \"sms\", enabled: true }),\n+        ],\n+        nextPreference: pref({\n+          event: \"manual-review-escalation\",\n+          channel: \"sms\",\n+          enabled: false,\n+        }),\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one notification channel enabled.\",\n+    });\n+  });\n+\n+  it(\"allows disabling escalation SMS when escalation email remains enabled\", () => {\n+    // FALSE POSITIVE: disabling one escalation channel is valid when another stays enabled.\n+    expect(\n+      validateNotificationPreferenceWrite({\n+        existingPreferences: [\n+          pref({ event: \"manual-review-escalation\", channel: \"email\", enabled: true }),\n+          pref({ event: \"manual-review-escalation\", channel: \"sms\", enabled: true }),\n+        ],\n+        nextPreference: pref({\n+          event: \"manual-review-escalation\",\n+          channel: \"sms\",\n+          enabled: false,\n+        }),\n+      }),\n+    ).toEqual({ allowed: true });\n+  });\n+\n+  it(\"blocks enabling decline SMS for CA loans under LEGAL-218\", () => {\n+    expect(\n+      validateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: pref({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"CA\",\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218 prohibits enabling SMS for decline notifications on California loans.\",\n+    });\n+  });\n+\n+  it(\"blocks enabling decline SMS for California loans under LEGAL-218\", () => {\n+    expect(\n+      validateNotificationPreferenceWrite({\n+        existingPreferences: [],\n+        nextPreference: pref({\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+        loanState: \"California\",\n+      }),\n+    ).toEqual({\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218 prohibits enabling SMS for decline notifications on California loans.\",\n+    });\n+  });\n+});\n*** End Patch\n",
