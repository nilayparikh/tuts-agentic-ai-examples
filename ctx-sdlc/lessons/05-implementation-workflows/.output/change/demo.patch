--- a/backend/src/rules/notification-preference-write-rules.ts
+++ b/backend/src/rules/notification-preference-write-rules.ts
@@ -0,0 +1,104 @@
+// ---------------------------------------------------------------------------
+// Notification Preference Write Rules
+// ---------------------------------------------------------------------------
+// FALSE POSITIVE:
+//   Disabling manual-review-escalation SMS is still valid when escalation email
+//   remains enabled. The write should not be rejected just because one channel
+//   turns off.
+//
+// HARD NEGATIVE:
+//   manual-review-escalation is a mandatory notification event for the
+//   underwriting -> decision flow. A write must never leave that event with all
+//   delivery channels disabled.
+// ---------------------------------------------------------------------------
+
+import type { LoanApplication, NotificationPreference } from "../models/types.js";
+import { getMandatoryEvents } from "./mandatory-events.js";
+
+export interface NotificationPreferenceWriteInput {
+  existingPreferences: NotificationPreference[];
+  nextPreference: NotificationPreference;
+  loanState?: LoanApplication["loanState"];
+}
+
+export type NotificationPreferenceWriteDecision =
+  | { allowed: true }
+  | { allowed: false; reason: string };
+
+const MANDATORY_WRITE_EVENTS = new Set(
+  getMandatoryEvents("underwriting", "decision"),
+);
+
+export function evaluateNotificationPreferenceWrite(
+  input: NotificationPreferenceWriteInput,
+): NotificationPreferenceWriteDecision {
+  if (blocksCaliforniaDeclineSms(input)) {
+    return {
+      allowed: false,
+      reason: "LEGAL-218: decline SMS cannot be enabled for California loans.",
+    };
+  }
+
+  if (blocksMandatoryEventChannelRemoval(input)) {
+    return {
+      allowed: false,
+      reason:
+        "manual-review-escalation must keep at least one notification channel enabled.",
+    };
+  }
+
+  return { allowed: true };
+}
+
+function blocksCaliforniaDeclineSms({
+  nextPreference,
+  loanState,
+}: NotificationPreferenceWriteInput): boolean {
+  return (
+    nextPreference.event === "decline" &&
+    nextPreference.channel === "sms" &&
+    nextPreference.enabled &&
+    isCaliforniaLoanState(loanState)
+  );
+}
+
+function blocksMandatoryEventChannelRemoval({
+  existingPreferences,
+  nextPreference,
+}: NotificationPreferenceWriteInput): boolean {
+  if (
+    !MANDATORY_WRITE_EVENTS.has(nextPreference.event) ||
+    nextPreference.enabled
+  ) {
+    return false;
+  }
+
+  const nextEventPreferences = mergeNextPreference(existingPreferences, nextPreference)
+    .filter((preference) => preference.event === nextPreference.event);
+
+  return !nextEventPreferences.some((preference) => preference.enabled);
+}
+
+function mergeNextPreference(
+  existingPreferences: NotificationPreference[],
+  nextPreference: NotificationPreference,
+): NotificationPreference[] {
+  const withoutCurrentChannel = existingPreferences.filter(
+    (preference) =>
+      !(
+        preference.event === nextPreference.event &&
+        preference.channel === nextPreference.channel
+      ),
+  );
+
+  return [...withoutCurrentChannel, nextPreference];
+}
+
+function isCaliforniaLoanState(loanState?: LoanApplication["loanState"]): boolean {
+  if (!loanState) {
+    return false;
+  }
+
+  const normalized = loanState.trim().toUpperCase();
+  return normalized === "CA" || normalized === "CALIFORNIA";
+}

--- a/backend/tests/unit/notification-preference-write-rules.test.ts
+++ b/backend/tests/unit/notification-preference-write-rules.test.ts
@@ -0,0 +1,109 @@
+import { describe, expect, it } from "vitest";
+import {
+  evaluateNotificationPreferenceWrite,
+} from "../../src/rules/notification-preference-write-rules.js";
+import type { NotificationPreference } from "../../src/models/types.js";
+
+function buildPreference(
+  overrides: Partial<NotificationPreference>,
+): NotificationPreference {
+  return {
+    userId: "u-1",
+    event: "manual-review-escalation",
+    channel: "email",
+    enabled: true,
+    updatedAt: "2026-03-14T00:00:00.000Z",
+    updatedBy: "u-1",
+    ...overrides,
+  };
+}
+
+describe("evaluateNotificationPreferenceWrite", () => {
+  it("allows disabling escalation SMS when escalation email stays enabled", () => {
+    // FALSE POSITIVE: disabling one escalation channel is still valid
+    // when the mandatory event keeps another enabled channel.
+    const result = evaluateNotificationPreferenceWrite({
+      existingPreferences: [
+        buildPreference({ channel: "email", enabled: true }),
+        buildPreference({ channel: "sms", enabled: true }),
+      ],
+      nextPreference: buildPreference({ channel: "sms", enabled: false }),
+    });
+
+    expect(result).toEqual({ allowed: true });
+  });
+
+  it("blocks disabling the last enabled channel for manual-review-escalation", () => {
+    // HARD NEGATIVE: the mandatory escalation event cannot end up with
+    // every delivery channel disabled.
+    const result = evaluateNotificationPreferenceWrite({
+      existingPreferences: [
+        buildPreference({ channel: "email", enabled: true }),
+        buildPreference({ channel: "sms", enabled: false }),
+      ],
+      nextPreference: buildPreference({ channel: "email", enabled: false }),
+    });
+
+    expect(result).toEqual({
+      allowed: false,
+      reason:
+        "manual-review-escalation must keep at least one notification channel enabled.",
+    });
+  });
+
+  it("blocks enabling decline SMS for California loan state abbreviations", () => {
+    const result = evaluateNotificationPreferenceWrite({
+      existingPreferences: [
+        buildPreference({
+          event: "decline",
+          channel: "email",
+          enabled: true,
+        }),
+      ],
+      nextPreference: buildPreference({
+        event: "decline",
+        channel: "sms",
+        enabled: true,
+      }),
+      loanState: "CA",
+    });
+
+    expect(result).toEqual({
+      allowed: false,
+      reason:
+        "LEGAL-218: decline SMS cannot be enabled for California loans.",
+    });
+  });
+
+  it("blocks enabling decline SMS for California loan state names", () => {
+    const result = evaluateNotificationPreferenceWrite({
+      existingPreferences: [],
+      nextPreference: buildPreference({
+        event: "decline",
+        channel: "sms",
+        enabled: true,
+      }),
+      loanState: "California",
+    });
+
+    expect(result).toEqual({
+      allowed: false,
+      reason:
+        "LEGAL-218: decline SMS cannot be enabled for California loans.",
+    });
+  });
+
+  it("allows non-California decline SMS writes", () => {
+    const result = evaluateNotificationPreferenceWrite({
+      existingPreferences: [],
+      nextPreference: buildPreference({
+        event: "decline",
+        channel: "sms",
+        enabled: true,
+      }),
+      loanState: "NY",
+    });
+
+    expect(result).toEqual({ allowed: true });
+  });
+});
