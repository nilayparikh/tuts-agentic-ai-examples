    "input": "*** Begin Patch\n*** Update File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\02-curate-project-context\\src\\backend\\src\\routes\\notifications.ts\n@@\n import * as prefRepo from \"../models/preference-repository.js\";\n import type {\n   SessionContext,\n   NotificationPreference,\n+  NotificationEvent,\n+  NotificationChannel,\n } from \"../models/types.js\";\n \n export const notificationRoutes = Router();\n+\n+const STANDARD_NOTIFICATION_EVENTS: NotificationEvent[] = [\n+  \"approval\",\n+  \"decline\",\n+  \"document-request\",\n+  \"manual-review-escalation\",\n+];\n \n function firstParam(value: string | string[]): string {\n   return Array.isArray(value) ? value[0] : value;\n }\n+\n+function assertCanWriteNotificationPreferences(\n+  session: SessionContext,\n+  targetUserId: string,\n+): void {\n+  if (session.delegatedFor) {\n+    throw new Error(\n+      \"FORBIDDEN: Delegated sessions cannot modify notification preferences.\",\n+    );\n+  }\n+\n+  if (session.actor.id !== targetUserId) {\n+    throw new Error(\n+      \"FORBIDDEN: Users can only modify their own notification preferences.\",\n+    );\n+  }\n+\n+  if (!hasPermission(session.actor.role, \"notification-pref:write\")) {\n+    throw new Error(\n+      `FORBIDDEN: Role '${session.actor.role}' cannot modify notification preferences.`,\n+    );\n+  }\n+}\n+\n+function setPreferenceWithAudit(\n+  session: SessionContext,\n+  pref: NotificationPreference,\n+): NotificationPreference {\n+  const previous = prefRepo.findPreference(pref.userId, pref.event, pref.channel);\n+\n+  prefRepo.setPreference(pref);\n+  auditAction(\n+    session,\n+    \"preference.updated\",\n+    previous ?? null,\n+    pref,\n+    \"notification-routes\",\n+  );\n+\n+  return pref;\n+}\n+\n+function setChannelPreferences(\n+  session: SessionContext,\n+  userId: string,\n+  channel: NotificationChannel,\n+  enabled: boolean,\n+): NotificationPreference[] {\n+  const now = new Date().t