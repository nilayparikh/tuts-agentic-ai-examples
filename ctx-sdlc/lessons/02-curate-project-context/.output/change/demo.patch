 import type {
   SessionContext,
   NotificationPreference,
+  NotificationEvent,
+  NotificationChannel,
 } from "../models/types.js";
 
 export const notificationRoutes = Router();
+
+const STANDARD_NOTIFICATION_EVENTS: NotificationEvent[] = [
+  "approval",
+  "decline",
+  "document-request",
+  "manual-review-escalation",
+];
 
 function firstParam(value: string | string[]): string {
   return Array.isArray(value) ? value[0] : value;
+}
+
+function assertCanWriteNotificationPreferences(
+  session: SessionContext,
+  targetUserId: string,
+): void {
+  if (session.delegatedFor) {
+    throw new Error(
+      "FORBIDDEN: Delegated sessions cannot modify notification preferences.",
+    );
+  }
+
+  if (session.actor.id !== targetUserId) {
+    throw new Error(
+      "FORBIDDEN: Users can only modify their own notification preferences.",
+    );
+  }
+
+  if (!hasPermission(session.actor.role, "notification-pref:write")) {
+    throw new Error(
+      `FORBIDDEN: Role '${session.actor.role}' cannot modify notification preferences.`,
+    );
+  }
+}
+
+function setPreferenceWithAudit(
+  session: SessionContext,
+  pref: NotificationPreference,
+): NotificationPreference {
+  const previous = prefRepo.findPreference(pref.userId, pref.event, pref.channel);
+
+  prefRepo.setPreference(pref);
+  auditAction(
+    session,
+    "preference.updated",
+    previous ?? null,
+    pref,
+    "notification-routes",
+  );
+
+  return pref;
+}
+
+function setChannelPreferences(
+  session: SessionContext,
+  userId: string,
+  channel: NotificationChannel,
+  enabled: boolean,
+): NotificationPreference[] {
+  const now = new Date().toISOString();
+
+  return STANDARD_NOTIFICATION_EVENTS.map((event) =>
+    setPreferenceWithAudit(session, {
+      userId,
+      event,
+      channel,
+      enabled,
+      updatedAt: now,
+      updatedBy: session.actor.id,
+    }),
+  );
 }
 
