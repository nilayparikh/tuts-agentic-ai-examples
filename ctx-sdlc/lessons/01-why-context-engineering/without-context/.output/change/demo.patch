@@ -0,0 +1,207 @@
+// ---------------------------------------------------------------------------
+// Manual Review Escalation Service
+// ---------------------------------------------------------------------------
+// Handles escalation workflows for loan applications.  When an application
+// is escalated to manual review, a compliance reviewer is assigned and
+// notified.  Reviewers can then approve, reject, or request additional info.
+// ---------------------------------------------------------------------------
+
+import { v4 as uuid } from "uuid";
+import * as escalationRepo from "../models/escalation-repository.js";
+import * as loanRepo from "../models/loan-repository.js";
+import { broker } from "../queue/broker.js";
+import { auditAction } from "./audit-service.js";
+import type {
+  ManualReviewEscalation,
+  SessionContext,
+} from "../models/types.js";
+import type {
+  AuditRequestedEvent,
+  NotificationRequestedEvent,
+} from "../queue/contracts.js";
+
+/**
+ * Initiate a manual review escalation for a loan application.
+ *
+ * Validation:
+ *  - Application must exist
+ *  - Only authorized roles can escalate (analyst-manager, compliance-reviewer)
+ *  - A compliance-reviewer must be assigned
+ *  - Delegated sessions cannot escalate
+ */
+export function escalateToManualReview(
+  session: SessionContext,
+  applicationId: string,
+  assignedReviewerId: string,
+  reason: string,
+): ManualReviewEscalation {
+  // Guard: delegated sessions cannot escalate
+  if (session.delegatedFor) {
+    throw new Error(
+      "FORBIDDEN: Escalations cannot be initiated in delegated sessions.",
+    );
+  }
+
+  // Guard: only certain roles can escalate
+  const allowedRoles = ["analyst-manager", "compliance-reviewer"];
+  if (!allowedRoles.includes(session.actor.role)) {
+    throw new Error(
+      `FORBIDDEN: Role '${session.actor.role}' cannot escalate applications.`,
+    );
+  }
+
+  const application = loanRepo.findLoanById(applicationId);
+  if (!application) {
+    throw new Error(`NOT_FOUND: Application '${applicationId}' not found.`);
+  }
+
+  // Create escalation record
+  const escalation = escalationRepo.createEscalation({
+    applicationId,
+    escalatedBy: session.actor.id,
+    assignedReviewer: assignedReviewerId,
+    reason,
+  });
+
+  // Emit audit event
+  const now = new Date().toISOString();
+  const auditEvent: AuditRequestedEvent = {
+    eventId: uuid(),
+    timestamp: now,
+    source: "escalation-service",
+    type: "audit.requested",
+    payload: {
+      action: "escalation.initiated",
+      actor: session.actor.id,
+      previousValue: undefined,
+      newValue: escalation,
+      source: "escalation-service",
+    },
+  };
+  broker.emit(auditEvent);
+
+  // Emit notification for the assigned reviewer
+  const notifEvent: NotificationRequestedEvent = {
+    eventId: uuid(),
+    timestamp: now,
+    source: "escalation-service",
+    type: "notification.requested",
+    payload: {
+      userId: assignedReviewerId,
+      event: "manual-review-escalation",
+      subject: `Manual Review Escalation: Application ${applicationId}`,
+      body: `Application ${applicationId} (${application.borrowerName}) has been escalated for manual review. Reason: ${reason}`,
+      preferredChannel: "email",
+    },
+  };
+  broker.emit(notifEvent);
+
+  return escalation;
+}
+
+/**
+ * Resolve a manual review escalation.
+ *
+ * Validation:
+ *  - Escalation must exist and be pending
+ *  - Only the assigned reviewer or compliance-reviewer can resolve
+ *  - Delegated sessions cannot resolve escalations
+ */
+export function resolveEscalation(
+  session: SessionContext,
+  escalationId: string,
+  status: "approved" | "rejected" | "completed",
+  resolutionNotes?: string,
+): ManualReviewEscalation {
+  // Guard: delegated sessions cannot resolve
+  if (session.delegatedFor) {
+    throw new Error(
+      "FORBIDDEN: Escalations cannot be resolved in delegated sessions.",
+    );
+  }
+
+  // Guard: only compliance-reviewers can resolve
+  if (session.actor.role !== "compliance-reviewer") {
+    throw new Error(
+      `FORBIDDEN: Only compliance-reviewers can resolve escalations. Current role: '${session.actor.role}'`,
+    );
+  }
+
+  const escalation = escalationRepo.findEscalationById(escalationId);
+  if (!escalation) {
+    throw new Error(`NOT_FOUND: Escalation '${escalationId}' not found.`);
+  }
+
+  if (escalation.status !== "pending") {
+    throw new Error(
+      `INVALID_STATE: Escalation is already '${escalation.status}'. Only pending escalations can be resolved.`,
+    );
+  }
+
+  // Guard: only assigned reviewer can resolve this escalation
+  if (escalation.assignedReviewer !== session.actor.id) {
+    throw new Error(
+      "FORBIDDEN: You are not assigned to this escalation.",
+    );
+  }
+
+  // Update escalation status
+  const resolved = escalationRepo.updateEscalationStatus(
+    escalationId,
+    status,
+    resolutionNotes,
+  );
+  if (!resolved) {
+    throw new Error(`NOT_FOUND: Escalation '${escalationId}' not found.`);
+  }
+
+  // Emit audit event
+  const now = new Date().toISOString();
+  const auditEvent: AuditRequestedEvent = {
+    eventId: uuid(),
+    timestamp: now,
+    source: "escalation-service",
+    type: "audit.requested",
+    payload: {
+      action: "escalation.resolved",
+      actor: session.actor.id,
+      previousValue: escalation,
+      newValue: resolved,
+      source: "escalation-service",
+    },
+  };
+  broker.emit(auditEvent);
+
+  return resolved;
+}
+
+/**
+ * Get escalation details for a specific escalation
+ */
+export function getEscalation(escalationId: string): ManualReviewEscalation | undefined {
+  return escalationRepo.findEscalationById(escalationId);
+}
+
+/**
+ * Get all escalations for a specific application
+ */
+export function getApplicationEscalations(applicationId: string): ManualReviewEscalation[] {
+  return escalationRepo.findEscalationsByApplication(applicationId);
+}
+
+/**
+ * Get the active (pending) escalation for an application, if any
+ */
+export function getActiveEscalation(applicationId: string): ManualReviewEscalation | undefined {
+  return escalationRepo.findActiveEscalation(applicationId);
+}
+
+/**
+ * Get all escalations assigned to a specific reviewer
+ */
+export function getReviewerEscalations(
+  reviewerId: string,
+  status?: "pending" | "approved" | "rejected" | "completed",
+): ManualReviewEscalation[] {
+  return escalationRepo.findEscalationsByReviewer(reviewerId, status);
+}

