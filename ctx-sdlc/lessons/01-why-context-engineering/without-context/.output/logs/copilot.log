              "arguments": "{\"file_text\":\"// ---------------------------------------------------------------------------\\n// Manual Review Escalation Routes\\n// ---------------------------------------------------------------------------\\n\\nimport { Router } from \\\"express\\\";\\nimport { requireRole } from \\\"../middleware/auth.js\\\";\\nimport { validateBody } from \\\"../middleware/request-validator.js\\\";\\nimport * as escalationService from \\\"../services/escalation-service.js\\\";\\nimport type { SessionContext } from \\\"../models/types.js\\\";\\n\\nexport const escalationRoutes = Router();\\n\\nfunction firstParam(value: string | string[]): string {\\n  return Array.isArray(value) ? value[0] : value;\\n}\\n\\n/**\\n * GET /api/escalations/:applicationId — get all escalations for an application.\\n */\\nescalationRoutes.get(\\n  \\\"/:applicationId\\\",\\n  requireRole(\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"),\\n  (req, res) => {\\n    const escalations = escalationService.getApplicationEscalations(\\n      firstParam(req.params.applicationId),\\n    );\\n    res.json(escalations);\\n  },\\n);\\n\\n/**\\n * GET /api/escalations/reviewer/:reviewerId — get escalations for a reviewer.\\n */\\nescalationRoutes.get(\\n  \\\"/reviewer/:reviewerId\\\",\\n  requireRole(\\\"compliance-reviewer\\\"),\\n  (req, res) => {\\n    const { status } = req.query;\\n    const escalations = escalationService.getReviewerEscalations(\\n      firstParam(req.params.reviewerId),\\n      status as \\\"pending\\\" | \\\"approved\\\" | \\\"rejected\\\" | \\\"completed\\\" | undefined,\\n    );\\n    res.json(escalations);\\n  },\\n);\\n\\n/**\\n * POST /api/escalations — initiate a manual review escalation.\\n * Request body: { applicationId, assignedReviewerId, reason }\\n */\\nescalationRoutes.post(\\n  \\\"/\\\",\\n  requireRole(\\\"analyst-manager\\\", \\\"compliance-reviewer\\\"),\\n  validateBody([\\n    { field: \\\"applicationId\\\", type: \\\"string\\\", required: true },\\n    { field: \\\"assignedReviewerId\\\", type: \\\"string\\\", required: true },\\n    { field: \\\"reason\\\", type: \\\"string\\\", required: true },\\n  ]),\\n  (req, res, next) => {\\n    try {\\n      const session = req.session as SessionContext;\\n      const { applicationId, assignedReviewerId, reason } = req.body;\\n      const escalation = escalationService.escalateToManualReview(\\n        session,\\n        applicationId,\\n        assignedReviewerId,\\n        reason,\\n      );\\n      res.status(201).json(escalation);\\n    } catch (err) {\\n      next(err);\\n    }\\n  },\\n);\\n\\n/**\\n * PATCH /api/escalations/:id/resolve — resolve a manual review escalation.\\n * Request body: { status, resolutionNotes? }\\n * Status must be one of: approved, rejected, completed\\n */\\nescalationRoutes.patch(\\n  \\\"/:id/resolve\\\",\\n  requireRole(\\\"compliance-reviewer\\\"),\\n  validateBody([\\n    { field: \\\"status\\\", type: \\\"string\\\", required: true },\\n    { field: \\\"resolutionNotes\\\", type: \\\"string\\\", required: false },\\n  ]),\\n  (req, res, next) => {\\n    try {\\n      const session = req.session as SessionContext;\\n      const { status, resolutionNotes } = req.body;\\n\\n      // Validate status\\n      const validStatuses = [\\\"approved\\\", \\\"rejected\\\", \\\"completed\\\"];\\n      if (!validStatuses.includes(status)) {\\n        res.status(400).json({\\n          error: `Invalid status. Must be one of: ${validStatuses.join(\\\", \\\")}`,\\n        });\\n        return;\\n      }\\n\\n      const escalation = escalationService.resolveEscalation(\\n        session,\\n        firstParam(req.params.id),\\n        status,\\n        resolutionNotes,\\n      );\\n      res.json(escalation);\\n    } catch (err) {\\n      next(err);\\n    }\\n  },\\n);\\n\\n/**\\n * GET /api/escalations/details/:id — get a specific escalation detail.\\n */\\nescalationRoutes.get(\\n  \\\"/details/:id\\\",\\n  requireRole(\\\"analyst-manager\\\", \\\"compliance-reviewer\\\"),\\n  (req, res) => {\\n    const escalation = escalationService.getEscalation(firstParam(req.params.id));\\n    if (!escalation) {\\n      res.status(404).json({ error: \\\"Escalation not found.\\\" });\\n      return;\\n    }\\n    res.json(escalation);\\n  },\\n);\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\src\\\\routes\\\\escalations.ts\"}",
