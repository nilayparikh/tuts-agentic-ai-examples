 expect(completed[0].status).toBe(\\\"completed\\\");\\n    });\\n  });\\n\\n  describe(\\\"getActiveEscalation\\\", () => {\\n    it(\\\"should return pending escalation for an application\\\", () => {\\n      const active = escalationService.getActiveEscalation(\\\"app-1\\\");\\n      expect(active).toBeDefined();\\n      expect(active?.status).toBe(\\\"pending\\\");\\n    });\\n\\n    it(\\\"should return undefined if no pending escalation\\\", () => {\\n      const active = escalationService.getActiveEscalation(\\\"app-3\\\");\\n      expect(active).toBeUndefined();\\n    });\\n  });\\n});\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\tests\\\\integration\\\\escalations.test.ts\"}",
