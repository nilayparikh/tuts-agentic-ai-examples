    "type": "function",
    "function": {
      "name": "grep",
      "description": "Fast and precise code search using ripgrep. Search for patterns in file contents.",
      "parameters": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string",
            "description": "The regular expression pattern to search for in file contents"
