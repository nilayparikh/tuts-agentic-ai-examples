+/**
+ * Escalate a loan application to manual review.
+ * Does not change the loan status, but emits a notification event.
+ * California high-risk loans (CA, >= $1M) get a special subject prefix.
+ */
+export function manualReviewEscalation(
+  session: SessionContext,
+  applicationId: string,
+): { ok: true; applicationId: string; notificationEventId: string } {
+  if (session.delegatedFor) {
+    throw new Error("FORBIDDEN: Delegated sessions cannot escalate to manual review.");
+  }
+
+  const loan = loanRepo.findLoanById(applicationId);
+  if (!loan) {
+    throw new Error(`NOT_FOUND: Application '${applicationId}' not found.`);
+  }
+
+  const notificationEventId = uuid();
+
+  // Build notification subject with California high-risk prefix if applicable
+  let subject = `Loan ${applicationId}: Manual Review Escalation`;
+  if (
+    featureFlags.californiaRules &&
+    loan.loanState === "CA" &&
+    loan.amount >= 1000000
+  ) {
+    subject = `[CA-HighRisk] ${subject}`;
+  }
+
+  // Emit notification event
+  const notifEvent: NotificationRequestedEvent = {
+    eventId: notificationEventId,
+    timestamp: new Date().toISOString(),
+    source: "loan-service",
+    type: "notification.requested",
+    payload: {
+      userId: loan.assignedUnderwriter,
+      event: "manual-review-escalation",
+      subject,
+      body: `Application ${applicationId} has been escalated for manual review.`,
+      preferredChannel: "email",
+    },
+  };
+  broker.emit(notifEvent);
+
+  // Audit the escalation
+  auditAction(
+    session,
+    "loan.manual-review-requested",
+    null,
+    { applicationId },
+    "loan-service",
+  );
+
+  return {
+    ok: true,
+    applicationId,
+    notificationEventId,
+  };
+}
