+/**
+ * POST /api/applications/:id/manual-review — escalate application to manual review.
+ *
+ * Triggers the manual review escalation workflow for an existing loan.
+ * Does not change the application status.
+ * Emits a notification and audit event.
+ */
+applicationRoutes.post(
+  "/:id/manual-review",
+  requireRole("analyst-manager"),
+  (req, res, next) => {
+    try {
+      const session = req.session as SessionContext;
+      const result = loanService.manualReviewEscalation(
+        session,
+        firstParam(req.params.id),
+      );
+      res.json(result);
+    } catch (err) {
+      next(err);
+    }
+  },
+);

