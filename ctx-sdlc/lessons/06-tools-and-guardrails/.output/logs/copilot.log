    "output": "1. {\n2.   \"hooks\": {\n3.     \"PreToolUse\": [\n4.       {\n5.         \"type\": \"command\",\n6.         \"command\": \"python .github/scripts/check_protected_files.py\",\n7.         \"timeout\": 10\n8.       }\n9.     ]\n10.   }\n11. }"
