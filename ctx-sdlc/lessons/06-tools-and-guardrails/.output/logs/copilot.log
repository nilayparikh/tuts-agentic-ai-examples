          "prompt": {
            "type": "string",
            "description": "The task for the agent to perform. Be specific about what you want. Provide complete context to be able to perform the task."
          },
          "agent_type": {
            "type": "string",
            "enum": [
              "explore",
              "task",
              "general-purpose",
              "code-review"
            ],
            "description": "The type of specialized agent to use for this task."
