    "input": "*** Begin Patch\n*** Add File: src/backend/src/rules/preference-event-channel-validator.ts\n+// ---------------------------------------------------------------------------\n+// Preference Event-Channel Validator\n+// ---------------------------------------------------------------------------\n+// Validates whether a notification preference update leaves an allowed\n+// event/channel combination in place.\n+//\n+// IMPORTANT — MANDATORY EVENTS:\n+//   Events reused from mandatory-events.ts must keep at least one delivery\n+//   channel enabled. Disabling the last channel would make required notices\n+//   impossible to send.\n+//\n+// IMPORTANT — LEGAL-218:\n+//   California decline notifications cannot disable SMS unless email remains\n+//   enabled as a fallback for that event.\n+// ---------------------------------------------------------------------------\n+\n+import { MANDATORY_EVENTS } from \"./mandatory-events.js\";\n+import type {\n+  NotificationChannel,\n+  NotificationEvent,\n+  NotificationPreference,\n+} from \"../models/types.js\";\n+\n+const NOTIFICATION_CHANNELS: NotificationChannel[] = [\"email\", \"sms\"];\n+\n+const MANDATORY_NOTIFICATION_EVENTS = new Set<NotificationEvent>(\n+  Object.values(MANDATORY_EVENTS).flat(),\n+);\n+\n+type EventChannelState = Record<NotificationChannel, boolean>;\n+\n+export interface PreferenceEventChannelValidationInput {\n+  event: NotificationEvent;\n+  channel: NotificationChannel;\n+  enabled: boolean;\n+  existingPreferences: NotificationPreference[];\n+  loanState?: string;\n+}\n+\n+export interface PreferenceEventChannelViolation {\n+  rule: string;\n+  message: string;\n+}\n+\n+function getNextEventChannelState(\n+  input: PreferenceEventChannelValidationInput,\n+): EventChannelState {\n+  const nextState: EventChannelState = {\n+    email: false,\n+    sms: false,\n+  };\n+\n+  for (const pref of input.existingPreferences) {\n+    if (pref.event !== input.event) {\n+      continue;\n+    }\n+\n+    nextState[pref.channel] = pref.enabled;\n+  }\n+\n+  nextState[input.channel] = input.enabled;\n+  return nextState;\n+}\n+\n+function isCaliforniaLoan(loanState?: string): boolean {\n+  return loanState?.toUpperCase() === \"CA\";\n+}\n+\n+export function validatePreferenceEventChannel(\n+  input: PreferenceEventChannelValidationInput,\n+): PreferenceEventChannelViolation[] {\n+  const violations: PreferenceEventChannelViolation[] = [];\n+  const nextState = getNextEventChannelState(input);\n+\n+  if (\n+    MANDATORY_NOTIFICATION_EVENTS.has(input.event) &&\n+    NOTIFICATION_CHANNELS.every((channel) => !nextState[channel])\n+  ) {\n+    violations.push({\n+      rule: \"mandatory-event-channel\",\n+      message: `Mandatory event '${input.event}' must keep at least one notification channel enabled.`,\n+    });\n+  }\n+\n+  if (\n+    isCaliforniaLoan(input.loanState) &&\n+    input.event === \"decline\" &&\n+    input.channel === \"sms\" &&\n+    !input.enabled &&\n+    !nextState.email\n+  ) {\n+    violations.push({\n+      rule: \"LEGAL-218\",\n+      message:\n+        \"LEGAL-218: California decline notifications cannot disable SMS unless email remains enabled.\",\n+    });\n+  }\n+\n+  return violations;\n+}\n+\n+export function assertPreferenceEventChannelAllowed(\n+  input: PreferenceEventChannelValidationInput,\n+): void {\n+  const violations = validatePreferenceEventChannel(input);\n+\n+  if (violations.length > 0) {\n+    throw new Error(\n+      `VALIDATION: ${violations.map((violation) => violation.message).join(\"; \")}`,\n+    );\n+  }\n+}\n*** Update File: src/backend/src/routes/notifications.ts\n@@\n import { requireRole } from \"../middleware/auth.js\";\n import { validateBody } from \"../middleware/request-validator.js\";\n import { hasPermission } from \"../rules/role-permissions.js\";\n+import { assertPreferenceEventChannelAllowed } from \"../rules/preference-event-channel-validator.js\";\n import { auditAction } from \"../services/audit-service.js\";\n import * as prefRepo from \"../models/preference-repository.js\";\n import type {\n   SessionContext,\n   NotificationPreference,\n@@\n \n       const { userId, event, channel, enabled } = req.body;\n       const now = new Date().toISOString();\n+      const existingPreferences = prefRepo.findPreferencesForUser(userId);\n \n       const previous = prefRepo.findPreference(userId, event, channel);\n+\n+      assertPreferenceEventChannelAllowed({\n+        event,\n+        channel,\n+        enabled,\n+        existingPreferences,\n+      });\n \n       const pref: NotificationPreference = {\n         userId,\n         event,\n*** Add File: src/backend/tests/unit/preference-event-channel-validator.test.ts\n+// ---------------------------------------------------------------------------\n+// Preference Event-Channel Validator Tests\n+// ---------------------------------------------------------------------------\n+\n+import { describe, it, expect } from \"vitest\";\n+import {\n+  assertPreferenceEventChannelAllowed,\n+  validatePreferenceEventChannel,\n+} from \"../../src/rules/preference-event-channel-validator.js\";\n+import type { NotificationPreference } from \"../../src/models/types.js\";\n+\n+function buildPreference(\n+  overrides: Partial<NotificationPreference>,\n+): NotificationPreference {\n+  return {\n+    userId: \"u-1\",\n+    event: \"approval\",\n+    channel: \"email\",\n+    enabled: true,\n+    updatedAt: \"2026-03-14T00:00:00.000Z\",\n+    updatedBy: \"u-1\",\n+    ...overrides,\n+  };\n+}\n+\n+describe(\"Preference Event-Channel Validator\", () => {\n+  it(\"allows mandatory events when another channel remains enabled\", () => {\n+    const existingPreferences: NotificationPreference[] = [\n+      buildPreference({ event: \"document-request\", channel: \"email\", enabled: true }),\n+      buildPreference({ event: \"document-request\", channel: \"sms\", enabled: true }),\n+    ];\n+\n+    expect(\n+      validatePreferenceEventChannel({\n