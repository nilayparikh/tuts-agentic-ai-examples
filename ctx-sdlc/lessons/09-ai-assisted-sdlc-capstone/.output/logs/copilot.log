    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\09-ai-assisted-sdlc-capstone\\src\\backend\\src\\rules\\preference-event-channel-validator.ts\n+// ---------------------------------------------------------------------------\n+// Notification Preference Event-Channel Validator\n+// ---------------------------------------------------------------------------\n+// Pure validation for notification preference writes. This hardens the write\n+// surface against invalid event/channel inputs, protects mandatory events from\n+// losing every delivery path, and preserves the LEGAL-218 decline fallback.\n+// ---------------------------------------------------------------------------\n+\n+import type {\n+  NotificationChannel,\n+  NotificationEvent,\n+  NotificationPreference,\n+} from \"../models/types.js\";\n+import { MANDATORY_EVENTS } from \"./mandatory-events.js\";\n+\n+export interface PreferenceEventChannelViolation {\n+  rule: string;\n+  message: string;\n+}\n+\n+export interface PreferenceEventChannelValidationInput {\n+  event: string;\n+  channel: string;\n+  enabled: boolean;\n+  existingPreferences: NotificationPreference[];\n+}\n+\n+const SUPPORTED_NOTIFICATION_EVENTS = [\n+  \"approval\",\n+  \"decline\",\n+  \"document-request\",\n+  \"manual-review-escalation\",\n+] as const satisfies NotificationEvent[];\n+\n+const SUPPORTED_NOTIFICATION_CHANNELS = [\n+  \"email\",\n+  \"sms\",\n+] as const satisfies NotificationChannel[];\n+\n+const MANDATORY_PREFERENCE_EVENTS = new Set<NotificationEvent>(\n+  Object.values(MANDATORY_EVENTS).flat(),\n+);\n+\n+function isNotificationEvent(value: string): value is NotificationEvent {\n+  return SUPPORTED_NOTIFICATION_EVENTS.includes(value as NotificationEvent);\n+}\n+\n+function isNotificationChannel(value: string): value is NotificationChannel {\n+  return SUPPORTED_NOTIFICATION_CHANNELS.includes(value as NotificationChannel);\n+}\n+\n+function getChannelState(\n+  existingPreferences: NotificationPreference[],\n+  event: NotificationEvent,\n+  nextChannel: NotificationChannel,\n+  nextEnabled: boolean,\n+): Record<NotificationChannel, boolean> {\n+  const currentState: Record<NotificationChannel, boolean> = {\n+    email: false,\n+    sms: false,\n+  };\n+\n+  for (const pref of existingPreferences) {\n+    if (pref.event !== event) {\n+      continue;\n+    }\n+\n+    currentState[pref.channel] = pref.enabled;\n+  }\n+\n+  currentState[nextChannel] = nextEnabled;\n+  return currentState;\n+}\n+\n+export function validatePreferenceEventChannel(\n+  input: PreferenceEventChannelValidationInput,\n+): PreferenceEventChannelViolation[] {\n+  const violations: PreferenceEventChannelViolation[] = [];\n+\n+  if (!isNotificationEvent(input.event)) {\n+    violations.push({\n+      rule: \"notification-event\",\n+      message: `Unsupported notification event '${input.event}'.`,\n+    });\n+  }\n+\n+  if (!isNotificationChannel(input.channel)) {\n+    violations.push({\n+      rule: \"notification-channel\",\n+      message: `Unsupported notification channel '${input.channel}'.`,\n+    });\n+  }\n+\n+  if (violations.length > 0) {\n+    return violations;\n+  }\n+\n+  const nextChannels = getChannelState(\n+    input.existingPreferences,\n+    input.event,\n+    input.channel,\n+    input.enabled,\n+  );\n+\n+  if (\n+    MANDATORY_PREFERENCE_EVENTS.has(input.event) &&\n+    !nextChannels.email &&\n+    !nextChannels.sms\n+  ) {\n+    violations.push({\n+      rule: \"mandatory-event-channel\",\n+      message: `Mandatory event '${input.event}' must keep at least one notification channel enabled.`,\n+    });\n+  }\n+\n+  // LEGAL-218: decline notifications must preserve an email fallback whenever\n+  // SMS is turned off on the preference surface.\n+  if (\n+    input.event === \"decline\" &&\n+    input.channel === \"sms\" &&\n+    !input.enabled &&\n+    !nextChannels.email\n+  ) {\n+    violations.push({\n+      rule: \"LEGAL-218\",\n+      message:\n+        \"LEGAL-218: decline SMS cannot be disabled unless email remains enabled as a fallback.\",\n+    });\n+  }\n+\n+  return violations;\n+}\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\09-ai-assisted-sdlc-capstone\\src\\backend\\tests\\unit\\preference-event-channel-validator.test.ts\n+// ---------------------------------------------------------------------------\n+// Preference Event-Channel Validator Tests\n+// ---------------------------------------------------------------------------\n+\n+import { describe, it, expect } from \"vitest\";\n+import { validatePreferenceEventChannel } from \"../../src/rules/preference-event-channel-validator.js\";\n+import type { NotificationPreference } from \"../../src/models/types.js\";\n+\n+function makePreference(\n+  overrides: Partial<NotificationPreference>,\n+): NotificationPreference {\n+  return {\n+    userId: \"u-1\",\n+    event: \"approval\",\n+    channel: \"email\",\n+    enabled: true,\n+    updatedAt: \"2026-03-14T00:00:00.000Z\",\n+    updatedBy: \"u-1\",\n+    ...overrides,\n+  };\n+}\n+\n+describe(\"Preference Event-Channel Validator\", () => {\n+  it(\"allows valid event-channel combinations\", () => {\n+    const violations = validatePreferenceEventChannel({\n+      event: \"approval\",\n+      channel: \"sms\",\n+      enabled: false,\n+      existingPreferences: [\n+        makePreference({ event: \"approval\", channel: \"email\", enabled: true }),\n+        makePreference({ event: \"approval\", channel: \"sms\", enabled: true }),\n+      ],\n+    });\n+\n+    expect(violations).toEqual([]);\n+  });\n+\n+  it(\"rejects disabling the last channel for a mandatory event\", () => {\n+    const violations = validatePreferenceEventChannel({\n+      event: \"manual-review-escalation\",\n+      channel: \"sms\",\n+      enabled: false,\n+      existingPreferences: [\n+        makePreference({\n+          event: \"manual-review-escalation\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+      ],\n+    });\n+\n+    expect(violations).toHaveLength(1);\n+    expect(violations[0].rule).toBe(\"mandatory-event-channel\");\n+  });\n+\n+  it(\"avoids a LEGAL-218 false positive when email fallback stays enabled\", () => {\n+    const violations = validatePreferenceEventChannel({\n+      event: \"decline\",\n+      channel: \"sms\",\n+      enabled: false,\n+      existingPreferences: [\n+        makePreference({ event: \"decline\", channel: \"email\", enabled: true }),\n+        makePreference({ event: \"decline\", channel: \"sms\", enabled: true }),\n+      ],\n+    });\n+\n+    expect(violations).toEqual([]);\n+  });\n+\n+  it(\"rejects the LEGAL-218 hard negative when decline SMS loses email fallback\", () => {\n+    const violations = validatePreferenceEventChannel({\n+      event: \"decline\",\n+      channel: \"sms\",\n+      enabled: false,\n+      existingPreferences: [\n+        makePreference({ event: \"decline\", channel: \"email\", enabled: false }),\n+        makePreference({ event: \"decline\", channel: \"sms\", enabled: true }),\n+      ],\n+    });\n+\n+    expect(violations).toHaveLength(1);\n+    expect(violations[0].rule).toBe(\"LEGAL-218\");\n+  });\n+});\n*** Update File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\09-ai-assisted-sdlc-capstone\\src\\backend\\src\\routes\\notifications.ts\n@@\n import { requireRole } from \"../middleware/auth.js\";\n import { validateBody } from \"../middleware/request-validator.js\";\n import { hasPermission } from \"../rules/role-permissions.js\";\n+import { validatePreferenceEventChannel } from \"../rules/preference-event-channel-validator.js\";\n import { auditAction } from \"../services/audit-service.js\";\n import * as prefRepo from \"../models/preference-repository.js\";\n@@\n       }\n \n       const { userId, event, channel, enabled } = req.body;\n       const now = new Date().toISOString();\n+      const existingPreferences = prefRepo.findPreferencesForUser(userId);\n+      const validationErrors = validatePreferenceEventChannel({\n+        event,\n+        channel,\n+        enabled,\n+        existingPreferences,\n+      });\n+\n+      if (validationErrors.length > 0) {\n+        res.status(400).json({\n+          error: \"Validation failed.\",\n+          details: validationErrors.map((violation) => violation.message),\n+        });\n+        return;\n+      }\n \n       const previous = prefRepo.findPreference(userId, event, channel);\n*** End Patch\n",
    "call_id": "call_SZoVl9ynGXkP7e7vBzZszJUT"
