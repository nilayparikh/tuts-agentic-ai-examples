--- a/backend/src/rules/notification-channel-rules.ts
+++ b/backend/src/rules/notification-channel-rules.ts
@@ -0,0 +1,174 @@
+// ---------------------------------------------------------------------------
+// Notification Channel Rules
+// ---------------------------------------------------------------------------
+// Validates when disabling a notification channel is allowed, particularly
+// for mandatory notification events.
+//
+// KEY RESTRICTION — LEGAL-218 (California Decline SMS):
+//   Loans from California (loan_state = "CA") CANNOT disable SMS for decline
+//   events.  This is a regulatory requirement for California commercial loans.
+//   This blocks the scenario: "I'll just skip SMS for decline notifications
+//   on my California loan". Email must be enabled as a fallback.
+//
+// FALSE POSITIVES (looks like violation, actually correct):
+//   1. Disabling SMS for decline on a NEW YORK loan is always allowed.
+//   2. Disabling EMAIL for decline on California is allowed (SMS remains as
+//      fallback).
+//   3. Disabling SMS for APPROVAL on California is allowed (approval is not
+//      subject to the decline restriction).
+//   4. Disabling a channel when the OTHER channel remains enabled counts as
+//      valid fallback (e.g., disable SMS if email is still on).
+//
+// HARD NEGATIVES (looks correct, actually violates rules):
+//   1. Disabling SMS for decline on a California loan when email is also
+//      disabled — no fallback exists.
+//   2. Disabling both SMS and EMAIL for any mandatory event is always a
+//      violation (customer cannot be reached).
+//   3. Attempting to disable SMS for decline on California even if it's
+//      currently the only enabled channel.
+// ---------------------------------------------------------------------------
+
+import type {
+  ApplicationState,
+  NotificationChannel,
+  NotificationEvent,
+  NotificationPreference,
+} from "../models/types.js";
+import { getMandatoryEvents } from "./mandatory-events.js";
+
+export interface ChannelDisableResult {
+  allowed: boolean;
+  reason: string;
+}
+
+/**
+ * Check if disabling a notification channel is allowed for a given event
+ * and user jurisdiction.
+ *
+ * @param event - The notification event (e.g., "decline", "approval")
+ * @param channel - The channel being disabled ("email" or "sms")
+ * @param loanState - The loan's state (jurisdiction), e.g. "CA", "NY"
+ * @param currentPreferences - The user's current notification preferences
+ * @param transition - Optional state transition context (e.g., "decision->finalized")
+ *                     to determine if the event is mandatory in that transition
+ * @returns Object with `allowed` boolean and human-readable `reason`
+ */
+export function canDisableChannel(
+  event: NotificationEvent,
+  channel: NotificationChannel,
+  loanState: string,
+  currentPreferences: NotificationPreference[],
+  transition?: `${string}->${string}`,
+): ChannelDisableResult {
+  // Determine if this event is mandatory for the given transition
+  let isMandatory = false;
+  if (transition) {
+    const parts = transition.split("->");
+    if (parts.length === 2) {
+      const [from, to] = parts;
+      // Validate that the parsed states are valid ApplicationState values
+      const validStates: ApplicationState[] = [
+        "intake",
+        "review",
+        "underwriting",
+        "decision",
+        "finalized",
+      ];
+      if (validStates.includes(from as ApplicationState) && validStates.includes(to as ApplicationState)) {
+        const mandatoryForTransition = getMandatoryEvents(
+          from as ApplicationState,
+          to as ApplicationState,
+        );
+        isMandatory = mandatoryForTransition.includes(event);
+      }
+    }
+  }
+
+  // LEGAL-218: California decline restriction
+  // Cannot disable SMS for decline events on California loans
+  if (
+    event === "decline" &&
+    channel === "sms" &&
+    loanState.toUpperCase() === "CA"
+  ) {
+    // Check if email is the alternative fallback
+    const emailPref = currentPreferences.find(
+      (p) => p.event === event && p.channel === "email",
+    );
+
+    if (!emailPref || !emailPref.enabled) {
+      return {
+        allowed: false,
+        reason:
+          "LEGAL-218: California loans cannot disable SMS for decline events unless email is enabled as a fallback.",
+      };
+    }
+
+    // Email is enabled, so SMS can be disabled (email is the fallback)
+  }
+
+  // Mandatory events require at least one channel enabled
+  // Cannot disable if this is the last enabled channel for a mandatory event
+  if (isMandatory && event) {
+    const otherChannel = channel === "email" ? "sms" : "email";
+    const otherPref = currentPreferences.find(
+      (p) => p.event === event && p.channel === otherChannel,
+    );
+
+    // If the other channel is disabled, this disable would leave no fallback
+    if (!otherPref || !otherPref.enabled) {
+      return {
+        allowed: false,
+        reason: `Cannot disable ${channel} for mandatory event '${event}'. At least one notification channel must remain enabled.`,
+      };
+    }
+  }
+
+  // Default: allow the disable
+  return {
+    allowed: true,
+    reason: `${channel.charAt(0).toUpperCase() + channel.slice(1)} can be disabled for ${event}.`,
+  };
+}
+
+/**
+ * Validate all proposed channel disables in a batch.
+ * Useful for bulk preference updates where multiple channels may be disabled.
+ *
+ * @param disableRequests - Array of { event, channel, newEnabled }
+ * @param loanState - The loan's state
+ * @param currentPreferences - Current user preferences
+ * @param transition - Optional state transition context
+ * @returns Array of violations; empty if all disables are allowed
+ */
+export function validateChannelDisables(
+  disableRequests: Array<{
+    event: NotificationEvent;
+    channel: NotificationChannel;
+    newEnabled: boolean;
+  }>,
+  loanState: string,
+  currentPreferences: NotificationPreference[],
+  transition?: `${string}->${string}`,
+): ChannelDisableResult[] {
+  const violations: ChannelDisableResult[] = [];
+
+  for (const request of disableRequests) {
+    // Only check if the request is to disable (newEnabled = false)
+    if (!request.newEnabled) {
+      const result = canDisableChannel(
+        request.event,
+        request.channel,
+        loanState,
+        currentPreferences,
+        transition,
+      );
+
+      if (!result.allowed) {
+        violations.push(result);
+      }
+    }
+  }
+
+  return violations;
+}

--- a/backend/tests/unit/notification-channel-rules.test.ts
+++ b/backend/tests/unit/notification-channel-rules.test.ts
