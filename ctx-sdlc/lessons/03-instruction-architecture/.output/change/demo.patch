+// ---------------------------------------------------------------------------
+// Notification Channel Rules Tests
+// ---------------------------------------------------------------------------
+
+import { describe, it, expect } from "vitest";
+import {
+  canDisableChannel,
+  validateChannelDisables,
+} from "../../src/rules/notification-channel-rules.js";
+import type {
+  NotificationEvent,
+  NotificationChannel,
+  NotificationPreference,
+} from "../../src/models/types.js";
+
+// Base preference set for testing
+const basePreferences: NotificationPreference[] = [
+  {
+    userId: "user-1",
+    event: "decline",
+    channel: "email",
+    enabled: true,
+    updatedAt: new Date().toISOString(),
+    updatedBy: "system",
+  },
+  {
+    userId: "user-1",
+    event: "decline",
+    channel: "sms",
+    enabled: true,
+    updatedAt: new Date().toISOString(),
+    updatedBy: "system",
+  },
+  {
+    userId: "user-1",
+    event: "approval",
+    channel: "email",
+    enabled: true,
+    updatedAt: new Date().toISOString(),
+    updatedBy: "system",
+  },
+  {
+    userId: "user-1",
+    event: "approval",
+    channel: "sms",
+    enabled: true,
+    updatedAt: new Date().toISOString(),
+    updatedBy: "system",
+  },
+];
+
+describe("Notification Channel Rules", () => {
+  describe("LEGAL-218: California Decline SMS Restriction", () => {
+    // HARD NEGATIVE: California decline SMS disable when email disabled
+    // This looks like a normal toggle but actually violates LEGAL-218
+    it("rejects SMS disable for decline on CA when email is disabled", () => {
+      const caPreferences = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" && p.channel === "sms" ? true : false,
+      }));
+
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        "CA",
+        caPreferences,
+      );
+
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("LEGAL-218");
+      expect(result.reason).toContain("California");
+    });
+
+    // FALSE POSITIVE: Disabling SMS decline on CA is OK if email is enabled
+    // This looks like violation but is actually correct.
+    it("allows SMS disable for decline on CA when email is enabled", () => {
+      const caPreferences = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" ? p.channel === "email" : true,
+      }));
+
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        "CA",
+        caPreferences,
+      );
+
+      expect(result.allowed).toBe(true);
+      expect(result.reason).toContain("disabled");
+    });
+
+    // HAPPY PATH: Non-CA states have no decline SMS restriction
+    it("allows SMS disable for decline on non-CA states", () => {
+      const nyPreferences = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" ? p.channel === "sms" : true,
+      }));
+
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        "NY",
+        nyPreferences,
+      );
+
+      expect(result.allowed).toBe(true);
+    });
+
+    // FALSE POSITIVE: Email disable on CA is OK (SMS is fallback for decline)
+    // This looks like violation but is actually correct because SMS remains.
+    it("allows email disable for decline on CA if SMS is enabled", () => {
+      const caPreferences = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" ? p.channel === "sms" : true,
+      }));
+
+      const result = canDisableChannel(
+        "decline",
+        "email",
+        "CA",
+        caPreferences,
+      );
+
+      expect(result.allowed).toBe(true);
+    });
+
+    // BOUNDARY: CA state check is case-insensitive
+    it("handles California state code case-insensitively", () => {
+      const caPreferences = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" ? p.channel === "email" : true,
+      }));
+
+      // Test with lowercase "ca"
+      const resultLower = canDisableChannel(
+        "decline",
+        "sms",
+        "ca",
+        caPreferences,
+      );
+      expect(resultLower.allowed).toBe(true);
+
+      // Test with mixed case "Ca"
+      const resultMixed = canDisableChannel(
+        "decline",
+        "sms",
+        "Ca",
+        caPreferences,
+      );
+      expect(resultMixed.allowed).toBe(true);
+    });
+  });
+
+  describe("Mandatory Event Constraints", () => {
+    // HARD NEGATIVE: Disabling last enabled channel for mandatory event
+    // This looks valid but violates mandatory event delivery.
+    it("rejects channel disable if it's the only enabled channel for mandatory event", () => {
+      const transition = "decision->finalized"; // "approval" is mandatory here
+      const prefs = basePreferences.map((p) => ({
+        ...p,
+        enabled:
+          p.event === "approval" && p.channel === "email"
+            ? true // only email is enabled for approval
+            : p.event === "approval"
+              ? false // disable SMS for approval
+              : true,
+      }));
+
+      const result = canDisableChannel(
+        "approval",
+        "email",
+        "NY",
+        prefs,
+        transition,
+      );
+
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("mandatory event");
+      expect(result.reason).toContain("one notification channel");
+    });
+
+    // HAPPY PATH: Disabling one channel is OK if other is enabled for mandatory event
+    it("allows disabling one channel for mandatory event if other is enabled", () => {
+      const transition = "decision->finalized";
+      const prefs = basePreferences; // both channels enabled
+
+      const result = canDisableChannel(
+        "approval",
+        "sms",
+        "NY",
+        prefs,
+        transition,
+      );
+
+      expect(result.allowed).toBe(true);
+    });
+
+    // FALSE POSITIVE: Non-mandatory events have no fallback requirement
+    // Disabling all channels for non-mandatory events is allowed.
+    it("allows all channels disabled for non-mandatory events", () => {
+      const prefs = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "approval", // only approval enabled
+      }));
+
+      // "document-request" is not mandatory in all transitions
+      const result = canDisableChannel(
+        "document-request",
+        "sms",
+        "NY",
+        prefs,
+      );
+
+      expect(result.allowed).toBe(true);
+    });
+
+    // BOUNDARY: Transition context matters for mandatory event classification
+    it("treats event as non-mandatory when transition is not mandatory", () => {
+      // "approval" is mandatory for decision->finalized, but not for all transitions
+      const transition = "intake->review"; // approval is not mandatory here
+
+      const prefs = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "approval" ? p.channel === "email" : true,
+      }));
+
+      const result = canDisableChannel(
+        "approval",
+        "email",
+        "NY",
+        prefs,
+        transition,
+      );
+
+      expect(result.allowed).toBe(true); // Allowed because not mandatory in this transition
+    });
+  });
+
+  describe("Event-Specific Rules", () => {
+    // FALSE POSITIVE: SMS disable on non-decline events on CA is allowed
+    // This looks like it might violate LEGAL-218 but only applies to decline.
+    it("allows SMS disable for approval on CA (LEGAL-218 only applies to decline)", () => {
+      const prefs = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "approval" ? p.channel === "email" : true,
+      }));
+
+      const result = canDisableChannel(
+        "approval",
+        "sms",
+        "CA",
+        prefs,
+      );
+
+      expect(result.allowed).toBe(true);
+    });
+
+    // HAPPY PATH: Multiple events can have independent channel states
+    it("handles multiple different events with different channel states", () => {
+      const prefs: NotificationPreference[] = [
+        {
+          userId: "user-1",
+          event: "decline",
+          channel: "email",
+          enabled: true,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+        {
+          userId: "user-1",
+          event: "decline",
+          channel: "sms",
+          enabled: true,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+        {
+          userId: "user-1",
+          event: "approval",
+          channel: "email",
+          enabled: false,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+        {
+          userId: "user-1",
+          event: "approval",
+          channel: "sms",
+          enabled: true,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+      ];
+
+      // Can disable SMS for decline (email is fallback)
+      const declineResult = canDisableChannel("decline", "sms", "CA", prefs);
+      expect(declineResult.allowed).toBe(true);
+
+      // Can disable SMS for approval (only SMS enabled, but approval not mandatory here)
+      const approvalResult = canDisableChannel("approval", "sms", "CA", prefs);
+      expect(approvalResult.allowed).toBe(true);
+    });
+  });
+
+  describe("Batch Validation", () => {
+    // HAPPY PATH: Bulk disable with no violations
+    it("validates multiple disables successfully", () => {
+      const disableRequests = [
+        { event: "approval" as NotificationEvent, channel: "sms" as NotificationChannel, newEnabled: false },
+        { event: "decline", channel: "email" as NotificationChannel, newEnabled: false },
+      ];
+
+      const violations = validateChannelDisables(
+        disableRequests,
+        "CA",
+        basePreferences,
+      );
+
+      expect(violations).toHaveLength(0);
+    });
+
+    // HARD NEGATIVE: Batch disable violates CA decline SMS restriction
+    it("catches LEGAL-218 violation in batch", () => {
+      const caPreferences = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" && p.channel === "sms" ? true : false,
+      }));
+
+      const disableRequests = [
+        { event: "decline" as NotificationEvent, channel: "sms" as NotificationChannel, newEnabled: false },
+      ];
+
+      const violations = validateChannelDisables(
+        disableRequests,
+        "CA",
+        caPreferences,
+      );
+
+      expect(violations).toHaveLength(1);
+      expect(violations[0].reason).toContain("LEGAL-218");
+    });
+
+    // HAPPY PATH: Batch ignores enables (only validates disables)
+    it("ignores enable requests and only validates disables", () => {
+      const disableRequests = [
+        { event: "approval" as NotificationEvent, channel: "sms" as NotificationChannel, newEnabled: true }, // enable (ignored)
+        { event: "decline", channel: "email" as NotificationChannel, newEnabled: false }, // disable (validated)
+      ];
+
+      const violations = validateChannelDisables(
+        disableRequests,
+        "NY",
+        basePreferences,
+      );
+
+      expect(violations).toHaveLength(0);
+    });
+
+    // FALSE POSITIVE: Multiple violations reported for each violation
+    it("reports multiple violations when batch has multiple problems", () => {
+      const prefs = basePreferences.map((p) => ({
+        ...p,
+        enabled: p.event === "decline" && p.channel === "email" ? true : false,
+      }));
+
+      const disableRequests = [
+        { event: "decline" as NotificationEvent, channel: "sms" as NotificationChannel, newEnabled: false }, // violates LEGAL-218
+        { event: "approval", channel: "email" as NotificationChannel, newEnabled: false }, // might violate mandatory
+      ];
+
+      const violations = validateChannelDisables(
+        disableRequests,
+        "CA",
+        prefs,
+      );
+
+      expect(violations.length).toBeGreaterThan(0);
+    });
+  });
+
+  describe("Edge Cases and Fallback Logic", () => {
+    // BOUNDARY: Empty preferences set
+    it("handles empty preference set", () => {
+      const result = canDisableChannel("decline", "sms", "CA", []);
+
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("LEGAL-218");
+    });
+
+    // BOUNDARY: Preference exists but with enabled=false
+    it("treats disabled preferences as unavailable fallback", () => {
+      const prefs: NotificationPreference[] = [
+        {
+          userId: "user-1",
+          event: "decline",
+          channel: "email",
+          enabled: false, // email is disabled
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+        {
+          userId: "user-1",
+          event: "decline",
+          channel: "sms",
+          enabled: true,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+      ];
+
+      const result = canDisableChannel("decline", "sms", "CA", prefs);
+
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("LEGAL-218");
+    });
+
+    // HAPPY PATH: Preference for different event doesn't interfere
+    it("ignores preferences for different events", () => {
+      const prefs: NotificationPreference[] = [
+        {
+          userId: "user-1",
+          event: "approval", // different event
+          channel: "email",
+          enabled: false,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+        {
+          userId: "user-1",
+          event: "decline",
+          channel: "email",
+          enabled: true,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+        {
+          userId: "user-1",
+          event: "decline",
+          channel: "sms",
+          enabled: true,
+          updatedAt: new Date().toISOString(),
+          updatedBy: "system",
+        },
+      ];
+
+      const result = canDisableChannel("decline", "sms", "CA", prefs);
+
+      expect(result.allowed).toBe(true);
+    });
+  });
+});
