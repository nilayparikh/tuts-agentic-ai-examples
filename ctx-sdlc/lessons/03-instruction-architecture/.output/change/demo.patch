--- a/backend/src/rules/notification-channel-rules.ts
+++ b/backend/src/rules/notification-channel-rules.ts
@@ -0,0 +1,93 @@
+// ---------------------------------------------------------------------------
+// Notification Channel Rules
+// ---------------------------------------------------------------------------
+// Validates when disabling a notification channel is allowed for mandatory
+// events. Enforces California-specific restrictions for decline notifications.
+//
+// FALSE POSITIVE:
+//   Disabling SMS for a California decline notification looks like a channel
+//   violation but is acceptable when email remains enabled. The rule allows
+//   this because at least one channel is still active for the event.
+//
+// HARD NEGATIVE:
+//   Disabling the last enabled channel for a California decline notification
+//   looks like a routine preference toggle but violates LEGAL-218. The system
+//   must reject this to maintain compliance with California notification
+//   requirements for decline events.
+// ---------------------------------------------------------------------------
+
+import type { NotificationChannel, NotificationEvent } from "../models/types.js";
+
+/**
+ * Result of a notification channel validation check.
+ */
+export interface ChannelValidationResult {
+  allowed: boolean;
+  reason: string;
+  ruleId?: string;
+}
+
+/**
+ * Check if disabling a notification channel is allowed for a given event.
+ *
+ * @param event - The notification event type
+ * @param channel - The channel being disabled
+ * @param otherChannelEnabled - Whether another channel is still enabled for this event
+ * @param loanState - The US state/jurisdiction of the loan
+ * @param isMandatoryEvent - Whether this is a mandatory notification event
+ * @returns A structured validation result with human-readable reason
+ */
+export function validateChannelDisable(
+  event: NotificationEvent,
+  channel: NotificationChannel,
+  otherChannelEnabled: boolean,
+  loanState: string,
+  isMandatoryEvent: boolean,
+): ChannelValidationResult {
+  // Mandatory events require at least one channel to remain enabled
+  if (isMandatoryEvent && !otherChannelEnabled) {
+    // California decline notifications have a specific legal requirement
+    if (loanState === "CA" && event === "decline") {
+      return {
+        allowed: false,
+        reason:
+          "Cannot disable the last notification channel for decline events on California loans. " +
+          "LEGAL-218 requires at least one active channel for decline communications.",
+        ruleId: "ca-decline-notification-legal-218",
+      };
+    }
+
+    // Other mandatory events also require at least one channel
+    return {
+      allowed: false,
+      reason: `Cannot disable the last notification channel for mandatory event '${event}'. ` +
+        "At least one channel must remain enabled for mandatory events.",
+      ruleId: "mandatory-event-requires-channel",
+    };
+  }
+
+  // If not a mandatory event or another channel is enabled, allow the disable
+  return {
+    allowed: true,
+    reason: "Channel disable is permitted.",
+  };
+}
+
+/**
+ * Determine if a notification event is mandatory.
+ *
+ * Mandatory events are those that MUST fire for certain state transitions.
+ * Users cannot disable all channels for mandatory events.
+ */
+export function isMandatoryNotificationEvent(
+  event: NotificationEvent,
+): boolean {
+  // Based on the mandatory events defined in mandatory-events.ts
+  const mandatoryEvents: NotificationEvent[] = [
+    "approval",
+    "decline",
+    "document-request",
+    "manual-review-escalation",
+  ];
+  return mandatoryEvents.includes(event);
+}

--- a/backend/tests/unit/notification-channel-rules.test.ts
