xport function validateChannelDisable(\\n  event: NotificationEvent,\\n  channel: NotificationChannel,\\n  otherChannelEnabled: boolean,\\n  loanState: string,\\n  isMandatoryEvent: boolean,\\n): ChannelValidationResult {\\n  // Mandatory events require at least one channel to remain enabled\\n  if (isMandatoryEvent && !otherChannelEnabled) {\\n    // California decline notifications have a specific legal requirement\\n    if (loanState === \\\"CA\\\" && event === \\\"decline\\\") {\\n      return {\\n        allowed: false,\\n        reason:\\n          \\\"Cannot disable the last notification channel for decline events on California loans. \\\" +\\n          \\\"LEGAL-218 requires at least one active channel for decline communications.\\\",\\n        ruleId: \\\"ca-decline-notification-legal-218\\\",\\n      };\\n    }\\n\\n    // Other mandatory events also require at least one channel\\n    return {\\n      allowed: false,\\n      reason: `Cannot disable the last notification channel for mandatory event '${event}'. ` +\\n        \\\"At least one channel must remain enabled for mandatory events.\\\",\\n      ruleId: \\\"mandatory-event-requires-channel\\\",\\n    };\\n  }\\n\\n  // If not a mandatory event or another channel is enabled, allow the disable\\n  return {\\n    allowed: true,\\n    reason: \\\"Channel disable is permitted.\\\",\\n  };\\n}\\n\\n/**\\n * Determine if a notification event is mandatory.\\n *\\n * Mandatory events are those that MUST fire for certain state transitions.\\n * Users cannot disable all channels for mandatory events.\\n */\\nexport function isMandatoryNotificationEvent(\\n  event: NotificationEvent,\\n): boolean {\\n  // Based on the mandatory events defined in mandatory-events.ts\\n  const mandatoryEvents: NotificationEvent[] = [\\n    \\\"approval\\\",\\n    \\\"decline\\\",\\n    \\\"document-request\\\",\\n    \\\"manual-review-escalation\\\",\\n  ];\\n  return mandatoryEvents.includes(event);\\n}\\n\"}",
