            "function": {
              "arguments": "{\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\03-instruction-architecture\\\\src\\\\backend\\\\tests\\\\unit\\\\notification-channel-rules.test.ts\",\"file_text\":\"// ---------------------------------------------------------------------------\\n// Notification Channel Rules Tests\\n// ---------------------------------------------------------------------------\\n\\nimport { describe, it, expect } from \\\"vitest\\\";\\nimport {\\n  canDisableChannel,\\n  validateChannelDisables,\\n} from \\\"../../src/rules/notification-channel-rules.js\\\";\\nimport type {\\n  NotificationEvent,\\n  NotificationChannel,\\n  NotificationPreference,\\n} from \\\"../../src/models/types.js\\\";\\n\\n// Base preference set for testing\\nconst basePreferences: NotificationPreference[] = [\\n  {\\n    userId: \\\"user-1\\\",\\n    event: \\\"decline\\\",\\n    channel: \\\"email\\\",\\n    enabled: true,\\n    updatedAt: new Date().toISOString(),\\n    updatedBy: \\\"system\\\",\\n  },\\n  {\\n    userId: \\\"user-1\\\",\\n    event: \\\"decline\\\",\\n    channel: \\\"sms\\\",\\n    enabled: true,\\n    updatedAt: new Date().toISOString(),\\n    updatedBy: \\\"system\\\",\\n  },\\n  {\\n    userId: \\\"user-1\\\",\\n    event: \\\"approval\\\",\\n    channel: \\\"email\\\",\\n    enabled: true,\\n    updatedAt: new Date().toISOString(),\\n    updatedBy: \\\"system\\\",\\n  },\\n  {\\n    userId: \\\"user-1\\\",\\n    event: \\\"approval\\\",\\n    channel: \\\"sms\\\",\\n    enabled: true,\\n    updatedAt: new Date().toISOString(),\\n    updatedBy: \\\"system\\\",\\n  },\\n];\\n\\ndescribe(\\\"Notification Channel Rules\\\", () => {\\n  describe(\\\"LEGAL-218: California Decline SMS Restriction\\\", () => {\\n    // HARD NEGATIVE: California decline SMS disable when email disabled\\n    // This looks like a normal toggle but actually violates LEGAL-218\\n    it(\\\"rejects SMS disable for decline on CA when email is disabled\\\", () => {\\n      const caPreferences = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" && p.channel === \\\"sms\\\" ? true : false,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        \\\"CA\\\",\\n        caPreferences,\\n      );\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n      expect(result.reason).toContain(\\\"California\\\");\\n    });\\n\\n    // FALSE POSITIVE: Disabling SMS decline on CA is OK if email is enabled\\n    // This looks like violation but is actually correct.\\n    it(\\\"allows SMS disable for decline on CA when email is enabled\\\", () => {\\n      const caPreferences = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" ? p.channel === \\\"email\\\" : true,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        \\\"CA\\\",\\n        caPreferences,\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n      expect(result.reason).toContain(\\\"disabled\\\");\\n    });\\n\\n    // HAPPY PATH: Non-CA states have no decline SMS restriction\\n    it(\\\"allows SMS disable for decline on non-CA states\\\", () => {\\n      const nyPreferences = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" ? p.channel === \\\"sms\\\" : true,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        \\\"NY\\\",\\n        nyPreferences,\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    // FALSE POSITIVE: Email disable on CA is OK (SMS is fallback for decline)\\n    // This looks like violation but is actually correct because SMS remains.\\n    it(\\\"allows email disable for decline on CA if SMS is enabled\\\", () => {\\n      const caPreferences = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" ? p.channel === \\\"sms\\\" : true,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"email\\\",\\n        \\\"CA\\\",\\n        caPreferences,\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    // BOUNDARY: CA state check is case-insensitive\\n    it(\\\"handles California state code case-insensitively\\\", () => {\\n      const caPreferences = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" ? p.channel === \\\"email\\\" : true,\\n      }));\\n\\n      // Test with lowercase \\\"ca\\\"\\n      const resultLower = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        \\\"ca\\\",\\n        caPreferences,\\n      );\\n      expect(resultLower.allowed).toBe(true);\\n\\n      // Test with mixed case \\\"Ca\\\"\\n      const resultMixed = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        \\\"Ca\\\",\\n        caPreferences,\\n      );\\n      expect(resultMixed.allowed).toBe(true);\\n    });\\n  });\\n\\n  describe(\\\"Mandatory Event Constraints\\\", () => {\\n    // HARD NEGATIVE: Disabling last enabled channel for mandatory event\\n    // This looks valid but violates mandatory event delivery.\\n    it(\\\"rejects channel disable if it's the only enabled channel for mandatory event\\\", () => {\\n      const transition = \\\"decision->finalized\\\"; // \\\"approval\\\" is mandatory here\\n      const prefs = basePreferences.map((p) => ({\\n        ...p,\\n        enabled:\\n          p.event === \\\"approval\\\" && p.channel === \\\"email\\\"\\n            ? true // only email is enabled for approval\\n            : p.event === \\\"approval\\\"\\n              ? false // disable SMS for approval\\n              : true,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"email\\\",\\n        \\\"NY\\\",\\n        prefs,\\n        transition,\\n      );\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory event\\\");\\n      expect(result.reason).toContain(\\\"one notification channel\\\");\\n    });\\n\\n    // HAPPY PATH: Disabling one channel is OK if other is enabled for mandatory event\\n    it(\\\"allows disabling one channel for mandatory event if other is enabled\\\", () => {\\n      const transition = \\\"decision->finalized\\\";\\n      const prefs = basePreferences; // both channels enabled\\n\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"sms\\\",\\n        \\\"NY\\\",\\n        prefs,\\n        transition,\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    // FALSE POSITIVE: Non-mandatory events have no fallback requirement\\n    // Disabling all channels for non-mandatory events is allowed.\\n    it(\\\"allows all channels disabled for non-mandatory events\\\", () => {\\n      const prefs = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"approval\\\", // only approval enabled\\n      }));\\n\\n      // \\\"document-request\\\" is not mandatory in all transitions\\n      const result = canDisableChannel(\\n        \\\"document-request\\\",\\n        \\\"sms\\\",\\n        \\\"NY\\\",\\n        prefs,\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    // BOUNDARY: Transition context matters for mandatory event classification\\n    it(\\\"treats event as non-mandatory when transition is not mandatory\\\", () => {\\n      // \\\"approval\\\" is mandatory for decision->finalized, but not for all transitions\\n      const transition = \\\"intake->review\\\"; // approval is not mandatory here\\n\\n      const prefs = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"approval\\\" ? p.channel === \\\"email\\\" : true,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"email\\\",\\n        \\\"NY\\\",\\n        prefs,\\n        transition,\\n      );\\n\\n      expect(result.allowed).toBe(true); // Allowed because not mandatory in this transition\\n    });\\n  });\\n\\n  describe(\\\"Event-Specific Rules\\\", () => {\\n    // FALSE POSITIVE: SMS disable on non-decline events on CA is allowed\\n    // This looks like it might violate LEGAL-218 but only applies to decline.\\n    it(\\\"allows SMS disable for approval on CA (LEGAL-218 only applies to decline)\\\", () => {\\n      const prefs = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"approval\\\" ? p.channel === \\\"email\\\" : true,\\n      }));\\n\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"sms\\\",\\n        \\\"CA\\\",\\n        prefs,\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    // HAPPY PATH: Multiple events can have independent channel states\\n    it(\\\"handles multiple different events with different channel states\\\", () => {\\n      const prefs: NotificationPreference[] = [\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"decline\\\",\\n          channel: \\\"email\\\",\\n          enabled: true,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"decline\\\",\\n          channel: \\\"sms\\\",\\n          enabled: true,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"approval\\\",\\n          channel: \\\"email\\\",\\n          enabled: false,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"approval\\\",\\n          channel: \\\"sms\\\",\\n          enabled: true,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n      ];\\n\\n      // Can disable SMS for decline (email is fallback)\\n      const declineResult = canDisableChannel(\\\"decline\\\", \\\"sms\\\", \\\"CA\\\", prefs);\\n      expect(declineResult.allowed).toBe(true);\\n\\n      // Can disable SMS for approval (only SMS enabled, but approval not mandatory here)\\n      const approvalResult = canDisableChannel(\\\"approval\\\", \\\"sms\\\", \\\"CA\\\", prefs);\\n      expect(approvalResult.allowed).toBe(true);\\n    });\\n  });\\n\\n  describe(\\\"Batch Validation\\\", () => {\\n    // HAPPY PATH: Bulk disable with no violations\\n    it(\\\"validates multiple disables successfully\\\", () => {\\n      const disableRequests = [\\n        { event: \\\"approval\\\" as NotificationEvent, channel: \\\"sms\\\" as NotificationChannel, newEnabled: false },\\n        { event: \\\"decline\\\", channel: \\\"email\\\" as NotificationChannel, newEnabled: false },\\n      ];\\n\\n      const violations = validateChannelDisables(\\n        disableRequests,\\n        \\\"CA\\\",\\n        basePreferences,\\n      );\\n\\n      expect(violations).toHaveLength(0);\\n    });\\n\\n    // HARD NEGATIVE: Batch disable violates CA decline SMS restriction\\n    it(\\\"catches LEGAL-218 violation in batch\\\", () => {\\n      const caPreferences = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" && p.channel === \\\"sms\\\" ? true : false,\\n      }));\\n\\n      const disableRequests = [\\n        { event: \\\"decline\\\" as NotificationEvent, channel: \\\"sms\\\" as NotificationChannel, newEnabled: false },\\n      ];\\n\\n      const violations = validateChannelDisables(\\n        disableRequests,\\n        \\\"CA\\\",\\n        caPreferences,\\n      );\\n\\n      expect(violations).toHaveLength(1);\\n      expect(violations[0].reason).toContain(\\\"LEGAL-218\\\");\\n    });\\n\\n    // HAPPY PATH: Batch ignores enables (only validates disables)\\n    it(\\\"ignores enable requests and only validates disables\\\", () => {\\n      const disableRequests = [\\n        { event: \\\"approval\\\" as NotificationEvent, channel: \\\"sms\\\" as NotificationChannel, newEnabled: true }, // enable (ignored)\\n        { event: \\\"decline\\\", channel: \\\"email\\\" as NotificationChannel, newEnabled: false }, // disable (validated)\\n      ];\\n\\n      const violations = validateChannelDisables(\\n        disableRequests,\\n        \\\"NY\\\",\\n        basePreferences,\\n      );\\n\\n      expect(violations).toHaveLength(0);\\n    });\\n\\n    // FALSE POSITIVE: Multiple violations reported for each violation\\n    it(\\\"reports multiple violations when batch has multiple problems\\\", () => {\\n      const prefs = basePreferences.map((p) => ({\\n        ...p,\\n        enabled: p.event === \\\"decline\\\" && p.channel === \\\"email\\\" ? true : false,\\n      }));\\n\\n      const disableRequests = [\\n        { event: \\\"decline\\\" as NotificationEvent, channel: \\\"sms\\\" as NotificationChannel, newEnabled: false }, // violates LEGAL-218\\n        { event: \\\"approval\\\", channel: \\\"email\\\" as NotificationChannel, newEnabled: false }, // might violate mandatory\\n      ];\\n\\n      const violations = validateChannelDisables(\\n        disableRequests,\\n        \\\"CA\\\",\\n        prefs,\\n      );\\n\\n      expect(violations.length).toBeGreaterThan(0);\\n    });\\n  });\\n\\n  describe(\\\"Edge Cases and Fallback Logic\\\", () => {\\n    // BOUNDARY: Empty preferences set\\n    it(\\\"handles empty preference set\\\", () => {\\n      const result = canDisableChannel(\\\"decline\\\", \\\"sms\\\", \\\"CA\\\", []);\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n    });\\n\\n    // BOUNDARY: Preference exists but with enabled=false\\n    it(\\\"treats disabled preferences as unavailable fallback\\\", () => {\\n      const prefs: NotificationPreference[] = [\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"decline\\\",\\n          channel: \\\"email\\\",\\n          enabled: false, // email is disabled\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"decline\\\",\\n          channel: \\\"sms\\\",\\n          enabled: true,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n      ];\\n\\n      const result = canDisableChannel(\\\"decline\\\", \\\"sms\\\", \\\"CA\\\", prefs);\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n    });\\n\\n    // HAPPY PATH: Preference for different event doesn't interfere\\n    it(\\\"ignores preferences for different events\\\", () => {\\n      const prefs: NotificationPreference[] = [\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"approval\\\", // different event\\n          channel: \\\"email\\\",\\n          enabled: false,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"decline\\\",\\n          channel: \\\"email\\\",\\n          enabled: true,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n        {\\n          userId: \\\"user-1\\\",\\n          event: \\\"decline\\\",\\n          channel: \\\"sms\\\",\\n          enabled: true,\\n          updatedAt: new Date().toISOString(),\\n          updatedBy: \\\"system\\\",\\n        },\\n      ];\\n\\n      const result = canDisableChannel(\\\"decline\\\", \\\"sms\\\", \\\"CA\\\", prefs);\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n  });\\n});\\n\"}",
