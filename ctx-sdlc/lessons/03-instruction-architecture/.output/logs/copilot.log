esult.reason).not.toContain(\\\"LEGAL-218\\\");\\n    });\\n\\n    // -----------------------------------------------------------------------\\n    // Hard Negative — Looks allowed, is actually forbidden\\n    // -----------------------------------------------------------------------\\n    it(\\\"blocks disabling the last channel for California decline (hard negative: LEGAL-218)\\\", () => {\\n      // Hard negative: disabling the last decline channel on CA is forbidden\\n      // even though it looks like a routine preference toggle.\\n      const result = validateChannelDisable(\\n        \\\"decline\\\",\\n        \\\"email\\\", // disabling email\\n        false, // SMS is also not enabled (or being disabled)\\n        \\\"CA\\\", // California loan\\n        true, // decline is mandatory\\n      );\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n      expect(result.reason).toContain(\\n        \\\"Cannot disable the last notification channel\\\",\\n      );\\n      expect(result.reason).toContain(\\\"decline events on California loans\\\");\\n      expect(result.ruleId).toBe(\\\"ca-decline-notification-legal-218\\\");\\n    });\\n\\n    it(\\\"blocks disabling the last channel for decline on non-California state\\\", () => {\\n      // Mandatory event rule still applies to decline outside California\\n      const result = validateChannelDisable(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        false, // no other channel\\n        \\\"NY\\\", // not California\\n        true, // decline is mandatory\\n      );\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory event\\\");\\n      expect(result.ruleId).toBe(\\\"mandatory-event-requires-channel\\\");\\n    });\\n\\n    // -----------------------------------------------------------------------\\n    // Additional boundary conditions\\n    // -----------------------------------------------------------------------\\n    it(\\\"allows disabling email for non-mandatory approval event even on California\\\", () => {\\n      // Non-mandatory approval event can have channels disabled freely\\n      const result = validateChannelDisable(\\n        \\\"approval\\\",\\n        \\\"email\\\",\\n        false, // no other channel\\n        \\\"CA\\\",\\n        false, // not mandatory\\n      );\\n\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    it(\\\"provides structured result with rule ID for California decline violation\\\", () => {\\n      // Verify the structured result includes proper metadata\\n      const result = validateChannelDisable(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        false,\\n        \\\"CA\\\",\\n        true,\\n      );\\n\\n      expect(result).toHaveProperty(\\\"allowed\\\");\\n      expect(result).toHaveProperty(\\\"reason\\\");\\n      expect(result).toHaveProperty(\\\"ruleId\\\");\\n      expect(typeof result.allowed).toBe(\\\"boolean\\\");\\n      expect(typeof result.reason).toBe(\\\"string\\\");\\n      expect(typeof result.ruleId).toBe(\\\"string\\\");\\n    });\\n\\n    it(\\\"handles different California case variants correctly\\\", () => {\\n      // The rule should work with different case representations if normalized\\n      // Note: Current implementation expects uppercase \\\"CA\\\"\\n      const result = validateChannelDisable(\\n        \\\"decline\\\",\\n        \\\"email\\\",\\n        false,\\n        \\\"CA\\\", // uppercase\\n        true,\\n      );\\n\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n    });\\n  });\\n\\n  describe(\\\"isMandatoryNotificationEvent\\\", () => {\\n    it(\\\"identifies approval as mandatory\\\", () => {\\n      expect(isMandatoryNotificationEvent(\\\"approval\\\")).toBe(true);\\n    });\\n\\n    it(\\\"identifies decline as mandatory\\\", () => {\\n      expect(isMandatoryNotificationEvent(\\\"decline\