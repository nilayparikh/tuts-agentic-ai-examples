        "tool_calls": [
          {
            "function": {
              "arguments": "{\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\03-instruction-architecture\\\\src\\\\backend\\\\src\\\\rules\\\\notification-channel-rules.ts\",\"file_text\":\"// ---------------------------------------------------------------------------\\n// Notification Channel Rules\\n// ---------------------------------------------------------------------------\\n// Validates when disabling a notification channel is allowed, particularly\\n// for mandatory notification events.\\n//\\n// KEY RESTRICTION — LEGAL-218 (California Decline SMS):\\n//   Loans from California (loan_state = \\\"CA\\\") CANNOT disable SMS for decline\\n//   events.  This is a regulatory requirement for California commercial loans.\\n//   This blocks the scenario: \\\"I'll just skip SMS for decline notifications\\n//   on my California loan\\\". Email must be enabled as a fallback.\\n//\\n// FALSE POSITIVES (looks like violation, actually correct):\\n//   1. Disabling SMS for decline on a NEW YORK loan is always allowed.\\n//   2. Disabling EMAIL for decline on California is allowed (SMS remains as\\n//      fallback).\\n//   3. Disabling SMS for APPROVAL on California is allowed (approval is not\\n//      subject to the decline restriction).\\n//   4. Disabling a channel when the OTHER channel remains enabled counts as\\n//      valid fallback (e.g., disable SMS if email is still on).\\n//\\n// HARD NEGATIVES (looks correct, actually violates rules):\\n//   1. Disabling SMS for decline on a California loan when email is also\\n//      disabled — no fallback exists.\\n//   2. Disabling both SMS and EMAIL for any mandatory event is always a\\n//      violation (customer cannot be reached).\\n//   3. Attempting to disable SMS for decline on California even if it's\\n//      currently the only enabled channel.\\n// ---------------------------------------------------------------------------\\n\\nimport type {\\n  NotificationChannel,\\n  NotificationEvent,\\n  NotificationPreference,\\n} from \\\"../models/types.js\\\";\\nimport { getMandatoryEvents, type TransitionKey } from \\\"./mandatory-events.js\\\";\\n\\nexport interface ChannelDisableResult {\\n  allowed: boolean;\\n  reason: string;\\n}\\n\\n/**\\n * Check if disabling a notification channel is allowed for a given event\\n * and user jurisdiction.\\n *\\n * @param event - The notification event (e.g., \\\"decline\\\", \\\"approval\\\")\\n * @param channel - The channel being disabled (\\\"email\\\" or \\\"sms\\\")\\n * @param loanState - The loan's state (jurisdiction), e.g. \\\"CA\\\", \\\"NY\\\"\\n * @param currentPreferences - The user's current notification preferences\\n * @param transition - Optional state transition context (e.g., \\\"decision->finalized\\\")\\n *                     to determine if the event is mandatory in that transition\\n * @returns Object with `allowed` boolean and human-readable `reason`\\n */\\nexport function canDisableChannel(\\n  event: NotificationEvent,\\n  channel: NotificationChannel,\\n  loanState: string,\\n  currentPreferences: NotificationPreference[],\\n  transition?: `${string}->${string}`,\\n): ChannelDisableResult {\\n  // Determine if this event is mandatory for the given transition\\n  let isMandatory = false;\\n  if (transition) {\\n    const [from, to] = transition.split(\\\"->\\\") as [string, string];\\n    const mandatoryForTransition = getMandatoryEvents(\\n      from as any,\\n      to as any,\\n    );\\n    isMandatory = mandatoryForTransition.includes(event);\\n  }\\n\\n  // LEGAL-218: California decline restriction\\n  // Cannot disable SMS for decline events on California loans\\n  if (\\n    event === \\\"decline\\\" &&\\n    channel === \\\"sms\\\" &&\\n    loanState.toUpperCase() === \\\"CA\\\"\\n  ) {\\n    // Check if email is the alternative fallback\\n    const emailPref = currentPreferences.find(\\n      (p) => p.event === event && p.channel === \\\"email\\\",\\n    );\\n\\n    if (!emailPref || !emailPref.enabled) {\\n      return {\\n        allowed: false,\\n        reason:\\n          \\\"LEGAL-218: California loans cannot disable SMS for decline events unless email is enabled as a fallback.\\\",\\n      };\\n    }\\n\\n    // Email is enabled, so SMS can be disabled (email is the fallback)\\n  }\\n\\n  // Mandatory events require at least one channel enabled\\n  // Cannot disable if this is the last enabled channel for a mandatory event\\n  if (isMandatory && event) {\\n    const otherChannel = channel === \\\"email\\\" ? \\\"sms\\\" : \\\"email\\\";\\n    const otherPref = currentPreferences.find(\\n      (p) => p.event === event && p.channel === otherChannel,\\n    );\\n\\n    // If the other channel is disabled, this disable would leave no fallback\\n    if (!otherPref || !otherPref.enabled) {\\n      return {\\n        allowed: false,\\n        reason: `Cannot disable ${channel} for mandatory event '${event}'. At least one notification channel must remain enabled.`,\\n      };\\n    }\\n  }\\n\\n  // Default: allow the disable\\n  return {\\n    allowed: true,\\n    reason: `${channel.charAt(0).toUpperCase() + channel.slice(1)} can be disabled for ${event}.`,\\n  };\\n}\\n\\n/**\\n * Validate all proposed channel disables in a batch.\\n * Useful for bulk preference updates where multiple channels may be disabled.\\n *\\n * @param disableRequests - Array of { event, channel, newEnabled }\\n * @param loanState - The loan's state\\n * @param currentPreferences - Current user preferences\\n * @param transition - Optional state transition context\\n * @returns Array of violations; empty if all disables are allowed\\n */\\nexport function validateChannelDisables(\\n  disableRequests: Array<{\\n    event: NotificationEvent;\\n    channel: NotificationChannel;\\n    newEnabled: boolean;\\n  }>,\\n  loanState: string,\\n  currentPreferences: NotificationPreference[],\\n  transition?: `${string}->${string}`,\\n): ChannelDisableResult[] {\\n  const violations: ChannelDisableResult[] = [];\\n\\n  for (const request of disableRequests) {\\n    // Only check if the request is to disable (newEnabled = false)\\n    if (!request.newEnabled) {\\n      const result = canDisableChannel(\\n        request.event,\\n        request.channel,\\n        loanState,\\n        currentPreferences,\\n        transition,\\n      );\\n\\n      if (!result.allowed) {\\n        violations.push(result);\\n      }\\n    }\\n  }\\n\\n  return violations;\\n}\\n\"}",
              "name": "create"
