--- a/backend/src/rules/notification-channel-rules.ts
+++ b/backend/src/rules/notification-channel-rules.ts
@@ -0,0 +1,69 @@
+// ---------------------------------------------------------------------------
+// Notification Channel Disable Rules
+// ---------------------------------------------------------------------------
+// Validates when disabling a notification channel is allowed for a user event.
+// This is a pure validation rule — it returns structured results without side effects.
+//
+// FALSE POSITIVE:
+//   Disabling SMS for a mandatory event looks like a violation, but is valid
+//   when email remains enabled (ensures the event still notifies the user via
+//   an enabled channel).
+//
+// HARD NEGATIVE:
+//   Disabling SMS for decline events on a California loan looks like a normal
+//   toggle, but actually violates regulatory requirement LEGAL-218 (decline
+//   notifications must reach the user via SMS on CA loans).
+// ---------------------------------------------------------------------------
+
+import type { LoanApplication, NotificationEvent } from "../models/types.js";
+
+/**
+ * Result of checking whether a notification channel can be disabled.
+ * Includes the decision and a human-readable reason for the UI.
+ */
+export interface ChannelDisableRule {
+  allowed: boolean;
+  reason: string;
+}
+
+/**
+ * Determine whether disabling a notification channel is allowed.
+ *
+ * @param event - The notification event type
+ * @param channel - The channel being disabled
+ * @param loan - The loan application this affects
+ * @param mandatoryEvents - List of mandatory events for the current state transition
+ * @returns Structured result with decision and reason
+ */
+export function canDisableChannel(
+  event: NotificationEvent,
+  channel: string,
+  loan: LoanApplication,
+  mandatoryEvents: NotificationEvent[],
+): ChannelDisableRule {
+  // California LEGAL-218: SMS for decline events cannot be disabled on CA loans
+  if (
+    event === "decline" &&
+    channel === "sms" &&
+    loan.loanState.toUpperCase() === "CA"
+  ) {
+    return {
+      allowed: false,
+      reason:
+        "Cannot disable SMS for decline events on California loans (LEGAL-218 compliance requirement).",
+    };
+  }
+
+  // Mandatory events cannot have all channels disabled
+  if (mandatoryEvents.includes(event)) {
+    return {
+      allowed: false,
+      reason: `Cannot disable notifications for mandatory event '${event}' — at least one channel must remain enabled.`,
+    };
+  }
+
+  return {
+    allowed: true,
+    reason: "Channel can be disabled.",
+  };
+}

