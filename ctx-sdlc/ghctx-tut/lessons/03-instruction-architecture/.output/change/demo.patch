+// ---------------------------------------------------------------------------
+// Notification Channel Rules Tests
+// ---------------------------------------------------------------------------
+
+import { describe, it, expect } from "vitest";
+import { canDisableChannel } from "../../src/rules/notification-channel-rules.js";
+import type { LoanApplication, NotificationEvent } from "../../src/models/types.js";
+
+const baseLoan: LoanApplication = {
+  id: "loan-1",
+  borrowerName: "Test Corp",
+  amount: 100000,
+  loanState: "NY",
+  status: "intake",
+  assignedUnderwriter: "u-1",
+  riskScore: null,
+  createdAt: new Date().toISOString(),
+  updatedAt: new Date().toISOString(),
+};
+
+describe("Notification Channel Rules", () => {
+  describe("Happy path", () => {
+    it("allows disabling email for optional events on non-CA loans", () => {
+      const result = canDisableChannel(
+        "approval",
+        "email",
+        baseLoan,
+        [],
+      );
+      expect(result.allowed).toBe(true);
+      expect(result.reason).toContain("can be disabled");
+    });
+
+    it("allows disabling SMS for approval events on CA loans", () => {
+      const result = canDisableChannel(
+        "approval",
+        "sms",
+        { ...baseLoan, loanState: "CA" },
+        [],
+      );
+      expect(result.allowed).toBe(true);
+    });
+
+    it("allows disabling email for approval events on CA loans", () => {
+      const result = canDisableChannel(
+        "approval",
+        "email",
+        { ...baseLoan, loanState: "CA" },
+        [],
+      );
+      expect(result.allowed).toBe(true);
+    });
+  });
+
+  describe("Hard negative: California LEGAL-218 decline SMS restriction", () => {
+    it("blocks disabling SMS for decline events on CA loans", () => {
+      // Hard negative: looks like a normal toggle, violates LEGAL-218
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        { ...baseLoan, loanState: "CA" },
+        [],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("LEGAL-218");
+      expect(result.reason).toContain("SMS");
+      expect(result.reason).toContain("decline");
+    });
+
+    it("applies LEGAL-218 regardless of other enabled channels", () => {
+      // Hard negative: even with email enabled, SMS cannot be disabled
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        { ...baseLoan, loanState: "CA" },
+        [],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("LEGAL-218");
+    });
+
+    it("allows disabling email for decline events on CA loans (only SMS protected)", () => {
+      const result = canDisableChannel(
+        "decline",
+        "email",
+        { ...baseLoan, loanState: "CA" },
+        [],
+      );
+      expect(result.allowed).toBe(true);
+    });
+
+    it("does not restrict decline SMS on non-CA loans", () => {
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        { ...baseLoan, loanState: "TX" },
+        [],
+      );
+      expect(result.allowed).toBe(true);
+    });
+
+    it("handles case-insensitive state code for CA restriction", () => {
+      const resultLower = canDisableChannel(
+        "decline",
+        "sms",
+        { ...baseLoan, loanState: "ca" },
+        [],
+      );
+      expect(resultLower.allowed).toBe(false);
+
+      const resultMixed = canDisableChannel(
+        "decline",
+        "sms",
+        { ...baseLoan, loanState: "Ca" },
+        [],
+      );
+      expect(resultMixed.allowed).toBe(false);
+    });
+  });
+
+  describe("Boundary: mandatory events", () => {
+    it("blocks disabling any channel for mandatory approval event", () => {
+      // Boundary case: mandatory event set explicitly
+      const result = canDisableChannel(
+        "approval",
+        "sms",
+        baseLoan,
+        ["approval"],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("mandatory");
+      expect(result.reason).toContain("approval");
+    });
+
+    it("blocks disabling any channel for mandatory decline event", () => {
+      const result = canDisableChannel(
+        "decline",
+        "email",
+        baseLoan,
+        ["decline"],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("mandatory");
+    });
+
+    it("blocks disabling email for mandatory document-request event", () => {
+      const result = canDisableChannel(
+        "document-request",
+        "email",
+        baseLoan,
+        ["document-request"],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("mandatory");
+    });
+
+    it("allows disabling optional events even when others are mandatory", () => {
+      // Boundary: one event mandatory, another optional
+      const result = canDisableChannel(
+        "approval",
+        "sms",
+        baseLoan,
+        ["decline"],
+      );
+      expect(result.allowed).toBe(true);
+    });
+  });
+
+  describe("False positive: mandatory event with alternative channel enabled", () => {
+    it("correctly rejects SMS disable for mandatory event (even with email enabled)", () => {
+      // False positive scenario: disabling SMS looks okay when email is enabled,
+      // but mandatory events require at least one channel. The caller must check
+      // other preferences to determine if email is actually enabled.
+      const result = canDisableChannel(
+        "approval",
+        "sms",
+        baseLoan,
+        ["approval"],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("mandatory");
+    });
+
+    it("requires caller to verify other channels before allowing mandatory event disable", () => {
+      // This test documents that this rule function does not check if other
+      // channels are enabled — it simply rejects disable for mandatory events.
+      // The service layer (caller) must verify email is enabled before allowing
+      // SMS to be disabled.
+      const result = canDisableChannel(
+        "manual-review-escalation",
+        "sms",
+        baseLoan,
+        ["manual-review-escalation"],
+      );
+      expect(result.allowed).toBe(false);
+    });
+  });
+
+  describe("Combined scenarios", () => {
+    it("prioritizes LEGAL-218 over mandatory event check on CA decline SMS", () => {
+      // When a user disables decline SMS on a CA loan, the rejection reason
+      // should cite LEGAL-218, not the mandatory event rule.
+      const result = canDisableChannel(
+        "decline",
+        "sms",
+        { ...baseLoan, loanState: "CA" },
+        ["decline"],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("LEGAL-218");
+    });
+
+    it("allows disabling optional decline event when it is not mandatory", () => {
+      const result = canDisableChannel(
+        "decline",
+        "email",
+        { ...baseLoan, loanState: "NY" },
+        ["approval"], // decline is not mandatory
+      );
+      expect(result.allowed).toBe(true);
+    });
+
+    it("blocks disabling mandatory document-request on any state", () => {
+      const result = canDisableChannel(
+        "document-request",
+        "sms",
+        baseLoan,
+        ["document-request"],
+      );
+      expect(result.allowed).toBe(false);
+      expect(result.reason).toContain("mandatory");
+    });
+  });
+});
