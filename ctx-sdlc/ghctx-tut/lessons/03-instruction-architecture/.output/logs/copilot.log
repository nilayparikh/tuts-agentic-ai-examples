              "arguments": "{\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\ghctx-tut\\\\lessons\\\\03-instruction-architecture\\\\src\\\\backend\\\\src\\\\rules\\\\notification-channel-rules.ts\",\"file_text\":\"// ---------------------------------------------------------------------------\\n// Notification Channel Disable Rules\\n// ---------------------------------------------------------------------------\\n// Validates when disabling a notification channel is allowed for a user event.\\n// This is a pure validation rule — it returns structured results without side effects.\\n//\\n// FALSE POSITIVE:\\n//   Disabling SMS for a mandatory event looks like a violation, but is valid\\n//   when email remains enabled (ensures the event still notifies the user via\\n//   an enabled channel).\\n//\\n// HARD NEGATIVE:\\n//   Disabling SMS for decline events on a California loan looks like a normal\\n//   toggle, but actually violates regulatory requirement LEGAL-218 (decline\\n//   notifications must reach the user via SMS on CA loans).\\n// ---------------------------------------------------------------------------\\n\\nimport type { LoanApplication, NotificationEvent } from \\\"../models/types.js\\\";\\n\\n/**\\n * Result of checking whether a notification channel can be disabled.\\n * Includes the decision and a human-readable reason for the UI.\\n */\\nexport interface ChannelDisableRule {\\n  allowed: boolean;\\n  reason: string;\\n}\\n\\n/**\\n * Determine whether disabling a notification channel is allowed.\\n *\\n * @param event - The notification event type\\n * @param channel - The channel being disabled\\n * @param loan - The loan application this affects\\n * @param mandatoryEvents - List of mandatory events for the current state transition\\n * @returns Structured result with decision and reason\\n */\\nexport function canDisableChannel(\\n  event: NotificationEvent,\\n  channel: string,\\n  loan: LoanApplication,\\n  mandatoryEvents: NotificationEvent[],\\n): ChannelDisableRule {\\n  // California LEGAL-218: SMS for decline events cannot be disabled on CA loans\\n  if (\\n    event === \\\"decline\\\" &&\\n    channel === \\\"sms\\\" &&\\n    loan.loanState.toUpperCase() === \\\"CA\\\"\\n  ) {\\n    return {\\n      allowed: false,\\n      reason:\\n        \\\"Cannot disable SMS for decline events on California loans (LEGAL-218 compliance requirement).\\\",\\n    };\\n  }\\n\\n  // Mandatory events cannot have all channels disabled\\n  if (mandatoryEvents.includes(event)) {\\n    return {\\n      allowed: false,\\n      reason: `Cannot disable notifications for mandatory event '${event}' — at least one channel must remain enabled.`,\\n    };\\n  }\\n\\n  return {\\n    allowed: true,\\n    reason: \\\"Channel can be disabled.\\\",\\n  };\\n}\\n\"}",
