            "function": {
              "arguments": "{\"file_text\":\"// ---------------------------------------------------------------------------\\n// Notification Channel Rules Tests\\n// ---------------------------------------------------------------------------\\n\\nimport { describe, it, expect } from \\\"vitest\\\";\\nimport { canDisableChannel } from \\\"../../src/rules/notification-channel-rules.js\\\";\\nimport type { LoanApplication, NotificationEvent } from \\\"../../src/models/types.js\\\";\\n\\nconst baseLoan: LoanApplication = {\\n  id: \\\"loan-1\\\",\\n  borrowerName: \\\"Test Corp\\\",\\n  amount: 100000,\\n  loanState: \\\"NY\\\",\\n  status: \\\"intake\\\",\\n  assignedUnderwriter: \\\"u-1\\\",\\n  riskScore: null,\\n  createdAt: new Date().toISOString(),\\n  updatedAt: new Date().toISOString(),\\n};\\n\\ndescribe(\\\"Notification Channel Rules\\\", () => {\\n  describe(\\\"Happy path\\\", () => {\\n    it(\\\"allows disabling email for optional events on non-CA loans\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"email\\\",\\n        baseLoan,\\n        [],\\n      );\\n      expect(result.allowed).toBe(true);\\n      expect(result.reason).toContain(\\\"can be disabled\\\");\\n    });\\n\\n    it(\\\"allows disabling SMS for approval events on CA loans\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"CA\\\" },\\n        [],\\n      );\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    it(\\\"allows disabling email for approval events on CA loans\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"email\\\",\\n        { ...baseLoan, loanState: \\\"CA\\\" },\\n        [],\\n      );\\n      expect(result.allowed).toBe(true);\\n    });\\n  });\\n\\n  describe(\\\"Hard negative: California LEGAL-218 decline SMS restriction\\\", () => {\\n    it(\\\"blocks disabling SMS for decline events on CA loans\\\", () => {\\n      // Hard negative: looks like a normal toggle, violates LEGAL-218\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"CA\\\" },\\n        [],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n      expect(result.reason).toContain(\\\"SMS\\\");\\n      expect(result.reason).toContain(\\\"decline\\\");\\n    });\\n\\n    it(\\\"applies LEGAL-218 regardless of other enabled channels\\\", () => {\\n      // Hard negative: even with email enabled, SMS cannot be disabled\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"CA\\\" },\\n        [],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n    });\\n\\n    it(\\\"allows disabling email for decline events on CA loans (only SMS protected)\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"email\\\",\\n        { ...baseLoan, loanState: \\\"CA\\\" },\\n        [],\\n      );\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    it(\\\"does not restrict decline SMS on non-CA loans\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"TX\\\" },\\n        [],\\n      );\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    it(\\\"handles case-insensitive state code for CA restriction\\\", () => {\\n      const resultLower = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"ca\\\" },\\n        [],\\n      );\\n      expect(resultLower.allowed).toBe(false);\\n\\n      const resultMixed = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"Ca\\\" },\\n        [],\\n      );\\n      expect(resultMixed.allowed).toBe(false);\\n    });\\n  });\\n\\n  describe(\\\"Boundary: mandatory events\\\", () => {\\n    it(\\\"blocks disabling any channel for mandatory approval event\\\", () => {\\n      // Boundary case: mandatory event set explicitly\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"sms\\\",\\n        baseLoan,\\n        [\\\"approval\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory\\\");\\n      expect(result.reason).toContain(\\\"approval\\\");\\n    });\\n\\n    it(\\\"blocks disabling any channel for mandatory decline event\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"email\\\",\\n        baseLoan,\\n        [\\\"decline\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory\\\");\\n    });\\n\\n    it(\\\"blocks disabling email for mandatory document-request event\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"document-request\\\",\\n        \\\"email\\\",\\n        baseLoan,\\n        [\\\"document-request\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory\\\");\\n    });\\n\\n    it(\\\"allows disabling optional events even when others are mandatory\\\", () => {\\n      // Boundary: one event mandatory, another optional\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"sms\\\",\\n        baseLoan,\\n        [\\\"decline\\\"],\\n      );\\n      expect(result.allowed).toBe(true);\\n    });\\n  });\\n\\n  describe(\\\"False positive: mandatory event with alternative channel enabled\\\", () => {\\n    it(\\\"correctly rejects SMS disable for mandatory event (even with email enabled)\\\", () => {\\n      // False positive scenario: disabling SMS looks okay when email is enabled,\\n      // but mandatory events require at least one channel. The caller must check\\n      // other preferences to determine if email is actually enabled.\\n      const result = canDisableChannel(\\n        \\\"approval\\\",\\n        \\\"sms\\\",\\n        baseLoan,\\n        [\\\"approval\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory\\\");\\n    });\\n\\n    it(\\\"requires caller to verify other channels before allowing mandatory event disable\\\", () => {\\n      // This test documents that this rule function does not check if other\\n      // channels are enabled — it simply rejects disable for mandatory events.\\n      // The service layer (caller) must verify email is enabled before allowing\\n      // SMS to be disabled.\\n      const result = canDisableChannel(\\n        \\\"manual-review-escalation\\\",\\n        \\\"sms\\\",\\n        baseLoan,\\n        [\\\"manual-review-escalation\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n    });\\n  });\\n\\n  describe(\\\"Combined scenarios\\\", () => {\\n    it(\\\"prioritizes LEGAL-218 over mandatory event check on CA decline SMS\\\", () => {\\n      // When a user disables decline SMS on a CA loan, the rejection reason\\n      // should cite LEGAL-218, not the mandatory event rule.\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"sms\\\",\\n        { ...baseLoan, loanState: \\\"CA\\\" },\\n        [\\\"decline\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"LEGAL-218\\\");\\n    });\\n\\n    it(\\\"allows disabling optional decline event when it is not mandatory\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"decline\\\",\\n        \\\"email\\\",\\n        { ...baseLoan, loanState: \\\"NY\\\" },\\n        [\\\"approval\\\"], // decline is not mandatory\\n      );\\n      expect(result.allowed).toBe(true);\\n    });\\n\\n    it(\\\"blocks disabling mandatory document-request on any state\\\", () => {\\n      const result = canDisableChannel(\\n        \\\"document-request\\\",\\n        \\\"sms\\\",\\n        baseLoan,\\n        [\\\"document-request\\\"],\\n      );\\n      expect(result.allowed).toBe(false);\\n      expect(result.reason).toContain(\\\"mandatory\\\");\\n    });\\n  });\\n});\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\ghctx-tut\\\\lessons\\\\03-instruction-architecture\\\\src\\\\backend\\\\tests\\\\unit\\\\notification-channel-rules.test.ts\"}",
