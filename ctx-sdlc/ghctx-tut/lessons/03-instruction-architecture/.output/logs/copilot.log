    "type": "custom_tool_call",
    "id": "ctc_call_zFM0ov9APtjr0qXkIgl0CuO9",
    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\03-instruction-architecture\\src\\backend\\src\\rules\\notification-channel-rules.ts\n+// ---------------------------------------------------------------------------\n+// Notification Channel Rules\n+// ---------------------------------------------------------------------------\n+// False positive:\n+//   Disabling SMS for a mandatory event is valid when another channel remains\n+//   enabled after the change. Mandatory delivery requires coverage, not every\n+//   channel to stay on.\n+//\n+// Hard negative:\n+//   Disabling the final enabled channel for a mandatory event looks like a\n+//   normal preference toggle, but it is forbidden because the event would lose\n+//   all delivery coverage. California decline SMS changes have an additional\n+//   LEGAL-218 fallback requirement.\n+// ---------------------------------------------------------------------------\n+\n+import {\n+  getMandatoryEvents,\n+  type MANDATORY_EVENTS,\n+} from \"./mandatory-events.js\";\n+import type {\n+  ApplicationState,\n+  NotificationChannel,\n+  NotificationEvent,\n+} from \"../models/types.js\";\n+\n+type RuleName = \"allowed\" | \"mandatory-event-coverage\" | \"ca-decline-sms-fallback\";\n+\n+export interface NotificationChannelPreferenceLike {\n+  channel: NotificationChannel;\n+  enabled: boolean;\n+}\n+\n+export interface ValidateNotificationChannelChangeInput {\n+  event: NotificationEvent;\n+  channel: NotificationChannel;\n+  enabled: boolean;\n+  currentPreferences: ReadonlyArray<NotificationChannelPreferenceLike>;\n+  loanState?: string;\n+  fromState?: ApplicationState;\n+  toState?: ApplicationState;\n+  mandatoryEvents?: ReadonlyArray<NotificationEvent>;\n+}\n+\n+export interface ChannelDisableResult {\n+  allowed: boolean;\n+  rule: RuleName;\n+  reason: string;\n+  ticket?: string;\n+}\n+\n+const CALIFORNIA_DECLINE_SMS_RESTRICTION = {\n+  rule: \"ca-decline-sms-fallback\",\n+  ticket: \"LEGAL-218\",\n+  reason:\n+    \"LEGAL-218: California decline notifications may disable SMS only when email remains enabled as a fallback.\",\n+} as const;\n+\n+function resolveMandatoryEvents(\n+  input: ValidateNotificationChannelChangeInput,\n+): ReadonlyArray<NotificationEvent> {\n+  if (input.mandatoryEvents) {\n+    return input.mandatoryEvents;\n+  }\n+\n+  if (input.fromState && input.toState) {\n+    return getMandatoryEvents(input.fromState, input.toState);\n+  }\n+\n+  return [];\n+}\n+\n+function buildPreferenceMap(\n+  currentPreferences: ReadonlyArray<NotificationChannelPreferenceLike>,\n+  channel: NotificationChannel,\n+  enabled: boolean,\n+): Record<NotificationChannel, boolean> {\n+  const nextState: Record<NotificationChannel, boolean> = {\n+    email: false,\n+    sms: false,\n+  };\n+\n+  for (const preference of currentPreferences) {\n+    nextState[preference.channel] = preference.enabled;\n+  }\n+\n+  nextState[channel] = enabled;\n+  return nextState;\n+}\n+\n+export function validateNotificationChannelChange(\n+  input: ValidateNotificationChannelChangeInput,\n+): ChannelDisableResult {\n+  if (input.enabled) {\n+    return {\n+      allowed: true,\n+      rule: \"allowed\",\n+      reason: \"Enabling a notification channel is always allowed.\",\n+    };\n+  }\n+\n+  const nextPreferences = buildPreferenceMap(\n+    input.currentPreferences,\n+    input.channel,\n+    input.enabled,\n+  );\n+  const mandatoryEvents = resolveMandatoryEvents(input);\n+  const eventIsMandatory = mandatoryEvents.includes(input.event);\n+  const normalizedLoanState = input.loanState?.toUpperCase();\n+\n+  if (\n+    normalizedLoanState === \"CA\" &&\n+    input.event === \"decline\" &&\n+    input.channel === \"sms\" &&\n+    !nextPreferences.email\n+  ) {\n+    return {\n+      allowed: false,\n+      rule: CALIFORNIA_DECLINE_SMS_RESTRICTION.rule,\n+      reason: CALIFORNIA_DECLINE_SMS_RESTRICTION.reason,\n+      ticket: CALIFORNIA_DECLINE_SMS_RESTRICTION.ticket,\n+    };\n+  }\n+\n+  if (eventIsMandatory && !nextPreferences.email && !nextPreferences.sms) {\n+    return {\n+      allowed: false,\n+      rule: \"mandatory-event-coverage\",\n+      reason: `Mandatory event '${input.event}' must keep at least one notification channel enabled.`,\n+    };\n+  }\n+\n+  return {\n+    allowed: true,\n+    rule: \"allowed\",\n+    reason: `Channel change allowed for '${input.event}'.`,\n+  };\n+}\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\lessons\\03-instruction-architecture\\src\\backend\\tests\\unit\\notification-channel-rules.test.ts\n+import { describe, expect, it } from \"vitest\";\n+import type { NotificationChannel } from \"../../src/models/types.js\";\n+import { validateNotificationChannelChange } from \"../../src/rules/notification-channel-rules.js\";\n+\n+function preference(channel: NotificationChannel, enabled: boolean) {\n+  return { channel, enabled };\n+}\n+\n+describe(\"notification channel rules\", () => {\n+  it(\"allows enabling a channel for a mandatory event\", () => {\n+    // Happy path: turning a channel on is always safe, even for mandatory events.\n+    const result = validateNotificationChannelChange({\n+      event: \"approval\",\n+      channel: \"sms\",\n+      enabled: true,\n+      currentPreferences: [preference(\"email\", false), preference(\"sms\", false)],\n+      fromState: \"decision\",\n+      toState: \"finalized\",\n+    });\n+\n+    expect(result).toEqual({\n+      allowed: true,\n+      rule: \"allowed\",\n+      reason: \"Enabling a notification channel is always allowed.\",\n+    });\n+  });\n+\n+  it(\"blocks disabling the last enabled channel for a mandatory event\", () => {\n+    // Boundary case: this change removes the exact last remaining delivery path.\n+    const result = validateNotificationChannelChange({\n+      event: \"approval\",\n+      channel: \"email\",\n+      enabled: false,\n+      currentPreferences: [preference(\"email\", true), preference(\"sms\", false)],\n+      fromState: \"decision\",\n+      toState: \"finalized\",\n+    });\n+\n+    expect(result.allowed).toBe(false);\n+    expect(result.rule).toBe(\"mandatory-event-coverage\");\n+    expect(result.reason).toBe(\n+      \"Mandatory event 'approval' must keep at least one notification channel enabled.\",\n+    );\n+  });\n+\n+  it(\"allows disabling sms for a mandatory event when email remains enabled\", () => {\n+    // False positive: disabling one channel still preserves mandatory coverage.\n+    const result = validateNotificationChannelChange({\n+      event: \"approval\",\n+      channel: \"sms\",\n+      enabled: false,\n+      currentPreferences: [preference(\"email\", true), preference(\"sms\", true)],\n+      fromState: \"decision\",\n+      toState: \"finalized\",\n+    });\n+\n+    expect(result).toEqual({\n+      allowed: true,\n+      rule: \"allowed\",\n+      reason: \"Channel change allowed for 'approval'.\",\n+    });\n+  });\n+\n+  it(\"blocks disabling sms for california decline notifications without email fallback\", () => {\n+    // Hard negative: it looks like a normal SMS toggle, but LEGAL-218 forbids it.\n+    const result = validateNotificationChannelChange({\n+      event: \"decline\",\n+      channel: \"sms\",\n+      enabled: false,\n+      currentPreferences: [preference(\"email\", false), preference(\"sms\", true)],\n+      loanState: \"ca\",\n+    });\n+\n+    expect(result.allowed).toBe(false);\n+    expect(result.rule).toBe(\"ca-decline-sms-fallback\");\n+    expect(result.ticket).toBe(\"LEGAL-218\");\n+    expect(result.reason).toBe(\n+      \"LEGAL-218: California decline notifications may disable SMS only when email remains enabled as a fallback.\",\n+    );\n+  });\n+});\n*** End Patch\n",
    "call_id": "call_zFM0ov9APtjr0qXkIgl0CuO9"
  },
  {
    "type": "custom_tool_call_output",
