    "output": "1. {\r\n2.   \"hooks\": {\r\n3.     \"PreToolUse\": [\r\n4.       {\r\n5.         \"type\": \"command\",\r\n6.         \"command\": \"python .github/scripts/validate_commit.py\",\r\n7.         \"timeout\": 60\r\n8.       }\r\n9.     ]\r\n10.   }\r\n11. }"
