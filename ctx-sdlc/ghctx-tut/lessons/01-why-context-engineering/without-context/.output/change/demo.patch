+// ---------------------------------------------------------------------------
+// Escalation Repository
+// ---------------------------------------------------------------------------
+// Database operations for escalations. All SQL lives here — services and
+// routes interact with escalations only through this module.
+
+import { v4 as uuid } from "uuid";
+import { getDb } from "../db/connection.js";
+import type { Escalation } from "./types.js";
+
+const ESCALATION_COLUMNS = `
+  id,
+  application_id AS applicationId,
+  escalated_by AS escalatedBy,
+  escalated_to AS escalatedTo,
+  reason,
+  status,
+  created_at AS createdAt,
+  updated_at AS updatedAt
+`;
+
+export function findEscalationById(id: string): Escalation | undefined {
+  const db = getDb();
+  return db
+    .prepare(`SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE id = ?`)
+    .get(id) as Escalation | undefined;
+}
+
+export function findEscalationsByApplication(
+  applicationId: string,
+): Escalation[] {
+  const db = getDb();
+  return db
+    .prepare(
+      `SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE application_id = ? ORDER BY created_at DESC`,
+    )
+    .all(applicationId) as Escalation[];
+}
+
+export function findEscalationsByStatus(
+  status: "pending" | "resolved" | "cancelled",
+): Escalation[] {
+  const db = getDb();
+  return db
+    .prepare(
+      `SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE status = ? ORDER BY created_at DESC`,
+    )
+    .all(status) as Escalation[];
+}
+
+export function findEscalationsByRecipient(userId: string): Escalation[] {
+  const db = getDb();
+  return db
+    .prepare(
+      `SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE escalated_to = ? AND status = 'pending' ORDER BY created_at DESC`,
+    )
+    .all(userId) as Escalation[];
+}
+
+export function createEscalation(data: {
+  applicationId: string;
+  escalatedBy: string;
+  escalatedTo: string;
+  reason: string;
+}): Escalation {
+  const db = getDb();
+  const id = uuid();
+  const now = new Date().toISOString();
+
+  db.prepare(
+    `INSERT INTO escalations (id, application_id, escalated_by, escalated_to, reason, status, created_at, updated_at)
+     VALUES (?, ?, ?, ?, ?, 'pending', ?, ?)`,
+  ).run(
+    id,
+    data.applicationId,
+    data.escalatedBy,
+    data.escalatedTo,
+    data.reason,
+    now,
+    now,
+  );
+
+  return findEscalationById(id)!;
+}
+
+export function updateEscalationStatus(
+  id: string,
+  status: "pending" | "resolved" | "cancelled",
+): Escalation | undefined {
+  const db = getDb();
+  const now = new Date().toISOString();
+
+  const result = db
+    .prepare(
+      "UPDATE escalations SET status = ?, updated_at = ? WHERE id = ?",
+    )
+    .run(status, now, id);
+
+  if (result.changes === 0) return undefined;
+  return findEscalationById(id);
+}

