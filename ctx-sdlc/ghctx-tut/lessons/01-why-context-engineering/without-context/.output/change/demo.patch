--- a/backend/src/services/escalation-service.ts
+++ b/backend/src/services/escalation-service.ts
@@ -0,0 +1,153 @@
+import { Database } from "sqlite";
+import { BrokerClient } from "../broker";
+import {
+  findEscalationById,
+  findEscalationsByApplication,
+  findEscalationsByRecipient,
+  createEscalation as createEscalationDb,
+  updateEscalationStatus,
+} from "../models/escalation-repository";
+import { findApplicationById } from "../models/loan-repository";
+import { findUserById } from "../models/user-repository";
+import { Escalation, Session } from "../models/types";
+import { nanoid } from "nanoid";
+
+export async function escalateReview(
+  db: Database,
+  broker: BrokerClient,
+  session: Session,
+  applicationId: string,
+  escalatedToUserId: string,
+  reason: string
+): Promise<Escalation> {
+  // Validate: delegated sessions cannot create escalations
+  if (session.delegated) {
+    throw new Error("Delegated sessions cannot create escalations");
+  }
+
+  // Validate: application exists and is in valid state
+  const application = await findApplicationById(db, applicationId);
+  if (!application) {
+    throw new Error("Application not found");
+  }
+  if (!["underwriting", "decision"].includes(application.state)) {
+    throw new Error(
+      `Cannot escalate application in '${application.state}' state. Must be in 'underwriting' or 'decision' state`
+    );
+  }
+
+  // Validate: recipient exists
+  const recipient = await findUserById(db, escalatedToUserId);
+  if (!recipient) {
+    throw new Error("Escalation recipient not found");
+  }
+
+  // Validate: reason not empty
+  if (!reason || reason.trim().length === 0) {
+    throw new Error("Escalation reason cannot be empty");
+  }
+
+  const escalationId = nanoid();
+  const escalation = await createEscalationDb(db, {
+    id: escalationId,
+    applicationId,
+    escalatedBy: session.userId,
+    escalatedTo: escalatedToUserId,
+    reason: reason.trim(),
+  });
+
+  // Emit events
+  broker.emit({
+    type: "audit.requested",
+    payload: {
+      userId: session.userId,
+      action: "escalation.created",
+      resourceType: "escalation",
+      resourceId: escalationId,
+      details: {
+        applicationId,
+        escalatedTo: escalatedToUserId,
+        reason: reason.trim(),
+      },
+    },
+  });
+
+  broker.emit({
+    type: "notification.requested",
+    payload: {
+      userId: escalatedToUserId,
+      type: "escalation_assigned",
+      message: `You have been assigned an escalation for application ${applicationId}`,
+      details: {
+        escalationId,
+        applicationId,
+        reason: reason.trim(),
+      },
+    },
+  });
+
+  broker.emit({
+    type: "escalation.requested",
+    payload: {
+      escalationId,
+      applicationId,
+      escalatedBy: session.userId,
+      escalatedTo: escalatedToUserId,
+      reason: reason.trim(),
+    },
+  });
+
+  return escalation;
+}
+
+export async function resolveEscalation(
+  db: Database,
+  broker: BrokerClient,
+  session: Session,
+  escalationId: string
+): Promise<Escalation> {
+  const escalation = await findEscalationById(db, escalationId);
+  if (!escalation) {
+    throw new Error("Escalation not found");
+  }
+
+  if (escalation.status !== "pending") {
+    throw new Error(`Cannot resolve escalation in '${escalation.status}' status`);
+  }
+
+  // Validate: only recipient can resolve
+  if (escalation.escalatedTo !== session.userId) {
+    throw new Error("Only the escalation recipient can resolve it");
+  }
+
+  const updated = await updateEscalationStatus(db, escalationId, "resolved");
+
+  broker.emit({
+    type: "audit.requested",
+    payload: {
+      userId: session.userId,
+      action: "escalation.resolved",
+      resourceType: "escalation",
+      resourceId: escalationId,
+      details: {
+        applicationId: escalation.applicationId,
+      },
+    },
+  });
+
+  return updated;
+}
+
+export async function getEscalationsForApplication(
+  db: Database,
+  applicationId: string
+): Promise<Escalation[]> {
+  return findEscalationsByApplication(db, applicationId);
+}
+
+export async function getPendingEscalationsForUser(
+  db: Database,
+  userId: string
+): Promise<Escalation[]> {
+  return findEscalationsByRecipient(db, userId);
+}
