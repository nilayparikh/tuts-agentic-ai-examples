+// ---------------------------------------------------------------------------
+// Escalation Service
+// ---------------------------------------------------------------------------
+// Orchestrates escalation operations: creation, resolution, and retrieval.
+// Delegates persistence to the escalation repository, and event emission
+// to the broker.
+
+import { v4 as uuid } from "uuid";
+import * as escalationRepo from "../models/escalation-repository.js";
+import * as loanRepo from "../models/loan-repository.js";
+import { getDb } from "../db/connection.js";
+import { broker } from "../queue/broker.js";
+import type {
+  Escalation,
+  SessionContext,
+  LoanApplication,
+} from "../models/types.js";
+import type {
+  EscalationRequestedEvent,
+  AuditRequestedEvent,
+  NotificationRequestedEvent,
+} from "../queue/contracts.js";
+
+/**
+ * Escalate a loan application for higher-level review.
+ *
+ * Validation:
+ *  - Application must exist and be in "underwriting" or "decision" state.
+ *  - Recipient user must exist.
+ *  - Reason must not be empty.
+ *  - Delegated sessions cannot create escalations.
+ *  - Emits audit, notification, and escalation events.
+ */
+export function escalateReview(
+  session: SessionContext,
+  applicationId: string,
+  escalatedToUserId: string,
+  reason: string,
+): Escalation {
+  if (session.delegatedFor) {
+    throw new Error("FORBIDDEN: Delegated sessions cannot escalate reviews.");
+  }
+
+  if (!reason || reason.trim().length === 0) {
+    throw new Error("VALIDATION: Reason cannot be empty.");
+  }
+
+  const application = loanRepo.findLoanById(applicationId);
+  if (!application) {
+    throw new Error(`NOT_FOUND: Application '${applicationId}' not found.`);
+  }
+
+  if (application.status !== "underwriting" && application.status !== "decision") {
+    throw new Error(
+      `INVALID_STATE: Cannot escalate application in '${application.status}' state. ` +
+        "Expected 'underwriting' or 'decision'.",
+    );
+  }
+
+  // Verify recipient exists
+  const db = getDb();
+  const recipientExists = db
+    .prepare("SELECT id FROM users WHERE id = ?")
+    .get(escalatedToUserId);
+  if (!recipientExists) {
+    throw new Error(`NOT_FOUND: User '${escalatedToUserId}' not found.`);
+  }
+
+  // Create escalation
+  const escalation = escalationRepo.createEscalation({
+    applicationId,
+    escalatedBy: session.actor.id,
+    escalatedTo: escalatedToUserId,
+    reason,
+  });
+
+  // Emit audit event
+  const auditEvent: AuditRequestedEvent = {
+    eventId: uuid(),
+    timestamp: new Date().toISOString(),
+    source: "escalation-service",
+    type: "audit.requested",
+    payload: {
+      action: "escalation.created",
+      actor: session.actor.id,
+      previousValue: undefined,
+      newValue: escalation,
+      source: "escalation-service",
+    },
+  };
+  broker.emit(auditEvent);
+
+  // Emit notification event for the escalation recipient
+  const notifEvent: NotificationRequestedEvent = {
+    eventId: uuid(),
+    timestamp: new Date().toISOString(),
+    source: "escalation-service",
+    type: "notification.requested",
+    payload: {
+      userId: escalatedToUserId,
+      event: "manual-review-escalation",
+      subject: `Escalation: Application ${applicationId} requires your review`,
+      body: `Application ${applicationId} has been escalated for your review. Reason: ${reason}`,
+      preferredChannel: "email",
+    },
+  };
+  broker.emit(notifEvent);
+
+  // Emit escalation event for extensibility
+  const escalationEvent: EscalationRequestedEvent = {
+    eventId: uuid(),
+    timestamp: new Date().toISOString(),
+    source: "escalation-service",
+    type: "escalation.requested",
+    payload: {
+      escalationId: escalation.id,
+      applicationId,
+      escalatedBy: session.actor.id,
+      escalatedTo: escalatedToUserId,
+      reason,
+    },
+  };
+  broker.emit(escalationEvent);
+
+  return escalation;
+}
+
+/**
+ * Resolve an escalation (mark as resolved).
+ *
+ * Validation:
+ *  - Escalation must exist and be in "pending" status.
+ *  - Only the escalation recipient can resolve it.
+ *  - Emits audit event.
+ */
+export function resolveEscalation(
+  session: SessionContext,
+  escalationId: string,
+): Escalation {
+  const escalation = escalationRepo.findEscalationById(escalationId);
+  if (!escalation) {
+    throw new Error(`NOT_FOUND: Escalation '${escalationId}' not found.`);
+  }
+
+  if (escalation.status !== "pending") {
+    throw new Error(
+      `INVALID_STATE: Cannot resolve escalation in '${escalation.status}' state. ` +
+        "Expected 'pending'.",
+    );
+  }
+
+  // Only recipient can resolve
+  if (escalation.escalatedTo !== session.actor.id) {
+    throw new Error(
+      "FORBIDDEN: Only the escalation recipient can resolve it.",
+    );
+  }
+
+  const updated = escalationRepo.updateEscalationStatus(
+    escalationId,
+    "resolved",
+  );
+  if (!updated) {
+    throw new Error(`NOT_FOUND: Escalation '${escalationId}' not found.`);
+  }
+
+  // Emit audit event
+  const auditEvent: AuditRequestedEvent = {
+    eventId: uuid(),
+    timestamp: new Date().toISOString(),
+    source: "escalation-service",
+    type: "audit.requested",
+    payload: {
+      action: "escalation.resolved",
+      actor: session.actor.id,
+      previousValue: { status: escalation.status },
+      newValue: { status: updated.status },
+      source: "escalation-service",
+    },
+  };
+  broker.emit(auditEvent);
+
+  return updated;
+}
+
+/**
+ * Get all escalations for a specific application.
+ */
+export function getEscalationsForApplication(
+  applicationId: string,
+): Escalation[] {
+  return escalationRepo.findEscalationsByApplication(applicationId);
+}
+
+/**
+ * Get all pending escalations assigned to the current user.
+ */
+export function getPendingEscalationsForUser(userId: string): Escalation[] {
+  return escalationRepo.findEscalationsByRecipient(userId);
+}
