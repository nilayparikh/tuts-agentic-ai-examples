+// ---------------------------------------------------------------------------
+// Escalation Routes
+// ---------------------------------------------------------------------------
+
+import { Router } from "express";
+import { requireRole } from "../middleware/auth.js";
+import { validateBody } from "../middleware/request-validator.js";
+import * as escalationService from "../services/escalation-service.js";
+import type { SessionContext } from "../models/types.js";
+
+export const escalationRoutes = Router();
+
+function firstParam(value: string | string[]): string {
+  return Array.isArray(value) ? value[0] : value;
+}
+
+/** GET /api/escalations/application/:applicationId — get escalations for an application. */
+escalationRoutes.get(
+  "/application/:applicationId",
+  requireRole("underwriter", "analyst-manager", "compliance-reviewer"),
+  (req, res) => {
+    const escalations = escalationService.getEscalationsForApplication(
+      firstParam(req.params.applicationId),
+    );
+    res.json(escalations);
+  },
+);
+
+/** GET /api/escalations/pending — get pending escalations for current user. */
+escalationRoutes.get(
+  "/pending",
+  requireRole("underwriter", "analyst-manager", "compliance-reviewer"),
+  (req, res) => {
+    const session = req.session as SessionContext;
+    const escalations = escalationService.getPendingEscalationsForUser(
+      session.actor.id,
+    );
+    res.json(escalations);
+  },
+);
+
+/** POST /api/escalations — create a new escalation. */
+escalationRoutes.post(
+  "/",
+  requireRole("underwriter", "analyst-manager"),
+  validateBody([
+    { field: "applicationId", type: "string", required: true },
+    { field: "escalatedToUserId", type: "string", required: true },
+    { field: "reason", type: "string", required: true },
+  ]),
+  (req, res, next) => {
+    try {
+      const session = req.session as SessionContext;
+      const { applicationId, escalatedToUserId, reason } = req.body;
+      const escalation = escalationService.escalateReview(
+        session,
+        applicationId,
+        escalatedToUserId,
+        reason,
+      );
+      res.status(201).json(escalation);
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+/** PATCH /api/escalations/:id/resolve — resolve an escalation. */
+escalationRoutes.patch(
+  "/:id/resolve",
+  requireRole("underwriter", "analyst-manager", "compliance-reviewer"),
+  (req, res, next) => {
+    try {
+      const session = req.session as SessionContext;
+      const escalation = escalationService.resolveEscalation(
+        session,
+        firstParam(req.params.id),
+      );
+      res.json(escalation);
+    } catch (err) {
+      next(err);
+    }
+  },
+);

