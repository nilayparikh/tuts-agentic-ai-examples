+import { Router, Response } from "express";
+import { Database } from "sqlite";
+import { BrokerClient } from "../broker";
+import {
+  escalateReview,
+  resolveEscalation,
+  getEscalationsForApplication,
+  getPendingEscalationsForUser,
+} from "../services/escalation-service";
+import { requireRole } from "../middleware/auth";
+import { AuthenticatedRequest } from "../middleware/types";
+
+export function createEscalationRoutes(
+  db: Database,
+  broker: BrokerClient
+): Router {
+  const router = Router();
+
+  // GET /api/escalations/application/:applicationId
+  router.get(
+    "/application/:applicationId",
+    requireRole(["underwriter", "analyst-manager", "compliance-reviewer"]),
+    async (req: AuthenticatedRequest, res: Response) => {
+      try {
+        const { applicationId } = req.params;
+        const escalations = await getEscalationsForApplication(db, applicationId);
+        res.json(escalations);
+      } catch (error) {
+        res.status(400).json({
+          error:
+            error instanceof Error ? error.message : "Failed to get escalations",
+        });
+      }
+    }
+  );
+
+  // GET /api/escalations/pending
+  router.get(
+    "/pending",
+    requireRole(["underwriter", "analyst-manager", "compliance-reviewer"]),
+    async (req: AuthenticatedRequest, res: Response) => {
+      try {
+        const escalations = await getPendingEscalationsForUser(
+          db,
+          req.user!.id
+        );
+        res.json(escalations);
+      } catch (error) {
+        res.status(400).json({
+          error:
+            error instanceof Error ? error.message : "Failed to get escalations",
+        });
+      }
+    }
+  );
+
+  // POST /api/escalations
+  router.post(
+    "/",
+    requireRole(["underwriter", "analyst-manager"]),
+    async (req: AuthenticatedRequest, res: Response) => {
+      try {
+        const { applicationId, escalatedToUserId, reason } = req.body;
+
+        if (!applicationId || !escalatedToUserId || !reason) {
+          res.status(400).json({
+            error:
+              "Missing required fields: applicationId, escalatedToUserId, reason",
+          });
+          return;
+        }
+
+        const escalation = await escalateReview(
+          db,
+          broker,
+          req.session!,
+          applicationId,
+          escalatedToUserId,
+          reason
+        );
+
+        res.status(201).json(escalation);
+      } catch (error) {
+        res.status(400).json({
+          error:
+            error instanceof Error ? error.message : "Failed to create escalation",
+        });
+      }
+    }
+  );
+
+  // PATCH /api/escalations/:id/resolve
+  router.patch(
+    "/:id/resolve",
+    requireRole(["underwriter", "analyst-manager", "compliance-reviewer"]),
+    async (req: AuthenticatedRequest, res: Response) => {
+      try {
+        const { id } = req.params;
+
+        const escalation = await resolveEscalation(
+          db,
+          broker,
+          req.session!,
+          id
+        );
+
+        res.json(escalation);
+      } catch (error) {
+        res.status(400).json({
+          error:
+            error instanceof Error ? error.message : "Failed to resolve escalation",
+        });
+      }
+    }
+  );
+
+  return router;
+}

