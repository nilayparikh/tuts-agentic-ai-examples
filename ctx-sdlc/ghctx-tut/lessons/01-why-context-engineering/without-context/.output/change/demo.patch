+import { Database } from "sqlite";
+import { Escalation } from "./types";
+
+export async function findEscalationById(
+  db: Database,
+  id: string
+): Promise<Escalation | null> {
+  const stmt = db.prepare(
+    "SELECT id, application_id AS applicationId, escalated_by AS escalatedBy, escalated_to AS escalatedTo, reason, status, created_at AS createdAt, updated_at AS updatedAt FROM escalations WHERE id = ?"
+  );
+  const row = stmt.get(id) as any;
+  return row || null;
+}
+
+export async function findEscalationsByApplication(
+  db: Database,
+  applicationId: string
+): Promise<Escalation[]> {
+  const stmt = db.prepare(
+    "SELECT id, application_id AS applicationId, escalated_by AS escalatedBy, escalated_to AS escalatedTo, reason, status, created_at AS createdAt, updated_at AS updatedAt FROM escalations WHERE application_id = ? ORDER BY created_at DESC"
+  );
+  const rows = stmt.all(applicationId) as any[];
+  return rows || [];
+}
+
+export async function findEscalationsByStatus(
+  db: Database,
+  status: string
+): Promise<Escalation[]> {
+  const stmt = db.prepare(
+    "SELECT id, application_id AS applicationId, escalated_by AS escalatedBy, escalated_to AS escalatedTo, reason, status, created_at AS createdAt, updated_at AS updatedAt FROM escalations WHERE status = ? ORDER BY created_at DESC"
+  );
+  const rows = stmt.all(status) as any[];
+  return rows || [];
+}
+
+export async function findEscalationsByRecipient(
+  db: Database,
+  userId: string
+): Promise<Escalation[]> {
+  const stmt = db.prepare(
+    "SELECT id, application_id AS applicationId, escalated_by AS escalatedBy, escalated_to AS escalatedTo, reason, status, created_at AS createdAt, updated_at AS updatedAt FROM escalations WHERE escalated_to = ? AND status = 'pending' ORDER BY created_at DESC"
+  );
+  const rows = stmt.all(userId) as any[];
+  return rows || [];
+}
+
+export async function createEscalation(
+  db: Database,
+  data: {
+    id: string;
+    applicationId: string;
+    escalatedBy: string;
+    escalatedTo: string;
+    reason: string;
+  }
+): Promise<Escalation> {
+  const stmt = db.prepare(
+    "INSERT INTO escalations (id, application_id, escalated_by, escalated_to, reason, status, created_at, updated_at) VALUES (?, ?, ?, ?, ?, 'pending', datetime('now'), datetime('now'))"
+  );
+  stmt.run(
+    data.id,
+    data.applicationId,
+    data.escalatedBy,
+    data.escalatedTo,
+    data.reason
+  );
+  const result = await findEscalationById(db, data.id);
+  if (!result) throw new Error("Failed to create escalation");
+  return result;
+}
+
+export async function updateEscalationStatus(
+  db: Database,
+  id: string,
+  status: string
+): Promise<Escalation> {
+  const stmt = db.prepare(
+    "UPDATE escalations SET status = ?, updated_at = datetime('now') WHERE id = ?"
+  );
+  stmt.run(status, id);
+  const result = await findEscalationById(db, id);
+  if (!result) throw new Error("Failed to update escalation");
+  return result;
+}

