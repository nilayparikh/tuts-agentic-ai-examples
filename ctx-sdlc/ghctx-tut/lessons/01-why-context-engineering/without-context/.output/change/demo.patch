+import { BrokerClient, BrokerEvent } from "../broker";
+
+export async function registerEscalationHandler(
+  broker: BrokerClient
+): Promise<void> {
+  broker.on("escalation.requested", async (event: BrokerEvent) => {
+    if (event.type !== "escalation.requested") return;
+    const payload = (event as any).payload;
+    console.log(`[escalation-handler] Escalation requested:`, {
+      escalationId: payload.escalationId,
+      applicationId: payload.applicationId,
+      escalatedBy: payload.escalatedBy,
+      escalatedTo: payload.escalatedTo,
+      reason: payload.reason,
+      timestamp: new Date().toISOString(),
+    });
+  });
+}

