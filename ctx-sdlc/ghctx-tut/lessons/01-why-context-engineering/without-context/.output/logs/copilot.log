status, created_at AS createdAt, updated_at AS updatedAt FROM escalations WHERE escalated_to = ? AND status = 'pending' ORDER BY created_at DESC\\\"\\n  );\\n  const rows = stmt.all(userId) as any[];\\n  return rows || [];\\n}\\n\\nexport async function createEscalation(\\n  db: Database,\\n  data: {\\n    id: string;\\n    applicationId: string;\\n    escalatedBy: string;\\n    escalatedTo: string;\\n    reason: string;\\n  }\\n): Promise<Escalation> {\\n  const stmt = db.prepare(\\n    \\\"INSERT INTO escalations (id, application_id, escalated_by, escalated_to, reason, status, created_at, updated_at) VALUES (?, ?, ?, ?, ?, 'pending', datetime('now'), datetime('now'))\\\"\\n  );\\n  stmt.run(\\n    data.id,\\n    data.applicationId,\\n    data.escalatedBy,\\n    data.escalatedTo,\\n    data.reason\\n  );\\n  const result = await findEscalationById(db, data.id);\\n  if (!result) throw new Error(\\\"Failed to create escalation\\\");\\n  return result;\\n}\\n\\nexport async function updateEscalationStatus(\\n  db: Database,\\n  id: string,\\n  status: string\\n): Promise<Escalation> {\\n  const stmt = db.prepare(\\n    \\\"UPDATE escalations SET status = ?, updated_at = datetime('now') WHERE id = ?\\\"\\n  );\\n  stmt.run(status, id);\\n  const result = await findEscalationById(db, id);\\n  if (!result) throw new Error(\\\"Failed to update escalation\\\");\\n  return result;\\n}\\n\"}",
