              "arguments": "{\"file_text\":\"// ---------------------------------------------------------------------------\\n// Escalation Routes\\n// ---------------------------------------------------------------------------\\n\\nimport { Router } from \\\"express\\\";\\nimport { requireRole } from \\\"../middleware/auth.js\\\";\\nimport { validateBody } from \\\"../middleware/request-validator.js\\\";\\nimport * as escalationService from \\\"../services/escalation-service.js\\\";\\nimport type { SessionContext } from \\\"../models/types.js\\\";\\n\\nexport const escalationRoutes = Router();\\n\\nfunction firstParam(value: string | string[]): string {\\n  return Array.isArray(value) ? value[0] : value;\\n}\\n\\n/** GET /api/escalations/application/:applicationId — get escalations for an application. */\\nescalationRoutes.get(\\n  \\\"/application/:applicationId\\\",\\n  requireRole(\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"),\\n  (req, res) => {\\n    const escalations = escalationService.getEscalationsForApplication(\\n      firstParam(req.params.applicationId),\\n    );\\n    res.json(escalations);\\n  },\\n);\\n\\n/** GET /api/escalations/pending — get pending escalations for current user. */\\nescalationRoutes.get(\\n  \\\"/pending\\\",\\n  requireRole(\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"),\\n  (req, res) => {\\n    const session = req.session as SessionContext;\\n    const escalations = escalationService.getPendingEscalationsForUser(\\n      session.actor.id,\\n    );\\n    res.json(escalations);\\n  },\\n);\\n\\n/** POST /api/escalations — create a new escalation. */\\nescalationRoutes.post(\\n  \\\"/\\\",\\n  requireRole(\\\"underwriter\\\", \\\"analyst-manager\\\"),\\n  validateBody([\\n    { field: \\\"applicationId\\\", type: \\\"string\\\", required: true },\\n    { field: \\\"escalatedToUserId\\\", type: \\\"string\\\", required: true },\\n    { field: \\\"reason\\\", type: \\\"string\\\", required: true },\\n  ]),\\n  (req, res, next) => {\\n    try {\\n      const session = req.session as SessionContext;\\n      const { applicationId, escalatedToUserId, reason } = req.body;\\n      const escalation = escalationService.escalateReview(\\n        session,\\n        applicationId,\\n        escalatedToUserId,\\n        reason,\\n      );\\n      res.status(201).json(escalation);\\n    } catch (err) {\\n      next(err);\\n    }\\n  },\\n);\\n\\n/** PATCH /api/escalations/:id/resolve — resolve an escalation. */\\nescalationRoutes.patch(\\n  \\\"/:id/resolve\\\",\\n  requireRole(\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"),\\n  (req, res, next) => {\\n    try {\\n      const session = req.session as SessionContext;\\n      const escalation = escalationService.resolveEscalation(\\n        session,\\n        firstParam(req.params.id),\\n      );\\n      res.json(escalation);\\n    } catch (err) {\\n      next(err);\\n    }\\n  },\\n);\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\src\\\\routes\\\\escalation.ts\"}",
