            "function": {
              "arguments": "{\"file_text\":\"import { Router, Response } from \\\"express\\\";\\nimport { Database } from \\\"sqlite\\\";\\nimport { BrokerClient } from \\\"../broker\\\";\\nimport {\\n  escalateReview,\\n  resolveEscalation,\\n  getEscalationsForApplication,\\n  getPendingEscalationsForUser,\\n} from \\\"../services/escalation-service\\\";\\nimport { requireRole } from \\\"../middleware/auth\\\";\\nimport { AuthenticatedRequest } from \\\"../middleware/types\\\";\\n\\nexport function createEscalationRoutes(\\n  db: Database,\\n  broker: BrokerClient\\n): Router {\\n  const router = Router();\\n\\n  // GET /api/escalations/application/:applicationId\\n  router.get(\\n    \\\"/application/:applicationId\\\",\\n    requireRole([\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"]),\\n    async (req: AuthenticatedRequest, res: Response) => {\\n      try {\\n        const { applicationId } = req.params;\\n        const escalations = await getEscalationsForApplication(db, applicationId);\\n        res.json(escalations);\\n      } catch (error) {\\n        res.status(400).json({\\n          error:\\n            error instanceof Error ? error.message : \\\"Failed to get escalations\\\",\\n        });\\n      }\\n    }\\n  );\\n\\n  // GET /api/escalations/pending\\n  router.get(\\n    \\\"/pending\\\",\\n    requireRole([\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"]),\\n    async (req: AuthenticatedRequest, res: Response) => {\\n      try {\\n        const escalations = await getPendingEscalationsForUser(\\n          db,\\n          req.user!.id\\n        );\\n        res.json(escalations);\\n      } catch (error) {\\n        res.status(400).json({\\n          error:\\n            error instanceof Error ? error.message : \\\"Failed to get escalations\\\",\\n        });\\n      }\\n    }\\n  );\\n\\n  // POST /api/escalations\\n  router.post(\\n    \\\"/\\\",\\n    requireRole([\\\"underwriter\\\", \\\"analyst-manager\\\"]),\\n    async (req: AuthenticatedRequest, res: Response) => {\\n      try {\\n        const { applicationId, escalatedToUserId, reason } = req.body;\\n\\n        if (!applicationId || !escalatedToUserId || !reason) {\\n          res.status(400).json({\\n            error:\\n              \\\"Missing required fields: applicationId, escalatedToUserId, reason\\\",\\n          });\\n          return;\\n        }\\n\\n        const escalation = await escalateReview(\\n          db,\\n          broker,\\n          req.session!,\\n          applicationId,\\n          escalatedToUserId,\\n          reason\\n        );\\n\\n        res.status(201).json(escalation);\\n      } catch (error) {\\n        res.status(400).json({\\n          error:\\n            error instanceof Error ? error.message : \\\"Failed to create escalation\\\",\\n        });\\n      }\\n    }\\n  );\\n\\n  // PATCH /api/escalations/:id/resolve\\n  router.patch(\\n    \\\"/:id/resolve\\\",\\n    requireRole([\\\"underwriter\\\", \\\"analyst-manager\\\", \\\"compliance-reviewer\\\"]),\\n    async (req: AuthenticatedRequest, res: Response) => {\\n      try {\\n        const { id } = req.params;\\n\\n        const escalation = await resolveEscalation(\\n          db,\\n          broker,\\n          req.session!,\\n          id\\n        );\\n\\n        res.json(escalation);\\n      } catch (error) {\\n        res.status(400).json({\\n          error:\\n            error instanceof Error ? error.message : \\\"Failed to resolve escalation\\\",\\n        });\\n      }\\n    }\\n  );\\n\\n  return router;\\n}\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\ghctx-tut\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\src\\\\routes\\\\escalation.ts\"}",
