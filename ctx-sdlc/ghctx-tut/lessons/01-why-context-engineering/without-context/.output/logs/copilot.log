          {
            "function": {
              "arguments": "{\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\src\\\\models\\\\escalation-repository.ts\",\"file_text\":\"// ---------------------------------------------------------------------------\\n// Escalation Repository\\n// ---------------------------------------------------------------------------\\n// Database operations for escalations. All SQL lives here — services and\\n// routes interact with escalations only through this module.\\n\\nimport { v4 as uuid } from \\\"uuid\\\";\\nimport { getDb } from \\\"../db/connection.js\\\";\\nimport type { Escalation } from \\\"./types.js\\\";\\n\\nconst ESCALATION_COLUMNS = `\\n  id,\\n  application_id AS applicationId,\\n  escalated_by AS escalatedBy,\\n  escalated_to AS escalatedTo,\\n  reason,\\n  status,\\n  created_at AS createdAt,\\n  updated_at AS updatedAt\\n`;\\n\\nexport function findEscalationById(id: string): Escalation | undefined {\\n  const db = getDb();\\n  return db\\n    .prepare(`SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE id = ?`)\\n    .get(id) as Escalation | undefined;\\n}\\n\\nexport function findEscalationsByApplication(\\n  applicationId: string,\\n): Escalation[] {\\n  const db = getDb();\\n  return db\\n    .prepare(\\n      `SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE application_id = ? ORDER BY created_at DESC`,\\n    )\\n    .all(applicationId) as Escalation[];\\n}\\n\\nexport function findEscalationsByStatus(\\n  status: \\\"pending\\\" | \\\"resolved\\\" | \\\"cancelled\\\",\\n): Escalation[] {\\n  const db = getDb();\\n  return db\\n    .prepare(\\n      `SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE status = ? ORDER BY created_at DESC`,\\n    )\\n    .all(status) as Escalation[];\\n}\\n\\nexport function findEscalationsByRecipient(userId: string): Escalation[] {\\n  const db = getDb();\\n  return db\\n    .prepare(\\n      `SELECT ${ESCALATION_COLUMNS} FROM escalations WHERE escalated_to = ? AND status = 'pending' ORDER BY created_at DESC`,\\n    )\\n    .all(userId) as Escalation[];\\n}\\n\\nexport function createEscalation(data: {\\n  applicationId: string;\\n  escalatedBy: string;\\n  escalatedTo: string;\\n  reason: string;\\n}): Escalation {\\n  const db = getDb();\\n  const id = uuid();\\n  const now = new Date().toISOString();\\n\\n  db.prepare(\\n    `INSERT INTO escalations (id, application_id, escalated_by, escalated_to, reason, status, created_at, updated_at)\\n     VALUES (?, ?, ?, ?, ?, 'pending', ?, ?)`,\\n  ).run(\\n    id,\\n    data.applicationId,\\n    data.escalatedBy,\\n    data.escalatedTo,\\n    data.reason,\\n    now,\\n    now,\\n  );\\n\\n  return findEscalationById(id)!;\\n}\\n\\nexport function updateEscalationStatus(\\n  id: string,\\n  status: \\\"pending\\\" | \\\"resolved\\\" | \\\"cancelled\\\",\\n): Escalation | undefined {\\n  const db = getDb();\\n  const now = new Date().toISOString();\\n\\n  const result = db\\n    .prepare(\\n      \\\"UPDATE escalations SET status = ?, updated_at = ? WHERE id = ?\\\",\\n    )\\n    .run(status, now, id);\\n\\n  if (result.changes === 0) return undefined;\\n  return findEscalationById(id);\\n}\\n\"}",
