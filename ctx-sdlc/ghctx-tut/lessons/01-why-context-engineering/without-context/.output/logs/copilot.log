        "tool_calls": [
          {
            "function": {
              "arguments": "{\"file_text\":\"import { Database } from \\\"sqlite\\\";\\nimport { BrokerClient } from \\\"../broker\\\";\\nimport {\\n  findEscalationById,\\n  findEscalationsByApplication,\\n  findEscalationsByRecipient,\\n  createEscalation as createEscalationDb,\\n  updateEscalationStatus,\\n} from \\\"../models/escalation-repository\\\";\\nimport { findApplicationById } from \\\"../models/loan-repository\\\";\\nimport { findUserById } from \\\"../models/user-repository\\\";\\nimport { Escalation, Session } from \\\"../models/types\\\";\\nimport { nanoid } from \\\"nanoid\\\";\\n\\nexport async function escalateReview(\\n  db: Database,\\n  broker: BrokerClient,\\n  session: Session,\\n  applicationId: string,\\n  escalatedToUserId: string,\\n  reason: string\\n): Promise<Escalation> {\\n  // Validate: delegated sessions cannot create escalations\\n  if (session.delegated) {\\n    throw new Error(\\\"Delegated sessions cannot create escalations\\\");\\n  }\\n\\n  // Validate: application exists and is in valid state\\n  const application = await findApplicationById(db, applicationId);\\n  if (!application) {\\n    throw new Error(\\\"Application not found\\\");\\n  }\\n  if (![\\\"underwriting\\\", \\\"decision\\\"].includes(application.state)) {\\n    throw new Error(\\n      `Cannot escalate application in '${application.state}' state. Must be in 'underwriting' or 'decision' state`\\n    );\\n  }\\n\\n  // Validate: recipient exists\\n  const recipient = await findUserById(db, escalatedToUserId);\\n  if (!recipient) {\\n    throw new Error(\\\"Escalation recipient not found\\\");\\n  }\\n\\n  // Validate: reason not empty\\n  if (!reason || reason.trim().length === 0) {\\n    throw new Error(\\\"Escalation reason cannot be empty\\\");\\n  }\\n\\n  const escalationId = nanoid();\\n  const escalation = await createEscalationDb(db, {\\n    id: escalationId,\\n    applicationId,\\n    escalatedBy: session.userId,\\n    escalatedTo: escalatedToUserId,\\n    reason: reason.trim(),\\n  });\\n\\n  // Emit events\\n  broker.emit({\\n    type: \\\"audit.requested\\\",\\n    payload: {\\n      userId: session.userId,\\n      action: \\\"escalation.created\\\",\\n      resourceType: \\\"escalation\\\",\\n      resourceId: escalationId,\\n      details: {\\n        applicationId,\\n        escalatedTo: escalatedToUserId,\\n        reason: reason.trim(),\\n      },\\n    },\\n  });\\n\\n  broker.emit({\\n    type: \\\"notification.requested\\\",\\n    payload: {\\n      userId: escalatedToUserId,\\n      type: \\\"escalation_assigned\\\",\\n      message: `You have been assigned an escalation for application ${applicationId}`,\\n      details: {\\n        escalationId,\\n        applicationId,\\n        reason: reason.trim(),\\n      },\\n    },\\n  });\\n\\n  broker.emit({\\n    type: \\\"escalation.requested\\\",\\n    payload: {\\n      escalationId,\\n      applicationId,\\n      escalatedBy: session.userId,\\n      escalatedTo: escalatedToUserId,\\n      reason: reason.trim(),\\n    },\\n  });\\n\\n  return escalation;\\n}\\n\\nexport async function resolveEscalation(\\n  db: Database,\\n  broker: BrokerClient,\\n  session: Session,\\n  escalationId: string\\n): Promise<Escalation> {\\n  const escalation = await findEscalationById(db, escalationId);\\n  if (!escalation) {\\n    throw new Error(\\\"Escalation not found\\\");\\n  }\\n\\n  if (escalation.status !== \\\"pending\\\") {\\n    throw new Error(`Cannot resolve escalation in '${escalation.status}' status`);\\n  }\\n\\n  // Validate: only recipient can resolve\\n  if (escalation.escalatedTo !== session.userId) {\\n    throw new Error(\\\"Only the escalation recipient can resolve it\\\");\\n  }\\n\\n  const updated = await updateEscalationStatus(db, escalationId, \\\"resolved\\\");\\n\\n  broker.emit({\\n    type: \\\"audit.requested\\\",\\n    payload: {\\n      userId: session.userId,\\n      action: \\\"escalation.resolved\\\",\\n      resourceType: \\\"escalation\\\",\\n      resourceId: escalationId,\\n      details: {\\n        applicationId: escalation.applicationId,\\n      },\\n    },\\n  });\\n\\n  return updated;\\n}\\n\\nexport async function getEscalationsForApplication(\\n  db: Database,\\n  applicationId: string\\n): Promise<Escalation[]> {\\n  return findEscalationsByApplication(db, applicationId);\\n}\\n\\nexport async function getPendingEscalationsForUser(\\n  db: Database,\\n  userId: string\\n): Promise<Escalation[]> {\\n  return findEscalationsByRecipient(db, userId);\\n}\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\ghctx-tut\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\src\\\\services\\\\escalation-service.ts\"}",
