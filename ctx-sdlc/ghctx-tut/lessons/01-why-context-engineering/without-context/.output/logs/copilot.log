              "arguments": "{\"file_text\":\"// ---------------------------------------------------------------------------\\n// Escalation Service\\n// ---------------------------------------------------------------------------\\n// Orchestrates escalation operations: creation, resolution, and retrieval.\\n// Delegates persistence to the escalation repository, and event emission\\n// to the broker.\\n\\nimport { v4 as uuid } from \\\"uuid\\\";\\nimport * as escalationRepo from \\\"../models/escalation-repository.js\\\";\\nimport * as loanRepo from \\\"../models/loan-repository.js\\\";\\nimport { getDb } from \\\"../db/connection.js\\\";\\nimport { broker } from \\\"../queue/broker.js\\\";\\nimport type {\\n  Escalation,\\n  SessionContext,\\n  LoanApplication,\\n} from \\\"../models/types.js\\\";\\nimport type {\\n  EscalationRequestedEvent,\\n  AuditRequestedEvent,\\n  NotificationRequestedEvent,\\n} from \\\"../queue/contracts.js\\\";\\n\\n/**\\n * Escalate a loan application for higher-level review.\\n *\\n * Validation:\\n *  - Application must exist and be in \\\"underwriting\\\" or \\\"decision\\\" state.\\n *  - Recipient user must exist.\\n *  - Reason must not be empty.\\n *  - Delegated sessions cannot create escalations.\\n *  - Emits audit, notification, and escalation events.\\n */\\nexport function escalateReview(\\n  session: SessionContext,\\n  applicationId: string,\\n  escalatedToUserId: string,\\n  reason: string,\\n): Escalation {\\n  if (session.delegatedFor) {\\n    throw new Error(\\\"FORBIDDEN: Delegated sessions cannot escalate reviews.\\\");\\n  }\\n\\n  if (!reason || reason.trim().length === 0) {\\n    throw new Error(\\\"VALIDATION: Reason cannot be empty.\\\");\\n  }\\n\\n  const application = loanRepo.findLoanById(applicationId);\\n  if (!application) {\\n    throw new Error(`NOT_FOUND: Application '${applicationId}' not found.`);\\n  }\\n\\n  if (application.status !== \\\"underwriting\\\" && application.status !== \\\"decision\\\") {\\n    throw new Error(\\n      `INVALID_STATE: Cannot escalate application in '${application.status}' state. ` +\\n        \\\"Expected 'underwriting' or 'decision'.\\\",\\n    );\\n  }\\n\\n  // Verify recipient exists\\n  const db = getDb();\\n  const recipientExists = db\\n    .prepare(\\\"SELECT id FROM users WHERE id = ?\\\")\\n    .get(escalatedToUserId);\\n  if (!recipientExists) {\\n    throw new Error(`NOT_FOUND: User '${escalatedToUserId}' not found.`);\\n  }\\n\\n  // Create escalation\\n  const escalation = escalationRepo.createEscalation({\\n    applicationId,\\n    escalatedBy: session.actor.id,\\n    escalatedTo: escalatedToUserId,\\n    reason,\\n  });\\n\\n  // Emit audit event\\n  const auditEvent: AuditRequestedEvent = {\\n    eventId: uuid(),\\n    timestamp: new Date().toISOString(),\\n    source: \\\"escalation-service\\\",\\n    type: \\\"audit.requested\\\",\\n    payload: {\\n      action: \\\"escalation.created\\\",\\n      actor: session.actor.id,\\n      previousValue: undefined,\\n      newValue: escalation,\\n      source: \\\"escalation-service\\\",\\n    },\\n  };\\n  broker.emit(auditEvent);\\n\\n  // Emit notification event for the escalation recipient\\n  const notifEvent: NotificationRequestedEvent = {\\n    eventId: uuid(),\\n    timestamp: new Date().toISOString(),\\n    source: \\\"escalation-service\\\",\\n    type: \\\"notification.requested\\\",\\n    payload: {\\n      userId: escalatedToUserId,\\n      event: \\\"manual-review-escalation\\\",\\n      subject: `Escalation: Application ${applicationId} requires your review`,\\n      body: `Application ${applicationId} has been escalated for your review. Reason: ${reason}`,\\n      preferredChannel: \\\"email\\\",\\n    },\\n  };\\n  broker.emit(notifEvent);\\n\\n  // Emit escalation event for extensibility\\n  const escalationEvent: EscalationRequestedEvent = {\\n    eventId: uuid(),\\n    timestamp: new Date().toISOString(),\\n    source: \\\"escalation-service\\\",\\n    type: \\\"escalation.requested\\\",\\n    payload: {\\n      escalationId: escalation.id,\\n      applicationId,\\n      escalatedBy: session.actor.id,\\n      escalatedTo: escalatedToUserId,\\n      reason,\\n    },\\n  };\\n  broker.emit(escalationEvent);\\n\\n  return escalation;\\n}\\n\\n/**\\n * Resolve an escalation (mark as resolved).\\n *\\n * Validation:\\n *  - Escalation must exist and be in \\\"pending\\\" status.\\n *  - Only the escalation recipient can resolve it.\\n *  - Emits audit event.\\n */\\nexport function resolveEscalation(\\n  session: SessionContext,\\n  escalationId: string,\\n): Escalation {\\n  const escalation = escalationRepo.findEscalationById(escalationId);\\n  if (!escalation) {\\n    throw new Error(`NOT_FOUND: Escalation '${escalationId}' not found.`);\\n  }\\n\\n  if (escalation.status !== \\\"pending\\\") {\\n    throw new Error(\\n      `INVALID_STATE: Cannot resolve escalation in '${escalation.status}' state. ` +\\n        \\\"Expected 'pending'.\\\",\\n    );\\n  }\\n\\n  // Only recipient can resolve\\n  if (escalation.escalatedTo !== session.actor.id) {\\n    throw new Error(\\n      \\\"FORBIDDEN: Only the escalation recipient can resolve it.\\\",\\n    );\\n  }\\n\\n  const updated = escalationRepo.updateEscalationStatus(\\n    escalationId,\\n    \\\"resolved\\\",\\n  );\\n  if (!updated) {\\n    throw new Error(`NOT_FOUND: Escalation '${escalationId}' not found.`);\\n  }\\n\\n  // Emit audit event\\n  const auditEvent: AuditRequestedEvent = {\\n    eventId: uuid(),\\n    timestamp: new Date().toISOString(),\\n    source: \\\"escalation-service\\\",\\n    type: \\\"audit.requested\\\",\\n    payload: {\\n      action: \\\"escalation.resolved\\\",\\n      actor: session.actor.id,\\n      previousValue: { status: escalation.status },\\n      newValue: { status: updated.status },\\n      source: \\\"escalation-service\\\",\\n    },\\n  };\\n  broker.emit(auditEvent);\\n\\n  return updated;\\n}\\n\\n/**\\n * Get all escalations for a specific application.\\n */\\nexport function getEscalationsForApplication(\\n  applicationId: string,\\n): Escalation[] {\\n  return escalationRepo.findEscalationsByApplication(applicationId);\\n}\\n\\n/**\\n * Get all pending escalations assigned to the current user.\\n */\\nexport function getPendingEscalationsForUser(userId: string): Escalation[] {\\n  return escalationRepo.findEscalationsByRecipient(userId);\\n}\\n\",\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\01-why-context-engineering\\\\without-context\\\\src\\\\backend\\\\src\\\\services\\\\escalation-service.ts\"}",
