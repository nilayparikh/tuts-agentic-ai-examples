,\"path\":\"Y:\\\\.sources\\\\localm-tuts\\\\courses\\\\_examples\\\\ctx-sdlc\\\\lessons\\\\01-why-context-engineering\\\\with-context\\\\src\\\\backend\\\\src\\\\services\\\\loan-service.ts\"}",
