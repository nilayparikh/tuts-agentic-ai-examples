+/**
+ * Request manual review escalation for a loan application.
+ * Emits a notification.requested event and audits the action.
+ * Does not change the loan's lifecycle status.
+ */
+export function requestManualReview(
+  session: SessionContext,
+  applicationId: string,
+): { ok: boolean; applicationId: string; notificationEventId: string } {
+  if (session.delegatedFor) {
+    throw new Error("FORBIDDEN: Delegated sessions cannot request manual review.");
+  }
+
+  const loan = loanRepo.findLoanById(applicationId);
+  if (!loan) {
+    throw new Error(`NOT_FOUND: Application '${applicationId}' not found.`);
+  }
+
+  const eventId = uuid();
+
+  // Build notification subject with California high-risk prefix if applicable
+  let subject = "Manual Review Escalation Requested";
+  if (
+    featureFlags.californiaRules &&
+    loan.loanState === "CA" &&
+    loan.amount >= 1000000
+  ) {
+    subject = "[CA-HighRisk] " + subject;
+  }
+
+  // Emit notification event
+  const notifEvent: NotificationRequestedEvent = {
+    eventId,
+    timestamp: new Date().toISOString(),
+    source: "loan-service",
+    type: "notification.requested",
+    payload: {
+      userId: loan.assignedUnderwriter,
+      event: "manual-review-escalation",
+      subject,
+      body: `Manual review has been requested for loan application ${applicationId} (${loan.borrowerName}, $${loan.amount.toLocaleString()}).`,
+      preferredChannel: "email",
+    },
+  };
+  broker.emit(notifEvent);
+
+  // Audit the action
+  auditAction(
+    session,
+    "loan.manual-review-requested",
+    null,
+    { applicationId, initiatedBy: session.actor.id },
+    "loan-service",
+  );
+
+  return {
+    ok: true,
+    applicationId,
+    notificationEventId: eventId,
+  };
+}
