or California loanState.\",\n+    };\n+  }\n+\n+  if (\n+    nextPreference.event !== \"manual-review-escalation\" ||\n+    nextPreference.enabled\n+  ) {\n+    return ALLOWED_WRITE;\n+  }\n+\n+  const otherChannel = otherNotificationChannel(nextPreference.channel);\n+  const otherPreference = existingPreferences.find(\n+    (preference) =>\n+      preference.event === \"manual-review-escalation\" &&\n+      preference.channel === otherChannel,\n+  );\n+\n+  if (otherPreference?.enabled === false) {\n+    return {\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one channel enabled.\",\n+    };\n+  }\n+\n+  return ALLOWED_WRITE;\n+}\n+\n+function otherNotificationChannel(\n+  channel: NotificationChannel,\n+): NotificationChannel {\n+  return channel === \"email\" ? \"sms\" : \"email\";\n+}\n+\n+function isCaliforniaLoanState(loanState: string): boolean {\n+  const normalized = loanState.trim().toLowerCase();\n+  return normalized === \"ca\" || normalized === \"california\";\n+}\n*** End Patch\n"
