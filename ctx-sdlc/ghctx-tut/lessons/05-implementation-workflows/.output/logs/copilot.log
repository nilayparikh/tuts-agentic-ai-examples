    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\ghctx-tut\\lessons\\05-implementation-workflows\\src\\backend\\src\\rules\\notification-preference-write-rules.ts\n+// ---------------------------------------------------------------------------\n+// Notification Preference Write Rules\n+// ---------------------------------------------------------------------------\n+// FALSE POSITIVE: disabling manual-review-escalation SMS is allowed when email\n+// remains enabled. The invariant is \"at least one channel\", not \"all channels\".\n+//\n+// HARD NEGATIVE: rejecting only a specific channel toggle is insufficient if\n+// the write would leave manual-review-escalation with zero enabled channels.\n+//\n+// LEGAL-218: decline SMS cannot be enabled for California loan contexts.\n+// ---------------------------------------------------------------------------\n+\n+import type {\n+  NotificationChannel,\n+  NotificationPreference,\n+} from \"../models/types.js\";\n+\n+export interface NotificationPreferenceWriteInput {\n+  nextPreference: Pick<NotificationPreference, \"event\" | \"channel\" | \"enabled\">;\n+  existingPreferences: NotificationPreference[];\n+  loanState: string;\n+}\n+\n+export interface NotificationPreferenceWriteRule {\n+  allowed: boolean;\n+  reason: string;\n+}\n+\n+const ALLOWED_WRITE: NotificationPreferenceWriteRule = {\n+  allowed: true,\n+  reason: \"Notification preference write allowed.\",\n+};\n+\n+export function validateNotificationPreferenceWrite(\n+  input: NotificationPreferenceWriteInput,\n+): NotificationPreferenceWriteRule {\n+  const { nextPreference, existingPreferences, loanState } = input;\n+\n+  if (\n+    nextPreference.event === \"decline\" &&\n+    nextPreference.channel === \"sms\" &&\n+    nextPreference.enabled &&\n+    isCaliforniaLoanState(loanState)\n+  ) {\n+    return {\n+      allowed: false,\n+      reason:\n+        \"LEGAL-218: decline SMS cannot be enabled for California loanState.\",\n+    };\n+  }\n+\n+  if (\n+    nextPreference.event !== \"manual-review-escalation\" ||\n+    nextPreference.enabled\n+  ) {\n+    return ALLOWED_WRITE;\n+  }\n+\n+  const otherChannel = otherNotificationChannel(nextPreference.channel);\n+  const otherPreference = existingPreferences.find(\n+    (preference) =>\n+      preference.event === \"manual-review-escalation\" &&\n+      preference.channel === otherChannel,\n+  );\n+\n+  if (otherPreference?.enabled === false) {\n+    return {\n+      allowed: false,\n+      reason:\n+        \"manual-review-escalation must keep at least one channel enabled.\",\n+    };\n+  }\n+\n+  return ALLOWED_WRITE;\n+}\n+\n+function otherNotificationChannel(\n+  channel: NotificationChannel,\n+): NotificationChannel {\n+  return channel === \"email\" ? \"sms\" : \"email\";\n+}\n+\n+function isCaliforniaLoanState(loanState: string): boolean {\n+  const normalized = loanState.trim().toLowerCase();\n+  return normalized === \"ca\" || normalized === \"california\";\n+}\n*** End Patch\n",
    "call_id": "call_h9V0EOomoYLgBSAmk7FBX4pt"
  },
