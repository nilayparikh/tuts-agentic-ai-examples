    "type": "custom_tool_call",
    "id": "ctc_call_uchuhE4GmtQfAJf1u4cG8OiA",
    "name": "apply_patch",
    "input": "*** Begin Patch\n*** Add File: Y:\\.sources\\localm-tuts\\courses\\_examples\\ctx-sdlc\\ghctx-tut\\lessons\\05-implementation-workflows\\src\\backend\\tests\\unit\\notification-preference-write-rules.test.ts\n+import { beforeAll, beforeEach, describe, expect, it, vi } from \"vitest\";\n+import type { NotificationPreference } from \"../../src/models/types.js\";\n+\n+const preferenceRepoMock = vi.hoisted(() => ({\n+  findPreference: vi.fn(),\n+  findPreferencesForUser: vi.fn(),\n+  setPreference: vi.fn(),\n+}));\n+\n+const auditServiceMock = vi.hoisted(() => ({\n+  auditAction: vi.fn(),\n+}));\n+\n+vi.mock(\"../../src/models/preference-repository.js\", () => preferenceRepoMock);\n+vi.mock(\"../../src/services/audit-service.js\", () => auditServiceMock);\n+\n+let validateNotificationPreferenceWrite: (\n+  input: {\n+    nextPreference: Pick<\n+      NotificationPreference,\n+      \"event\" | \"channel\" | \"enabled\"\n+    >;\n+    existingPreferences: NotificationPreference[];\n+    loanState: string;\n+  },\n+) => { allowed: boolean; reason: string };\n+\n+let notificationRoutes: unknown;\n+\n+function buildPreference(\n+  overrides: Partial<NotificationPreference>,\n+): NotificationPreference {\n+  return {\n+    userId: \"user-1\",\n+    event: \"manual-review-escalation\",\n+    channel: \"email\",\n+    enabled: true,\n+    updatedAt: \"2026-04-16T00:00:00.000Z\",\n+    updatedBy: \"user-1\",\n+    ...overrides,\n+  };\n+}\n+\n+function normalizeText(value: unknown): string {\n+  return String(value).toLowerCase().replace(/\\s+/g, \" \").trim();\n+}\n+\n+function getPutPreferencesHandler(): (\n+  req: Record<string, unknown>,\n+  res: {\n+    status: (code: number) => unknown;\n+    json: (payload: unknown) => unknown;\n+  },\n+  next: (error?: unknown) => void,\n+) => void {\n+  const routeLayer = (notificationRoutes as {\n+    stack: Array<{\n+      route?: {\n+        path: string;\n+        methods: Record<string, boolean>;\n+        stack: Array<{ handle: (...args: unknown[]) => void }>;\n+      };\n+    }>;\n+  }).stack.find(\n+    (layer) => layer.route?.path === \"/preferences\" && layer.route.methods.put,\n+  );\n+\n+  if (!routeLayer?.route) {\n+    throw new Error(\"PUT /preferences route not found.\");\n+  }\n+\n+  return routeLayer.route.stack[routeLayer.route.stack.length - 1]\n+    .handle as typeof getPutPreferencesHandler extends () => infer T ? T : never;\n+}\n+\n+function createResponse() {\n+  return {\n+    statusCode: 200,\n+    body: undefined as unknown,\n+    status(code: number) {\n+      this.statusCode = code;\n+      return this;\n+    },\n+    json(payload: unknown) {\n+      this.body = payload;\n+      return this;\n+    },\n+  };\n+}\n+\n+beforeAll(async () => {\n+  ({ validateNotificationPreferenceWrite } = await import(\n+    \"../../src/rules/notification-preference-write-rules.js\"\n+  ));\n+  ({ notificationRoutes } = await import(\"../../src/routes/notifications.js\"));\n+});\n+\n+beforeEach(() => {\n+  vi.clearAllMocks();\n+});\n+\n+describe(\"validateNotificationPreferenceWrite\", () => {\n+  it(\"allows disabling escalation sms when escalation email remains enabled\", () => {\n+    // FALSE POSITIVE: SMS can be disabled when email still preserves the mandatory event.\n+    const result = validateNotificationPreferenceWrite({\n+      nextPreference: {\n+        event: \"manual-review-escalation\",\n+        channel: \"sms\",\n+        enabled: false,\n+      },\n+      existingPreferences: [\n+        buildPreference({ event: \"manual-review-escalation\", channel: \"email\" }),\n+        buildPreference({\n+          event: \"manual-review-escalation\",\n+          channel: \"sms\",\n+          enabled: true,\n+        }),\n+      ],\n+      loanState: \"NY\",\n+    });\n+\n+    expect(result.allowed).toBe(true);\n+  });\n+\n+  it(\"rejects disabling the last enabled escalation channel\", () => {\n+    // HARD NEGATIVE: manual-review-escalation must never end up with zero enabled channels.\n+    const result = validateNotificationPreferenceWrite({\n+      nextPreference: {\n+        event: \"manual-review-escalation\",\n+        channel: \"email\",\n+        enabled: false,\n+      },\n+      existingPreferences: [\n+        buildPreference({ event: \"manual-review-escalation\", channel: \"email\" }),\n+        buildPreference({\n+          event: \"manual-review-escalation\",\n+          channel: \"sms\",\n+          enabled: false,\n+        }),\n+      ],\n+      loanState: \"NY\",\n+    });\n+\n+    const reason = normalizeText(result.reason);\n+\n+    expect(result.allowed).toBe(false);\n+    expect(reason).toContain(\"manual-review-escalation\");\n+    expect(reason).toContain(\"at least one\");\n+  });\n+\n+  it.each([\"CA\", \"California\"])(\n+    \"rejects enabling decline sms for %s loan state under LEGAL-218\",\n+    (loanState) => {\n+      const result = validateNotificationPreferenceWrite({\n+        nextPreference: {\n+          event: \"decline\",\n+          channel: \"sms\",\n+          enabled: true,\n+        },\n+        existingPreferences: [],\n+        loanState,\n+      });\n+\n+      const reason = normalizeText(result.reason);\n+\n+      expect(result.allowed).toBe(false);\n+      expect(reason).toContain(\"legal-218\");\n+      expect(reason).toContain(\"decline\");\n+      expect(reason).toContain(\"sms\");\n+    },\n+  );\n+\n+  it(\"allows enabling decline sms for non-California loan state\", () => {\n+    const result = validateNotificationPreferenceWrite({\n+      nextPreference: {\n+        event: \"decline\",\n+        channel: \"sms\",\n+        enabled: true,\n+      },\n+      existingPreferences: [],\n+      loanState: \"NV\",\n+    });\n+\n+    expect(result.allowed).toBe(true);\n+  });\n+});\n+\n+describe(\"PUT /preferences route hardening\", () => {\n+  it(\"returns 400 with escalation invariant details when the write would disable the last channel\", () => {\n+    const handler = getPut