@@ -0,0 +1,387 @@
+import { beforeEach, describe, expect, it, vi } from "vitest";
+
+vi.mock("../../src/models/preference-repository.js", () => ({
+  findPreference: vi.fn(),
+  findPreferencesForUser: vi.fn(),
+  setPreference: vi.fn(),
+}));
+
+vi.mock("../../src/services/audit-service.js", () => ({
+  auditAction: vi.fn(),
+}));
+
+import { notificationRoutes } from "../../src/routes/notifications.js";
+import * as prefRepo from "../../src/models/preference-repository.js";
+import { validateNotificationPreferenceWrite } from "../../src/rules/notification-preference-write-rules.js";
+import type {
+  NotificationPreference,
+  SessionContext,
+} from "../../src/models/types.js";
+
+function buildPreference(
+  overrides: Partial<NotificationPreference>,
+): NotificationPreference {
+  return {
+    userId: "u-1",
+    event: "approval",
+    channel: "email",
+    enabled: true,
+    updatedAt: "2026-04-16T00:00:00.000Z",
+    updatedBy: "u-1",
+    ...overrides,
+  };
+}
+
+function createSession(
+  overrides: Partial<SessionContext> = {},
+): SessionContext {
+  return {
+    actor: {
+      id: "u-1",
+      role: "underwriter",
+      name: "Under Writer",
+      email: "uw@example.com",
+    },
+    ...overrides,
+  };
+}
+
+function normalize(value: unknown): string {
+  return String(value ?? "").toLowerCase();
+}
+
+function createMockResponse() {
+  return {
+    statusCode: 200,
+    body: undefined as unknown,
+    status(code: number) {
+      this.statusCode = code;
+      return this;
+    },
+    json(payload: unknown) {
+      this.body = payload;
+      return this;
+    },
+  };
+}
+
+function invokePutPreferenceRoute(args: {
+  body: Record<string, unknown>;
+  session?: SessionContext;
+}) {
+  const routeLayer = (notificationRoutes as any).stack.find(
+    (layer: any) =>
+      layer.route?.path === "/preferences" && layer.route?.methods?.put,
+  );
+
+  if (!routeLayer?.route) {
+    throw new Error("PUT /preferences route not found.");
+  }
+
+  const handlers = routeLayer.route.stack.map((layer: any) => layer.handle);
+  const req = {
+    body: args.body,
+    params: {},
+    path: "/preferences",
+    session: args.session,
+  } as any;
+  const res = createMockResponse();
+  let forwardedError: unknown;
+
+  const run = (index: number): void => {
+    const handler = handlers[index];
+    if (!handler) {
+      return;
+    }
+
+    handler(req, res, (err?: unknown) => {
+      if (err) {
+        forwardedError = err;
+        return;
+      }
+
+      run(index + 1);
+    });
+  };
+
+  run(0);
+
+  return { res, forwardedError };
+}
+
+beforeEach(() => {
+  vi.clearAllMocks();
+  vi.mocked(prefRepo.findPreference).mockReturnValue(undefined);
+  vi.mocked(prefRepo.findPreferencesForUser).mockReturnValue([]);
+});
+
+describe("validateNotificationPreferenceWrite", () => {
+  describe("Happy path", () => {
+    it("allows ordinary preference updates", () => {
+      expect(
+        validateNotificationPreferenceWrite({
+          nextPreference: {
+            event: "approval",
+            channel: "email",
+            enabled: false,
+          },
+          existingPreferences: [],
+          loanState: "NY",
+        }),
+      ).toEqual({ allowed: true });
+    });
+  });
+
+  describe("False positive", () => {
+    it("allows disabling escalation SMS when escalation email stays enabled", () => {
+      expect(
+        validateNotificationPreferenceWrite({
+          nextPreference: {
+            event: "manual-review-escalation",
+            channel: "sms",
+            enabled: false,
+          },
+          existingPreferences: [
+            buildPreference({
+              event: "manual-review-escalation",
+              channel: "email",
+              enabled: true,
+            }),
+            buildPreference({
+              event: "manual-review-escalation",
+              channel: "sms",
+              enabled: true,
+            }),
+          ],
+          loanState: "NY",
+        }),
+      ).toEqual({ allowed: true });
+    });
+  });
+
+  describe("Hard negative", () => {
+    it("rejects disabling the last escalation channel", () => {
+      const result = validateNotificationPreferenceWrite({
+        nextPreference: {
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: false,
+        },
+        existingPreferences: [
+          buildPreference({
+            event: "manual-review-escalation",
+            channel: "email",
+            enabled: false,
+          }),
+          buildPreference({
+            event: "manual-review-escalation",
+            channel: "sms",
+            enabled: true,
+          }),
+        ],
+        loanState: "NY",
+      });
+
+      expect({
+        allowed: result.allowed,
+        reason: normalize(result.reason),
+      }).toEqual(
+        expect.objectContaining({
+          allowed: false,
+          reason: expect.stringMatching(
+            /(manual-review-escalation|escalation).*(at least one)|(at least one).*(manual-review-escalation|escalation)/,
+          ),
+        }),
+      );
+    });
+  });
+
+  describe("LEGAL-218", () => {
+    it("rejects enabling decline SMS for CA loan context", () => {
+      const result = validateNotificationPreferenceWrite({
+        nextPreference: {
+          event: "decline",
+          channel: "sms",
+          enabled: true,
+        },
+        existingPreferences: [],
+        loanState: "CA",
+      });
+
+      expect({
+        allowed: result.allowed,
+        reason: normalize(result.reason),
+      }).toEqual(
+        expect.objectContaining({
+          allowed: false,
+          reason: expect.stringMatching(
+            /(decline.*sms.*legal-218)|(legal-218.*decline.*sms)/,
+          ),
+        }),
+      );
+    });
+
+    it("treats California as the same restricted loan state", () => {
+      expect(
+        validateNotificationPreferenceWrite({
+          nextPreference: {
+            event: "decline",
+            channel: "sms",
+            enabled: true,
+          },
+          existingPreferences: [],
+          loanState: "California",
+        }).allowed,
+      ).toBe(false);
+    });
+  });
+});
+
+describe("PUT /preferences", () => {
+  describe("False positive", () => {
+    it("keeps allowing escalation SMS disable when email remains enabled", () => {
+      vi.mocked(prefRepo.findPreferencesForUser).mockReturnValue([
+        buildPreference({
+          event: "manual-review-escalation",
+          channel: "email",
+          enabled: true,
+        }),
+        buildPreference({
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: true,
+        }),
+      ]);
+      vi.mocked(prefRepo.findPreference).mockReturnValue(
+        buildPreference({
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: true,
+        }),
+      );
+
+      const { res, forwardedError } = invokePutPreferenceRoute({
+        session: createSession(),
+        body: {
+          userId: "u-1",
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: false,
+        },
+      });
+
+      expect({
+        statusCode: res.statusCode,
+        body: res.body,
+        persisted: vi.mocked(prefRepo.setPreference).mock.calls.length,
+        forwardedError,
+      }).toEqual({
+        statusCode: 200,
+        body: expect.objectContaining({
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: false,
+        }),
+        persisted: 1,
+        forwardedError: undefined,
+      });
+    });
+  });
+
+  describe("Hard negative", () => {
+    it("rejects disabling the last escalation channel with a business invariant message", () => {
+      vi.mocked(prefRepo.findPreferencesForUser).mockReturnValue([
+        buildPreference({
+          event: "manual-review-escalation",
+          channel: "email",
+          enabled: false,
+        }),
+        buildPreference({
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: true,
+        }),
+      ]);
+      vi.mocked(prefRepo.findPreference).mockReturnValue(
+        buildPreference({
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: true,
+        }),
+      );
+
+      const { res, forwardedError } = invokePutPreferenceRoute({
+        session: createSession(),
+        body: {
+          userId: "u-1",
+          event: "manual-review-escalation",
+          channel: "sms",
+          enabled: false,
+        },
+      });
+
+      expect({
+        statusCode: res.statusCode,
+        error: normalize((res.body as { error?: string } | undefined)?.error),
+        persisted: vi.mocked(prefRepo.setPreference).mock.calls.length,
+        forwardedError,
+      }).toEqual({
+        statusCode: 400,
+        error: expect.stringMatching(
+          /(manual-review-escalation|escalation).*(at least one)|(at least one).*(manual-review-escalation|escalation)/,
+        ),
+        persisted: 0,
+        forwardedError: undefined,
+      });
+    });
+  });
+
+  describe("LEGAL-218", () => {
+    it("rejects California decline SMS enable with a clear business invariant message", () => {
+      vi.mocked(prefRepo.findPreferencesForUser).mockReturnValue([
+        buildPreference({
+          event: "decline",
+          channel: "email",
+          enabled: true,
+        }),
+        buildPreference({
+          event: "decline",
+          channel: "sms",
+          enabled: false,
+        }),
+      ]);
+      vi.mocked(prefRepo.findPreference).mockReturnValue(
+        buildPreference({
+          event: "decline",
+          channel: "sms",
+          enabled: false,
+        }),
+      );
+
+      const { res, forwardedError } = invokePutPreferenceRoute({
+        session: createSession(),
+        body: {
+          userId: "u-1",
+          event: "decline",
+          channel: "sms",
+          enabled: true,
+          loanState: "California",
+        },
+      });
+
+      expect({
+        statusCode: res.statusCode,
+        error: normalize((res.body as { error?: string } | undefined)?.error),
+        persisted: vi.mocked(prefRepo.setPreference).mock.calls.length,
+        forwardedError,
+      }).toEqual({
+        statusCode: 400,
+        error: expect.stringMatching(
+          /(decline.*sms.*legal-218)|(legal-218.*decline.*sms)/,
+        ),
+        persisted: 0,
+        forwardedError: undefined,
+      });
+    });
+  });
+});
