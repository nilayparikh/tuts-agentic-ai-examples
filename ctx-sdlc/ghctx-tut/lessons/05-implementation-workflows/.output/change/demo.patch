--- a/backend/src/rules/notification-preference-write-rules.ts
+++ b/backend/src/rules/notification-preference-write-rules.ts
@@ -0,0 +1,94 @@
+// ---------------------------------------------------------------------------
+// Notification Preference Write Rules
+// ---------------------------------------------------------------------------
+// FALSE POSITIVE: Disabling manual-review-escalation SMS is allowed when the
+// email channel stays enabled. The violation is zero enabled channels, not a
+// specific channel being turned off.
+//
+// HARD NEGATIVE: Reject writes that leave manual-review-escalation with no
+// enabled channels, and reject enabling decline SMS for California loan
+// context while LEGAL-218 remains in effect.
+// ---------------------------------------------------------------------------
+
+import type {
+  LoanApplication,
+  NotificationChannel,
+  NotificationPreference,
+} from "../models/types.js";
+
+export interface NotificationPreferenceWriteRule {
+  allowed: boolean;
+  reason?: string;
+}
+
+export interface NotificationPreferenceWriteInput {
+  nextPreference: Pick<
+    NotificationPreference,
+    "event" | "channel" | "enabled"
+  >;
+  existingPreferences: NotificationPreference[];
+  loanState?: LoanApplication["loanState"];
+}
+
+const ESCALATION_CHANNELS: NotificationChannel[] = ["email", "sms"];
+
+function isCaliforniaLoanState(
+  loanState?: LoanApplication["loanState"],
+): boolean {
+  const normalized = loanState?.trim().toLowerCase();
+  return normalized === "ca" || normalized === "california";
+}
+
+function isChannelEnabledAfterWrite(
+  input: NotificationPreferenceWriteInput,
+  channel: NotificationChannel,
+): boolean {
+  if (
+    input.nextPreference.event === "manual-review-escalation" &&
+    input.nextPreference.channel === channel
+  ) {
+    return input.nextPreference.enabled;
+  }
+
+  return Boolean(
+    input.existingPreferences.find(
+      (preference) =>
+        preference.event === "manual-review-escalation" &&
+        preference.channel === channel,
+    )?.enabled,
+  );
+}
+
+export function validateNotificationPreferenceWrite(
+  input: NotificationPreferenceWriteInput,
+): NotificationPreferenceWriteRule {
+  if (
+    input.nextPreference.event === "decline" &&
+    input.nextPreference.channel === "sms" &&
+    input.nextPreference.enabled &&
+    isCaliforniaLoanState(input.loanState)
+  ) {
+    // LEGAL-218: California decline SMS must remain disabled.
+    return {
+      allowed: false,
+      reason:
+        "LEGAL-218 prevents enabling decline SMS for California loan context.",
+    };
+  }
+
+  if (input.nextPreference.event === "manual-review-escalation") {
+    const hasEnabledEscalationChannel = ESCALATION_CHANNELS.some((channel) =>
+      isChannelEnabledAfterWrite(input, channel),
+    );
+
+    if (!hasEnabledEscalationChannel) {
+      return {
+        allowed: false,
+        reason:
+          "manual-review-escalation must keep at least one notification channel enabled.",
+      };
+    }
+  }
+
+  return { allowed: true };
+}

--- a/backend/tests/unit/notification-preference-write-rules.test.ts
