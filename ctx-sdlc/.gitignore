# ── App source copied by util.py ──
# Each lesson's src/ is populated from the root app/.
# Run `python util.py --setup` in each lesson to recreate.
lessons/*/src/

# ── Runtime / build artifacts ──
node_modules/
dist/
.venv/
*.db
data/

# ── Python bytecode ──
__pycache__/
*.pyc
*.egg-info/

# ── Environment ──
.env
