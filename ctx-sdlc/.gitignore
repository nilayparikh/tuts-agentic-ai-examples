# ── App source copied by util.py ──
# Each lesson's src/ is populated from the root app/.
# Run `python util.py --setup` in each lesson to recreate.
lessons/**/src/

# ── Runtime / build artifacts ──
node_modules/
dist/
.venv/
*.db
data/

# ── Python bytecode ──
__pycache__/
*.pyc
*.egg-info/

# ── Environment ──
.env

# ── Captured lesson demo outputs (track selected files) ──
!lessons/**/.output/logs/
!lessons/**/.output/logs/command.txt
!lessons/**/.output/logs/prompt.txt
!lessons/**/.output/logs/session.md
!lessons/**/.output/logs/*.log
!lessons/**/.output/change/
!lessons/**/.output/change/*.patch
!lessons/**/.output/change/changed-files.json