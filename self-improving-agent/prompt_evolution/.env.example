# Optional local override for Prompt Evolution Studio.
# If this file is copied to .env, values here override nothing already set in
# the shell and are loaded before ../.env.

LLM_ENDPOINT=
LLM_API_KEY=
MODEL_NAME=gpt-4.1-mini
LLM_API_VERSION=2024-12-01-preview

# Legacy OpenAI-compatible fallbacks also work:
# OPENAI_BASE_URL=
# OPENAI_API_KEY=
# AZURE_ENDPOINT=
# AZURE_API_KEY=
# AZURE_OPENAI_DEPLOY_NAME=
